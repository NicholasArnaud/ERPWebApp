@page
@model UserPreferencesModel
@{
    ViewData["Title"] = "User Preference";
    ViewData["ActivePage"] = ManageNavPages.UserPreferences;
}

<div class="container-fluid text-white">
    <form method="post">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="card-title">My Preference</h2>
                <div>
                    <button type="submit" name="submit" class="action-button btn btn-primary"><span class="mdi mdi-18px mdi-content-save">&nbsp;Save</span></button>
                </div>
            </div>
            <div class="justify-content-center">
                <div class="card mb-4">
                    <div class="card-body justify-content-center">
                        <div class="row">
                            <div class="form-group">
                                <label class="control-label">Dashboard</label>
                                <select asp-for="SelectedDashBoard" class="form-control" id="selector-ashboard" asp-items="Model.DashBoards">
                                </select>
                            </div>
                        </div>
                        <hr>
                        <div class="row">
                            <div class="form-group">
                                <label class="control-label">Themes</label>
                                <select asp-for="SelectedTheme" class="form-control" id="selector-theme" asp-items="Model.Theme" data-placeholder="Select Theme">
                                </select>
                            </div>
                        </div>
                        <hr>
                        <div class="row">
                            <div class="form-group">
                                <label class="control-label">Departments</label>
                                <select asp-for="SelectedDepartment" class="form-control" id="selector-department" asp-items="Model.Departments" data-placeholder="Select Department">
                                    <option value="">All</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
