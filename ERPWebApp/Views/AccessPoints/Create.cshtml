@model ERPWebApp.Models.Company.Security.AccessPoint
@namespace ERPWebApp.Models.Company.Security
@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Create</h1>

<h4>AccessPoint</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group p-1">
                <label asp-for="AccessPointLocation" class="control-label"></label>
                <input asp-for="AccessPointLocation" class="form-control" />
                <span asp-validation-for="AccessPointLocation" class="text-danger"></span>
            </div>
            <div class="form-group p-1">
                <label asp-for="IpAddress" class="control-label"></label>
                <input asp-for="IpAddress" class="form-control" placeholder="255.255.255.255"/>
                <span asp-validation-for="IpAddress" class="text-danger"></span>
            </div>
            <div class="form-group p-1">
                <label asp-for="MacAddress" class="control-label"></label>
                <input asp-for="MacAddress" class="form-control" placeholder="1A:2B:3C:4D:5E:6F"/>
                <span asp-validation-for="MacAddress" class="text-danger"></span>
            </div>
            <div class="form-group p-1">
                <label asp-for="SerialNumber" class="control-label"></label>
                <input asp-for="SerialNumber" class="form-control"/>
                <span asp-validation-for="SerialNumber" class="text-danger"></span>
            </div>
            <div class="form-group p-1">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" asp-items="@Html.GetEnumSelectList<AccessPointStatus>()" class="form-control"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsActive" checked/> @Html.DisplayNameFor(model => model.IsActive)
                </label>
            </div>
            <div class="form-group p-2">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a class="p-2" asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
