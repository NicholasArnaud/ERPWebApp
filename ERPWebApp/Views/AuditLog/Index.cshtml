@model IEnumerable<ERPWebApp.Data.DTOModels.AuditLogDTO>


@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<head>
    <link rel="stylesheet" type="text/css" href="~/css/datatablecoloring.css">
    <link rel="stylesheet" type="text/css" href="~/css/sliderbutton.css">
</head>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Audit Logs</h3>
            </div>
            <div class="card-body">
                <div class="row">

                    <div id="filtered-orders-partial">
                        @{
                            <table class="table dt-responsive webkit-nowrap w-100" id="auditlog-datatable">
                                <thead>
                                    <tr>
                                        <th>
                                            @Html.DisplayNameFor(model => model.User)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.Timestamp)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.BusinessEntity)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.PropertyName)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.OldValue)
                                        </th>
                                        <th>
                                            @Html.DisplayNameFor(model => model.NewValue)
                                        </th>
                                    </tr>
                                </thead>
                            </table>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/pages/auditlog-datatable.min.js"></script>
}

