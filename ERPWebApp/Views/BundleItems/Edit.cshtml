@model ERPWebApp.Models.Inventory.BundleItem

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>BundleItem</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="BundleItemId" />
            <div class="form-group">
                <label asp-for="BundleId" class="control-label"></label>
                <select asp-for="BundleId" class="form-control select2" data-toggle="select2" asp-items="ViewBag.BundleId"></select>
                <span asp-validation-for="BundleId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProductId" class="control-label"></label>
                <select asp-for="ProductId" class="form-control select2" data-toggle="select2" asp-items="ViewBag.ProductId"></select>
                <span asp-validation-for="ProductId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Quantity" class="control-label"></label>
                <input asp-for="Quantity" class="form-control" min="1" max="9999" type="number" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
