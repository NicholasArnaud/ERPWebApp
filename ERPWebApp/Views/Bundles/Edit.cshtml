@model ERPWebApp.Models.Inventory.Bundle

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Bundle</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="BundleId" />
            <div class="form-group">
                <label asp-for="BundleName" class="control-label"></label>
                <input asp-for="BundleName" class="form-control" />
                <span asp-validation-for="BundleName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FulfillmentCost" class="control-label"></label>
                <div class="input-group">
                    <div class="input-group-text"><i class="mdi mdi-currency-usd"></i></div>
                    <input asp-for="FulfillmentCost" class="form-control" type="number" step="0.01" />
                </div>
                <span asp-validation-for="FulfillmentCost" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
