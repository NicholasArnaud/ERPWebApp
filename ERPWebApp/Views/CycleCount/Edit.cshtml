@model ERPWebApp.Models.CycleCount

<form id="editForm" asp-action="Edit">
    <label asp-for="StockId" hidden></label>
    <input asp-for="StockId" id="editid" value="@Model.StockId" type="hidden">
    <label asp-for="CycleCountId" hidden></label>
    <input asp-for="CycleCountId" id="editid" value="@Model.CycleCountId" type="hidden">

    <div class="form-group p-1">
        <label asp-for="EnteredSku" class="control-label">Product</label>
        <input asp-for="EnteredSku" value="@Model.Stock.Products.Sku" class="form-control" disabled />
    </div>

    <div class="form-group p-1">
        <label class="control-label">Description</label>
        <input value="@Model.Stock.Products.Description" class="form-control" disabled />
    </div>

    <div class="form-group p-1">
        <label class="control-label">Site</label>
        <input value="@Model.Stock.Location.Sites.SiteName" class="form-control" disabled />
    </div>

    <div class="form-group p-1">
        <label class="control-label">Location</label>
        <input value="@Model.Stock.Location.LocationName" class="form-control" disabled />
    </div>
    <hr style="padding: 0px" />
    <div class="form-group p-1">
        <label asp-for="EnteredQuantity" class="control-label">Count</label>
        <input asp-for="EnteredQuantity" id="edit-count" required="required" type="number" class="form-control" min="0" value="@ViewBag.BeforeCount" />
        <span style="color:yellow; display:none" id="mismatchwarning">The entered quantity does not match the stored quantity. Please double check the entered quantity before proceeding.</span>
    </div>
    <div class="form-group p-1">
        <label asp-for="EnteredById" class="control-label">Counted By(Employee)</label>
        <select asp-for="EnteredById" class="form-control select2" required data-toggle="select2" asp-items="ViewBag.EnteredById" id="EnteredBy-select-id">
        </select>
    </div>

    <div class="modal-footer">
        <a id="error-message-edit" style="color:pink"></a>
        <button type="button" class="btn btn-danger" data-bs-dismiss="modal" aria-hidden="true">Cancel</button>
        @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.InventoryManager) || this.User.IsInRole(RoleList.ShippingManager))
        {
            <button type="button" class="btn btn-primary" onclick="showConfirmModal()">Submit</button>
        }
    </div>
    <div class="modal fade" id="confirm-count" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning" style="color:black">
                    <h4 class="modal-title" id="myModalLabel">Confirm</h4>
                </div>
                <div class="modal-body bg-dark" style="color:black">
                    <p>You are about to finish the stock cycle.</p>
                    <p>Do you want to proceed?</p>
                </div>
                <div class="modal-footer bg-dark">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="EditStock()">Submit</button>
                </div>
            </div>
        </div>
    </div>
</form>
<script>
    $(document).ready(function () {
        $('#EnteredBy-select-id').select2({ dropdownParent: $('#my-edit-modal') });
        $('#edit-count').on('change', function () {
            $('#mismatchwarning').show();
        });
    });

    function showConfirmModal() {
        var confirmModal = new bootstrap.Modal(document.getElementById('confirm-count'), {});
        confirmModal.show();
    }
</script>
