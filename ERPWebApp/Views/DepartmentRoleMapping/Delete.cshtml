@model ERPWebApp.Models.DepartmentRoleMappingViewModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Department Name
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DepartmentName)
        </dd>
        <dt class="col-sm-2">
            Default Roles
        </dt>
        <dd class="col-sm-10">
            @if (Model.Roles != null && Model.Roles.Any())
            {
                <p>@string.Join(", ", Model.Roles.Select(role => role.Name))</p>
            }
            else
            {
                <p>No roles assigned to this department.</p>
            }
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="DepartmentId" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <button type="submit" formaction="@Url.Action("Index")" class="btn btn-secondary">Back to List</button>
    </form>
</div>

