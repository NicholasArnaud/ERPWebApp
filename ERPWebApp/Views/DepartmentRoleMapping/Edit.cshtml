@model ERPWebApp.Models.DepartmentRoleMappingViewModel
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
<h1>Edit</h1>
<h4>Department Role Mapping</h4>
<hr />
<div class="row">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="col-md-4">
        <form asp-action="Edit">
            <div class="form-group mb-2">
                <input type="hidden" asp-for="DepartmentRoleId" />
                <label asp-for="DepartmentId" class="control-label "></label>
                <select asp-for="DepartmentId" class="form-control select2" data-toggle="select2" asp-items="ViewBag.DepartmentId" id="departmentId-select2">
                    <option></option>
                </select>
                <span asp-validation-for="DepartmentId" class="text-danger"></span>
            </div>
            <div class="form-group mb-2">
                <label class="control-label">Default Roles</label>
                <select asp-for="UserRoleIds" class="form-control select2 select2-multiple" data-toggle="select2" asp-items="ViewBag.UserRoleId" id="roleId-select2">
                    <option value='0'></option>
                </select>
                <span asp-validation-for="UserRoleIds" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script type="text/javascript">
        $(document).ready(function () {
            $("#departmentId-select2").select2({
                placeholder: 'Select a Department.'
            });
            $("#roleId-select2").select2({
                placeholder: {
                    id: '0',
                    text: ' Select a user Role.'
                }
            });
        });
    </script>
}