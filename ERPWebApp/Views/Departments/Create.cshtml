@model ERPWebApp.Models.Company.Department

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Create</h1>

<h4>Department</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group p-1">
                <label asp-for="DepartmentName" class="control-label"></label>
                <input asp-for="DepartmentName" class="form-control" />
                <span asp-validation-for="DepartmentName" class="text-danger"></span>
            </div>
            <div class="form-group p-1">
                <label asp-for="DepartmentColor" class="control-label"></label>
                <input asp-for="DepartmentColor" class="form-control" />
                <span asp-validation-for="DepartmentColor" class="text-danger"></span>
            </div>
            <div class="form-group p-1 form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsActive" checked /> @Html.DisplayNameFor(model => model.IsActive)
                </label>
            </div>
            <div class="form-group p-1 form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="IsProduction" checked /> @Html.DisplayNameFor(model => model.IsProduction)
                </label>
            </div>
            <div class="form-group p-1">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
