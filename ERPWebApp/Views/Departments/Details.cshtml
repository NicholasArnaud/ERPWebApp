@model ERPWebApp.Models.Company.Department

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Details</h1>

<div>
    <h4>Department</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DepartmentName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DepartmentName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DepartmentColor)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DepartmentColor)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class="col-sm-10">
            @if (@Html.ValueFor(model => model.IsActive) == "True")
            {<a>Yes</a>}
            else
            {<a>No</a>}
        </dd>
        <dd class="col-sm-10">
            @if (@Html.ValueFor(model => model.IsProduction) == "True")
            {<a>Yes</a>}
            else
            {<a>No</a>}
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.DepartmentId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}