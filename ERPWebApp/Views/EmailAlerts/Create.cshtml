<!-- Create Email Alert Modal -->
<div class="modal fade" id="createEmailAlertModal" tabindex="-1" role="dialog" aria-labelledby="createEmailAlertModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form id="createEmailAlertForm" method="post" action="@Url.Action("CreateEmailAlert", "EmailAlerts")">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="createEmailAlertModalLabel">Create Email Alert</h5>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="subjectCreate">Subject</label>
                        <input type="text" class="form-control" id="subjectCreate" name="EmailAlert.Subject">
                    </div>
                    <div class="form-group">
                        <label for="alertTypeCreate">Alert Type</label>
                        <select class="form-control" id="alertTypeCreate" name="EmailAlert.AlertType">
                            <option value="0">Time Based</option>
                            <option value="1">Trigger Based</option>
                        </select>
                    </div>
                    <div class="form-group" id="frequencyGroupCreate" style="display: none;">
                        <label for="frequencyCreate">Frequency</label>
                        <select class="form-control" id="frequencyCreate" name="EmailAlert.Frequency">
                            <option value="0">Daily</option>
                            <option value="1">Weekly</option>
                            <option value="2">Monthly</option>
                        </select>
                    </div>
                    <div class="form-group" id="presetTriggersGroupCreate" style="display: none;">
                        <label for="presetTriggersCreate">Trigger Conditions</label>
                        <select class="form-control" id="presetTriggersCreate" name="AlertTemplateId"></select>
                    </div>
                    <div class="form-group">
                        <label for="bodyCreate">Body</label>
                        <textarea class="form-control" id="bodyCreate" rows="3" maxlength="400" name="EmailAlert.Body"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="recipientsCreate">Recipients</label>
                        <select class="form-control" id="recipientsCreate" name="Recipients" multiple>
                            @foreach (var userEmail in Model.UserEmails)
                            {
                                <option value="@userEmail">@userEmail</option>
                            }
                        </select>
                    </div>
                    <div class="form-group" id="createScheduledTimeGroup">
                        <label for="createScheduledTime">Scheduled Time</label>
                        <input type="text" class="form-control" id="createScheduledDateTime" name="EmailAlert.ScheduledTime">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>  
@{
    var userEmails = ViewData["UserEmails"] as List<string>;
}
