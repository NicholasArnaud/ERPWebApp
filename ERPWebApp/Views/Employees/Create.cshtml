@model ERPWebApp.Models.Company.Employee
@namespace ERPWebApp.Models.Company
@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Create</h1>

<h4>Employee</h4>
<hr />
<form asp-action="Create">
    <div class="row">
        <div class="col-md-12">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        </div>
        <div class="col-md-4"> 
            <div class="form-group p-1">
                <label asp-for="FirstName" class="control-label"></label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
        </div>
            <div class="col-md-4">
                <div class="form-group p-1">
                    <label asp-for="MiddleName" class="control-label"></label>
                    <input asp-for="MiddleName" class="form-control" />
                    <span asp-validation-for="MiddleName" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group p-1">
                    <label asp-for="LastName" class="control-label"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group p-1">
                    <label for="UserRolesViewModelId">Username | Email</label>
                    <select asp-for="UserRolesViewModelId" id="ViewBag.UserRolesViewModel" class="form-control" asp-items="ViewBag.UserRolesViewModel" data-toggle="select2">
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group p-1">
                    <label asp-for="Position" class="control-label"></label>
                    <input asp-for="Position" class="form-control" />
                    <span asp-validation-for="Position" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group p-1">
                    <label asp-for="DepartmentId" class="control-label"></label>
                    <select asp-for="DepartmentId" class="form-control" asp-items="ViewBag.Department"></select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group p-1">
                    <label asp-for="PhoneNumber" class="control-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" data-toggle="input-mask" data-mask-format="(000) 000-0000" placeholder="(012) 345-6789 " />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group p-1">
                    <label asp-for="CompanyEmail" class="control-label"></label>
                    <input asp-for="CompanyEmail" class="form-control" />
                    <span asp-validation-for="CompanyEmail" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group p-1">
                    <label asp-for="PersonalEmail" class="control-label"></label>
                    <input asp-for="PersonalEmail" class="form-control" />
                    <span asp-validation-for="PersonalEmail" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group p-1">
                    <label asp-for="JobStatus" class="control-label"></label>
                    <select asp-for="JobStatus" asp-items="@Html.GetEnumSelectList<JobStatus>()" class="form-control"></select>
                    <span asp-validation-for="JobStatus" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group p-1">
                    <label asp-for="IncomePerHour" class="control-label"></label>
                    <input asp-for="IncomePerHour" class="form-control" value="0.00" />
                    <span asp-validation-for="IncomePerHour" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group p-1">
                    <label asp-for="EmployeeReferenceNumber" class="control-label"></label>
                    <input asp-for="EmployeeReferenceNumber" class="form-control" />
                    <span asp-validation-for="EmployeeReferenceNumber" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group p-2">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>

        </div>
</form>

<div>
    <a class="p-2" asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
}