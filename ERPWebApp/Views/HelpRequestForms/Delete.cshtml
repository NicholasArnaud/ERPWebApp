@model ERPWebApp.Models.HelpRequestForm

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Help Request Ticket</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Requesting User
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.RequestedByUser)
        </dd>
        <dt class="col-sm-2">
            Requesting Employee
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.RequestingEmployee.FullName)
        </dd>
        <dd></dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Subject)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Subject)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dd></dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Urgency)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Urgency)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CreatedDate)
        </dd>
        <dd></dd>
        <dt class="col-sm-2">
            Assigned Helper
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.HelperEmployee.FullName)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Priority)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Priority)
        </dd>
        <dd></dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsDenied)
        </dt>
        <dd class="col-sm-10">
            @if (Html.ValueFor(model => model.IsDenied) == "True")
            {<a>Yes</a> }
            else
            {<a>No</a>}
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsComplete)
        </dt>
        <dd class="col-sm-10">
            @if (Html.ValueFor(model => model.IsComplete) == "True")
            {<a>Yes</a> }
            else
            {<a>No</a>}
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CompletedDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CompletedDate)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="HelpRequestFormId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>
