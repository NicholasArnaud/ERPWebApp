@model ERPWebApp.Models.Inventory.Location

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Details</h1>

<div>
    <h4>Location</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Sites)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Sites.SiteName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.LocationName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.LocationName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.LocationDescription)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.LocationDescription)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Type)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Type)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class="col-sm-10">
            @if (@Html.ValueFor(model => model.IsActive) == "True")
            {
                <a>Yes</a>
            }
            else
            {
                <a>No</a>
            }
        </dd>

        @if (User.IsInRole(RoleList.Administrator) || User.IsInRole(RoleList.ExternalViewer))
        {
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.IsExternal)
            </dt>
            <dd class="col-sm-10">
                @if (@Html.ValueFor(model => model.IsExternal) == "True")
                {
                    <a>Yes</a>
                }
                else
                {
                    <a>No</a>
                }
            </dd>
        }
    </dl>
</div>
<div class="row g-2">
    <table class="table table-hover table-dar" id="product-datatable">
        <thead>
            <tr>
                <th scope="col">Sku</th>
                <th scope="col">Description</th>
                <th scope="col">Total Available</th>
            </tr>
        </thead>
        <tbody id="table-body">
        </tbody>
    </table>
</div>
<div>
    @if (User.IsInRole(RoleList.Administrator) || User.IsInRole(RoleList.InventoryManager) || User.IsInRole(RoleList.ShippingManager))
    {
        @if (User.IsInRole(RoleList.Administrator))
        {
            <a asp-action="Edit" asp-route-id="@Model.LocationId">Edit</a>
            <span>|</span>
        }
        else if (User.IsInRole(RoleList.InventoryManager) && Model.Sites.SiteId == 2)
        {
            <a asp-action="Edit" asp-route-id="@Model.LocationId">Edit</a>
            <span>|</span>
        }
        else if (User.IsInRole(RoleList.ShippingManager) && (Model.Sites.SiteId == 49))
        {
            <a asp-action="Edit" asp-route-id="@Model.LocationId">Edit</a>
            <span>|</span>
        }
    }
    <a asp-action="Index">Back to List</a>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }


    <script src="~/js/pages/location-datatable.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            console.log('aji')

            const url = '../GetStockDetails'
            const tableBody = document.getElementById("table-body");
            while (tableBody.firstChild) {
                tableBody.removeChild(tableBody.firstChild);
            }
            $.getJSON(url, { id: @Model.LocationId}, function (response) {
                response.forEach(item => {

                    const row = document.createElement("tr");
                    row.innerHTML = `<td>${item.products.sku}</td>
                                     <td>${item.products.description}</td>
                                     <td>${item.totalAvailable}</td>`;
                    tableBody.appendChild(row);
                })
            });

        });
    </script>
}