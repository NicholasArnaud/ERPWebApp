@model MessageEmployeeFilter

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@10.16.2/dist/sweetalert2.all.min.js"></script>
<link rel="stylesheet" href="css/emojibuttonlistjs.min.css"/>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Messaging</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-3">

                    </div>
                </div>
                <div class="row mb-2">
                    <div class="col-12">
                        <div id="success-alert-modal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content modal-filled modal-sm">
                                    <div class="modal-body p-4">
                                        <div class="text-center">
                                            <i class="mdi mdi-check-circle h1"></i>
                                            <h4 class="mt-2">Sent!</h4>
                                            <p class="mt-3"></p>
                                        </div>
                                    </div>
                                </div><!-- /.modal-content -->
                            </div><!-- /.modal-dialog -->
                        </div><!-- /.modal -->
                    </div>
                </div>

                <div class="row">
                    <!-- start chat users-->
                    <div class="col-md-7">
                        <div class="card">
                            <div class="card-body p-0">
                                <ul class="nav nav-tabs nav-bordered">
                                    <li class="nav-item active">
                                        <a href="#allUsers" data-bs-toggle="tab" aria-expanded="true" class="nav-link active py-2">
                                            All
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="#departments" data-bs-toggle="tab" aria-expanded="false" class="nav-link py-2">
                                            Departments
                                        </a>
                                    </li>
                                </ul> <!-- end nav-->
                                <div class="tab-content">
                                    <div class="tab-pane show active p-8" id="allUsers">
                                        <!-- users -->
                                        <div class="row">
                                            <div class="col">
                                                <div data-simplebar style="max-height: 550px">
                                                    <br/>
                                                    <table class="table dt-responsive" id="employee-table">
                                                        <thead>
                                                        <tr>
                                                            <th hidden>
                                                                @Html.DisplayNameFor(model => model.Employees.First().EmployeeId)
                                                            </th>
                                                            <th>
                                                                @Html.DisplayNameFor(model => model.Employees.First().FullName)
                                                            </th>
                                                            <th>
                                                                @Html.DisplayNameFor(model => model.Employees.First().Department)
                                                            </th>
                                                            <th>
                                                                @Html.DisplayNameFor(model => model.Employees.First().PhoneNumber)
                                                            </th>
                                                            <th>
                                                                @Html.DisplayNameFor(model => model.Employees.First().JobStatus)
                                                            </th>
                                                        </tr>
                                                        </thead>
                                                        <tbody>
                                                        @foreach (var item in Model.Employees)
                                                        {
                                                            <tr>
                                                                <td hidden>
                                                                    @Html.DisplayFor(modelItem => item.EmployeeId)
                                                                </td>
                                                                <td>
                                                                    @Html.DisplayFor(modelItem => item.FullName)
                                                                </td>
                                                                <td>
                                                                    @Html.DisplayFor(modelItem => item.Department.DepartmentName)
                                                                </td>
                                                                <td>
                                                                    @Html.DisplayFor(modelItem => item.PhoneNumber)
                                                                </td>
                                                                <td>
                                                                    @Html.DisplayFor(modelItem => item.JobStatus)
                                                                </td>
                                                            </tr>
                                                        }
                                                        </tbody>
                                                    </table>
                                                </div> <!-- end slimscroll-->
                                            </div> <!-- End col -->
                                        </div>
                                        <!-- end users -->
                                    </div> <!-- end Tab Pane-->
                                    <div class="tab-pane p-3" id="departments">
                                        <!-- users -->
                                        <div class="row">
                                            <div class="col">
                                                <div data-simplebar style="max-height: 550px">
                                                    <table class="table dt-responsive" id="department-table">
                                                        <thead>
                                                        <tr>
                                                            <th hidden>
                                                                @Html.DisplayNameFor(model => model.Employees.First().DepartmentId)
                                                            </th>
                                                            <th>
                                                                @Html.DisplayNameFor(model => model.Employees.First().Department)
                                                            </th>
                                                        </tr>
                                                        </thead>
                                                        <tbody>
                                                        @foreach (var item in Model.Employees.Select(d => d.Department).Distinct())
                                                        {
                                                            <tr>
                                                                <td hidden>
                                                                    @Html.DisplayFor(modelItem => item.DepartmentId)
                                                                </td>
                                                                <td>
                                                                    @Html.DisplayFor(modelItem => item.DepartmentName)
                                                                </td>
                                                            </tr>
                                                        }
                                                        </tbody>
                                                    </table>
                                                </div> <!-- end slimscroll-->
                                            </div> <!-- End col -->
                                        </div>
                                        <!-- end users -->
                                    </div> <!-- end Tab Pane-->
                                </div> <!-- end tab content-->
                            </div> <!-- end card-body-->
                        </div> <!-- end card-->
                    </div>
                    <!-- end chat users-->
                    <!-- chat area -->
                    <div class="col-md-5">
                        <div class="card">
                            <div class="card-body">
                                <div data-simplebar style="max-height: 550px">
                                    <div id="partialRender">
                                        @{
                                            await Html.RenderPartialAsync("MessageHistoryView", Model);
                                        }
                                    </div>
                                </div> <!-- end slimscroll-->
                                <div class="row">
                                    <div class="col">
                                        <div class="mt-2 bg-light p-3 rounded">
                                            <form class="needs-validation" novalidate="" name="chat-form"
                                                  id="chat-form">
                                                <div class="row">
                                                    <div class="col mb-2 mb-sm-0">
                                                        <input type="text" class="form-control border-0" placeholder="Enter your text" required="" id="message">
                                                        <div class="invalid-feedback">
                                                            Please enter your messsage
                                                        </div>
                                                    </div>
                                                    <div class="col-sm-auto">
                                                        <div class="btn-group">

                                                            <a id="emojiButton" class="btn btn-light">
                                                                <i id="emojiButton" class='uil uil-smile'></i>
                                                            </a>

                                                            <div class="d-grid">
                                                                <button type="button" class="btn btn-success chat-send" id="send-message">
                                                                    <i class='uil uil-message'></i>
                                                                </button>
                                                                
                                                            </div>
                                                        </div>
                                                    </div> <!-- end col -->
                                                </div> <!-- end row-->
                                            </form>
                                        </div>
                                    </div> <!-- end col-->
                                </div>
                            </div> <!-- end card-body -->
                        </div> <!-- end card -->
                    </div><!-- end chat area-->
                </div> <!-- end row-->

            </div>
        </div>

    </div>

</div>

<script src="~/js/pages/emojibuttonlist.min.js"></script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
        <script type="text/javascript">
        instance = new emojiButtonList( "emojiButton", {
                dropDownXAlign: "left",
                dropDownYAlign: "bottom",
                yAlignMargin: 25,
                xAlignMargin: -125,
              textBoxID: "message"
            });
            $(document).ready(function () {
                
                var empTable = $("#employee-table").DataTable({
                    iDisplayLength: 100,
                    dom: "<'row'<'col-sm-12 col-md-4'f><'col-sm-12 col-md-8'>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row'<'col-sm-12'i>>",
                    select: {
                        style: 'multi'
                    },
                    paging: false
                });
                
                var depTable = $("#department-table").DataTable({
                    iDisplayLength: 100,
                    dom: "<'row'<'col-sm-12 col-md-4'f><'col-sm-12 col-md-8'>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row'<'col-sm-12'i>>",
                    select: {
                        style: 'multi'
                    },
                    paging: false
                });
                
                var historyTable = $("#Message-table").DataTable({
                   order: [[2, 'desc']],        
                   keys: !0, language: {
                       paginate: {
                           previous: "<i class='mdi mdi-chevron-left'>", next: "<i class='mdi mdi-chevron-right'>"
                       },
   
                   }, drawCallback: function () {
                       $(".dataTables_paginate > .pagination").addClass("pagination-rounded")
                   }
                }); 
                
                $("#department-table").on('select.dt', function (e, dt, type, indexes){
                    if (type === 'row') {
                        var selectedDepartment = dt.data()[1];
                        
                        var rows = empTable.rows().count();
                        
                        var tempArray = empTable.rows().data();
                        for (var i = 0; i < rows; i++){
                             
                             console.log(tempArray[i][2]);
                             if (tempArray[i][2] === selectedDepartment){
                                 empTable.rows(i).select();
                             }
                         } 
                    }
                });
                
                $("#department-table").on('deselect.dt', function (e, dt, type, indexes){
                    if (type === 'row') {
                        var UnselectedDepartment = dt.data()[1];
                        
                        var rows = empTable.rows().count();
                        
                        var tempArray = empTable.rows().data();
                        for (var i = 0; i < rows; i++){
                             if (tempArray[i][2] === UnselectedDepartment){
                                 empTable.rows(i).deselect();
                             }
                        } 
                    }
                });
                
                $('#send-message').click(function (d) {
                    var messageString = $('#message').val();

                    const empIds = new Array();
                    const depIds = new Array();
                    if (empTable.rows({ selected: true }).count() >= 1)
                        for (var i = 0; i < empTable.rows({ selected: true }).count(); i++)
                            empIds.push(Number(empTable.rows({ selected: true }).data()[i][0]));
                    if (depTable.rows({ selected: true }).count() >= 1)
                        for (var i = 0; i < depTable.rows({ selected: true }).count(); i++)
                            depIds.push(Number(depTable.rows({ selected: true }).data()[i][0]));
                    if (messageString != "") {
                        console.log(messageString);
                        var url = '@Url.Action("SendMessage")';
                        $.getJSON(url, { EmployeeIds: JSON.stringify(empIds), DepartmentIds: JSON.stringify(depIds), Message: messageString }).done(function (response) {
                            
                            Swal.fire({
                                title: 'Message Sent!',
                                icon: 'success',
                                timer: 2000,
                                timerProgressBar: true,
                                didOpen: () => {
                                    Swal.showLoading()
                                    timerInterval = setInterval(() => {
                                        const content = Swal.getContent()
                                        if (content) {
                                            const b = content.querySelector('b')
                                            if (b) {
                                                b.textContent = Swal.getTimerLeft()
                                            }
                                        }
                                    }, 500)
                                },
                                willClose: () => {
                                    clearInterval(timerInterval)
                                }
                            });
                            
                                console.log("PartialView Loading");
                                //Recalled DataTable in Load to wait for data is allocated in the table before reloading it
                                //otherwise DataTable does not work
                                $('#partialRender').load('/MessageEmployees/MessageHistoryView', function (response) {
                                    
                                    var historyTable = $("#Message-table").DataTable({
                                        order: [[2, 'desc']],        
                                          keys: !0, language: {
                                              paginate: {
                                                  previous: "<i class='mdi mdi-chevron-left'>", next: "<i class='mdi mdi-chevron-right'>"
                                              },
                          
                                          }, drawCallback: function () {
                                              $(".dataTables_paginate > .pagination").addClass("pagination-rounded")
                                          }
                                    });
                                    //SetupDataTable($("#shipstation-awaiting-order-datatable"), response.TotalNeeded);
                                    //$("#shipstation-awaiting-order-datatable").DataTable().draw();
                                    console.log("PartialView Reloaded");
                                });
                            $('#message').val("");
                        });
                    }
                });
            });
        </script>
}
