@using ERPWebApp.Models.Inventory
@using ERPWebApp.Models.NirfForms
@using System.Text.Json;
@using System.Text.Json.Serialization;
@model ERPWebApp.Models.NirfForms.NirfViewModel
<head xmlns="http://www.w3.org/1999/html">
    <link rel="stylesheet" type="text/css" href="~/css/datatablecoloring.css">
    <link rel="stylesheet" type="text/css" href="~/css/sliderbutton.css">
</head>
<style>
    .accordion-button:not(.collapsed) {
        background: #464F5B;
        color: white;
    }

    /*
                                                                                                                                                                            This is for select2 validations.
                                                                                                                                                                            If a select2 didnt pass the validation and gets auto applied the classes invalid
                                                                                                                                                                            the css below will set the border to red. And same Visa Versa for if it passes validation
                                                                                                                                                                            then the css below will set the border to green.S
                                                                                                                                                                            */
    .was-validated .custom-select:invalid + .select2 .select2-selection {
        border-color: #FF5B5B !important;
    }

    .was-validated .custom-select:valid + .select2 .select2-selection {
        border-color: #10C469 !important;
    }

    *:focus {
        outline: 0px;
    }

    .ribbon-wrapper {
        width: 85px;
        height: 88px;
        overflow: hidden;
        position: absolute;
        top: -3px;
        right: -3px;
    }

    .ribbon {
        font-size: 14px;
        color: white;
        text-transform: uppercase;
        font-family: 'Montserrat Bold', 'Helvetica Neue', Helvetica, Arial, sans-serif;
        letter-spacing: .05em;
        line-height: 5px;
        text-align: center;
        text-shadow: 0 -1px 0 rgba(0, 0, 0, .4);
        -webkit-transform: rotate(45deg);
        -moz-transform: rotate(45deg);
        -ms-transform: rotate(45deg);
        -o-transform: rotate(45deg);
        transform: rotate(45deg);
        position: relative;
        padding: 15px 0;
        right: 5px;
        top: 15px;
        width: 120px;
        height: 28px;
        -webkit-box-shadow: 0 0 3px rgba(0, 0, 0, .3);
        box-shadow: 0 0 3px rgba(0, 0, 0, .3);
        background-color: #536DE6;
        background-image: -webkit-linear-gradient(top, #536DE6 45%, #536DE6 100%);
        background-image: -o-linear-gradient(top, #536DE6 45%, #536DE6 100%);
        background-image: linear-gradient(to bottom, #536DE6 45%, #536DE6 100%);
        background-repeat: repeat-x;
    }

        .ribbon:before,
        .ribbon:after {
            content: "";
            border-top: 3px solid #536DE6;
            border-left: 3px solid transparent;
            border-right: 3px solid transparent;
            position: absolute;
            bottom: -3px;
        }

        .ribbon:before {
            left: 0
        }

        .ribbon:after {
            right: 0
        }
    /* Popup container */
    .popup {
        position: relative;
        display: inline-block;
        cursor: pointer;
    }

        /* The actual popup (appears on top) */
        .popup .popuptext {
            visibility: hidden;
            width: 180px;
            background-color: #555;
            color: #fff;
            text-align: center;
            border-radius: 10px;
            padding: 4px 8px;
            position: absolute;
            z-index: 1;
            top: 125%;
            left: -250%;
            margin-left: -80px;
        }

        /* Toggle this class when clicking on the popup container (hide and show the popup) */
        .popup .show {
            visibility: visible;
            -webkit-animation: fadeIn 1s;
            animation: fadeIn 1s
        }

    .info {
        position: relative;
        display: inline-block;
        cursor: pointer;
    }

        /* The actual popup (appears on top) */
        .info .infotext {
            visibility: hidden;
            width: 180px;
            background-color: #555;
            color: #fff;
            text-align: center;
            border-radius: 10px;
            padding: 4px 8px;
            position: absolute;
            z-index: 1;
            top: 125%;
             margin-left: -50px;
        }

        /* Toggle this class when clicking on the popup container (hide and show the popup) */
        .info .show {
            visibility: visible;
            -webkit-animation: fadeIn 1s;
            animation: fadeIn 1s
        }

    #department-error {
        color: #ff5b5b;
    }
</style>
@if (@TempData["Error"] != null)
{
    <div class="row">
        <div class="col-12 text-danger">
            <h2>@TempData["Error"]</h2>
        </div>
    </div>
}

<div class="col-12">
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">NIRF Form</h2>
        </div>
        <div class="card-body">
            <form asp-action="FinishForm" class="needs-validation" novalidate enctype="multipart/form-data">
                <div class="row">
                    <input asp-for="@Model.NirfForms.NirfFormId" value="@Model.NirfForms.NirfFormId" hidden />
                    <input asp-for="NirfProductMapping.ProductId" value="@Model.NirfProductMapping.ProductId" hidden />
                    
                    <div class="row mt-3">
                        <div class="form-group col">
                            <label class="control-label" asp-for="@Model.NirfForms.SellersProductSku">Sellers Product Sku</label>
                            <input asp-for="@Model.NirfForms.SellersProductSku" class="form-control" type="text" required />
                        </div>
                        <div class="form-group col">
                            <label class="control-label" asp-for="NirfProductMapping.Product.Sku">Sku</label>
                            <input asp-for="NirfProductMapping.Product.Sku" class="form-control" id="full-sku" type="text" required />
                        </div>
                        <div class="form-group col">
                            <label class="control-label" asp-for="NirfProductMapping.Product.AltItemNumber">Alt Item No.</label>
                            <input asp-for="NirfProductMapping.Product.AltItemNumber" class="form-control" type="text" />
                        </div>
                        <div class="form-group col">
                            <label class="control-label">Department</label>
                            @*<select name="DepartmentList" id="DepartmentList" asp-for="NirfProductMapping.Product.DepartmentList"
                            class="select custom-select select2-multiple" data-toggle="select2" multiple="multiple"
                            data-placeholder="Choose ..."
                            asp-items="@ViewBag.DepartmentList" required>
                            </select>*@
                            @Html.ListBoxFor(m => m.NirfProductMapping.Product.DepartmentList, (MultiSelectList)ViewBag.DepartmentList,
                                     new
                                     {
                                         @class = "select2 custom-select select2-multiple",
                                         data_toggle = "select2",
                                         multiple = "multiple",
                                         data_placeholder = "Choose ...",
                                         asp_for = "NirfProductMapping.Product.DepartmentList"
                                     })
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="form-group col-12">
                            <label class="control-label" asp-for="NirfProductMapping.Product.Description">Description</label>
                            <textarea asp-for="NirfProductMapping.Product.Description" class="form-control" rows="5"></textarea>
                        </div>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="form-group col-md-4">
                            <label class="control-label" asp-for="NirfProductMapping.Product.DimensionalUnit">Dimensional Unit</label>
                            <select class="select custom-select select2-multiple"
                                    data-toggle="select2"
                                    asp-for="NirfProductMapping.Product.DimensionalUnit" required asp-items="@Html.GetEnumSelectList<DimensionalUnit>()" class="form-control">
                            </select>
                        </div>
                        <div class="form-group col-md-4">
                            <label class="control-label" asp-for="NirfProductMapping.Product.Length">Length</label>
                            <input class="form-control" type="number" min="0.01" step="0.01" required asp-for="NirfProductMapping.Product.Length" />
                        </div>
                        <div class="form-group col-md-4">
                            <label class="control-label" asp-for="NirfProductMapping.Product.Width">Width</label>
                            <input class="form-control" type="number" min="0.01" step="0.01" required asp-for="NirfProductMapping.Product.Width" />
                        </div>
                        <div class="form-group col-md-4">
                            <label class="control-label" asp-for="NirfProductMapping.Product.Height">Height</label>
                            <input class="form-control" type="number" min="0.01" step="0.01" required asp-for="NirfProductMapping.Product.Height" />
                        </div>
                        <div class="form-group col-md-4">
                            <label class="control-label" asp-for="NirfProductMapping.Product.WeightUnit">Weight Unit</label>
                            <select class="select custom-select select2-multiple"
                                    data-toggle="select2"
                                    asp-for="NirfProductMapping.Product.WeightUnit" asp-items="@Html.GetEnumSelectList<WeightUnit>()" class="form-control" required>
                            </select>
                        </div>
                        <div class="form-group col-md-4">
                            <label class="control-label" asp-for="NirfProductMapping.Product.WeightAmount">Weight</label>
                            <input class="form-control" type="number" min="0.01" step="0.01" required asp-for="NirfProductMapping.Product.WeightAmount" />
                        </div>

                    </div>

                    <div class="row g-3 mt-3">
                        <div class="form-group col-md-4">
                            <label class="control-label" asp-for="@Model.NirfForms.Orientation">Orientation</label>
                            <input class="form-control" type="text" required asp-for="@Model.NirfForms.Orientation" />
                        </div>
                        <div class="form-group col-md-4">
                            <label class="control-label" asp-for="@Model.NirfForms.DesignPlacement">Design Placement</label>
                            <input class="form-control" type="text" required asp-for="@Model.NirfForms.DesignPlacement" />
                        </div>

                        <div class="form-group col-md-4">
                            <label class="control-label" asp-for="@Model.NirfForms.DesignAlignment">Design Alignment</label>
                            <input class="form-control" type="text" required asp-for="@Model.NirfForms.DesignAlignment" />
                        </div>
                        <div class="form-group col-md-12">
                            <label class="control-label" asp-for="@Model.NirfForms.SpecialInstructions">Special Instructions</label>
                            <textarea asp-for="@Model.NirfForms.SpecialInstructions" class="form-control" rows="5"></textarea>
                        </div>
                        <div class="form-group col-md-4">
                            <label class="form-label" asp-for="NirfProductMapping.Product.FulfillmentCost">Fulfillment Cost</label>
                            <div class="input-group mb-1">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" min="0.01" step="0.01" required asp-for="NirfProductMapping.Product.FulfillmentCost">
                            </div>
                        </div>
                        <div class="form-group col-md-4">
                            <label class="form-label" asp-for="NirfProductMapping.Product.Cost">Cost</label>
                            <div class="input-group mb-1">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" min="0.01" step="0.01" required asp-for="NirfProductMapping.Product.Cost">
                            </div>
                        </div>
                    </div>
                </div>

                @if (User.IsInRole(RoleList.CustomerSupportManager) || User.IsInRole(RoleList.Administrator))
                {
                    <div class="row g-3 mt-4">
                        <div class="col-6">
                            <div class="dropdown btn-group ">
                                <button class="btn btn-light dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    Save
                                </button>
                                <div class="dropdown-menu dropdown-menu-animated">
                                    <input value="Save Changes" type="submit" class="btn" name="submit" asp-action="Edit" asp-route-id="@Model.NirfForms.NirfFormId" />
                                    <input value="Finish Form" type="submit" class="btn" name="submit" />
                                </div>
                            </div>
                            <input value="Cancel Form" type="submit" class="btn btn-danger mr-4" asp-action="CancelForm" asp-route-id="@Model.NirfForms.NirfFormId" />
                        </div>
                    </div>
                }
                <input type="hidden" asp-for="@Model.NirfForms.CreatedBy" />
                <input type="hidden" asp-for="@Model.NirfForms.AspUserId" />
                <input type="hidden" asp-for="@Model.NirfForms.StartedDate" />
                <input type="hidden" asp-for="@Model.NirfForms.CompletedDate" />
                <input type="hidden" asp-for="@Model.NirfForms.NirfStatus" />
                <input type="hidden" asp-for="@Model.NirfProductMapping.NirfProductMappingId" />
                <input type="hidden" asp-for="@Model.NirfProductMapping.ProductId" />
                <input type="hidden" asp-for="@Model.NirfProductMapping.NirfFormId" />
                <input type="hidden" asp-for="@Model.NirfProductMapping.Product.ProductId" />
                <input type="hidden" asp-for="@Model.NirfProductMapping.NirfForm.NirfFormId" />
            </form>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12 col-lg-6">
        <div class="accordion custom-accordion mt-1" id="custom-accordion-prod">
            <div class="card mb-0">
                <h4 class="accordion-header" id="heading-one">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-one" aria-expanded="false" aria-controls="collapse-one">
                        Inventory
                    </button>
                </h4>
                <div id="collapse-one" class="accordion-collapse collapse" aria-labelledby="heading-one" data-bs-parent="#accordion-example">
                    <div class="accordion-body">
                        <form asp-action="SignInventory" class="needs-validation" novalidate>
                            <div class="row">
                                <input asp-for="NirfInventories.NirfFormId" value="@Model.NirfProductMapping.NirfForm.NirfFormId" hidden />
                                <div class="info mdi-24px mdi mdi-help-circle-outline" style="float:right" onclick="infoInventory()">
                                    <span class="infotext" id="info-popup">
                                        This tab sets where the default location of this item will be and should be when storing the item in the warehouse/membrane.
                                    </span>
                                </div>
                                <div class="col-12 col-lg-6">
                                    <div class="form-group p-1" style="align-content:center">
                                        <label class="control-label">Membrane Site</label>
                                        @{
                                            var jsonData = JsonSerializer.Serialize(new { MembraneLocationId = Model.NirfInventories?.MembraneLocationId, AltMembraneLocationId = Model.NirfInventories?.AltMembraneLocationId });
                                        }
                                        <select class="select custom-select select2-multiple" data-toggle="select2"
                                                data-placeholder="Choose ..."
                                                asp-items="@ViewBag.SiteList" asp-for="@Model.NirfInventories.MembraneSiteId" id="membrane-site-select-id" data-locations="@jsonData">

                                            <option value="" selected disabled></option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-12 col-lg-6">
                                    <div class="form-group p-1" style="align-content:center">
                                        <label class="control-label">Main Site</label>
                                        @{
                                            var jsonDataMainSite = System.Text.Json.JsonSerializer.Serialize(new { MainLocationId = Model.NirfInventories?.MainLocationId, AltMainLocationId = Model.NirfInventories?.AltMainLocationId });
                                        }
                                        <select class="select custom-select select2-multiple" data-toggle="select2"
                                                data-placeholder="Choose ..."
                                                asp-items="@ViewBag.SiteList" asp-for="@Model.NirfInventories.MainSiteId" id="main-site-select-id" data-locations="@jsonDataMainSite">
                                            <option value="" selected disabled></option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12 col-lg-6">
                                    <div class="form-group p-1" id="membrane-location" style="display:none">
                                        <label class="control-label">Membrane Location</label>
                                        <select asp-for="NirfInventories.MembraneLocationId" class="select custom-select select2-multiple" data-toggle="select2"
                                                data-placeholder="Choose ..."
                                                asp-items="@ViewBag.MembraneList" asp-for="@Model.NirfInventories.MembraneLocationId" id="membrane-location-select-id">
                                            <option value="" selected disabled></option>
                                        </select> 
                                    </div>
                                </div>
                                <div class="col-12 col-lg-6">
                                    <div class="form-group p-1" id="main-location" style="display:none">
                                        <label class="control-label">Main Location</label>
                                        <select class="select custom-select select2-multiple" data-toggle="select2"
                                                data-placeholder="Choose ..."
                                                asp-items="@ViewBag.MainList" asp-for="@Model.NirfInventories.MainLocationId" id="main-location-select-id">
                                            <option value="" selected disabled></option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12 col-lg-6">
                                    <div class="form-group p-1" id="alt-membrane-location" style="display:none">
                                        <label class="control-label text-nowrap">Alt Membrane Location</label>
                                        <select class="select custom-select select2-multiple" data-toggle="select2"
                                                data-placeholder="Choose ..."
                                                asp-for="@Model.NirfInventories.AltMembraneLocationId" id="alt-membrane-location-id">
                                            <option value="" selected disabled></option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-12 col-lg-6">
                                    <div class="form-group p-1" id="alt-main-location" style="display:none">
                                        <label class="control-label">Alt Main Location</label>
                                        <select class="select custom-select select2-multiple" data-toggle="select2"
                                                data-placeholder="Choose ..."
                                                asp-for="@Model.NirfInventories.AltMainLocationId" id="alt-main-location-id">
                                            <option value="" selected disabled></option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12">
                                    <div class="form-group p-1">
                                        <label class="control-label">Comments</label>
                                        <textarea asp-for="NirfInventories.Comments" class="form-control" rows="7"></textarea>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                @if (Model.NirfInventories == null)
                                {
                                    @if (User.IsInRole(RoleList.InventoryManager) || User.IsInRole(RoleList.Administrator))
                                    {
                                        <div class="col-1">
                                            <button type="submit" class="btn btn-primary">Sign</button>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-light col-12" style="font-size: 1.1em; margin: 10px 0px;">@Model.NirfInventories.SignedBy : @Model.NirfInventories.SignedOn.ToLongDateString()</span>
                                    @if (User.IsInRole(RoleList.InventoryManager) || User.IsInRole(RoleList.Administrator) && (Model.NirfProductMapping.NirfForm.NirfStatus != NirfForm.Status.Cancelled || Model.NirfProductMapping.NirfForm.NirfStatus != NirfForm.Status.Completed))
                                    {
                                        <div class="row">
                                            <div class="col-6">
                                                <button type="submit" class="btn btn-primary">Re-Sign</button>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @* forcasting *@
    <div class="col-12 col-lg-6">
        <div class="accordion custom-accordion mt-1" id="custom-accordion-prod">
            <div class="card mb-0">
                <h2 class="accordion-header" id="heading-four">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-four" aria-expanded="false" aria-controls="collapse-four">
                        Forecasting
                    </button>
                </h2>
                <div id="collapse-four" class="accordion-collapse collapse" aria-labelledby="heading-four" data-bs-parent="#accordion-example">
                    <div class="accordion-body">
                        <form asp-action="SignForecasting" class="needs-validation" novalidate>
                            <div class="info mdi-24px mdi mdi-help-circle-outline" style="float:none" onclick="infoForecasting()">
                                <span class="infotext" id="info-forecasting">
                                    Lead time shows the estimated time it takes to receive the product from the supplier
                                    all the way to the customer recieving the personalized item. Min Max level is a reordering
                                    strategy that sets a trigger to reorder when the minimum value is reached
                                </span>
                            </div>
                            <div class="row">
                                <input asp-for="NirfForecastings.NirfFormId" value="@Model.NirfProductMapping.NirfForm.NirfFormId" hidden />
                                <div class="col-6">
                                    <div class="form-group p-1">
                                        <label class="control-label">Lead Time (Days)</label>
                                        <input class="form-control" min="1" type="number" asp-for="NirfForecastings.LeadTime" required />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="form-group p-1">
                                        <label class="control-label">Min Max Level</label>
                                        <input class="form-control" min="1" type="number" asp-for="NirfForecastings.MinMaxLevel" required />
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-6">
                                    <div class="form-group p-1">
                                        <label class="control-label">Count</label>
                                        <input class="form-control" min="1" type="number" asp-for="NirfForecastings.Count" required />
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12">
                                    <div class="form-group p-1">
                                        <label class="control-label">Comments</label>
                                        <textarea asp-for="NirfForecastings.Comments" class="form-control" rows="7"></textarea>
                                    </div>
                                </div>
                            </div>
                            @if (Model.NirfForecastings == null)
                            {
                                @if (User.IsInRole(RoleList.FinancialManager) || User.IsInRole(RoleList.Administrator))
                                {
                                    <div class="row">
                                        <div class="col-6">
                                            <button type="submit" class="btn btn-primary">Sign</button>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="row justify-content-center">
                                    <span class="badge rounded-pill bg-light col-12" style="font-size: 1.1em; margin: 10px 0px;">@Model.NirfForecastings.SignedBy : @Model.NirfForecastings.SignedOn.ToLongDateString()</span>
                                </div>
                                @if (User.IsInRole(RoleList.ProductionManager) || User.IsInRole(RoleList.Administrator) && (Model.NirfProductMapping.NirfForm.NirfStatus != NirfForm.Status.Cancelled || Model.NirfProductMapping.NirfForm.NirfStatus != NirfForm.Status.Completed))
                                {
                                    <div class="row">
                                        <div class="col-6">
                                            <button type="submit" class="btn btn-primary">Re-Sign</button>
                                        </div>
                                    </div>
                                }
                            }
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-2">
    <div class="col-12 col-lg-6">
        <div class="accordion custom-accordion mt-1" id="custom-accordion-prod">
            <div class="card mb-0">
                <h2 class="accordion-header" id="heading-three">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-three" aria-expanded="false" aria-controls="collapse-three">
                    Packaging
                </button>
            </h2>
            <div id="collapse-three" class="accordion-collapse collapse" aria-labelledby="heading-three" data-bs-parent="#accordion-example">
                <div class="accordion-body">
                    <form asp-action="SignPackaging" class="needs-validation" novalidate>
                        <div class="row">
                            <input asp-for="NirfPackagings.NirfFormId" value="@Model.NirfProductMapping.NirfForm.NirfFormId" hidden />
                            <div class="info mdi-24px mdi mdi-help-circle-outline" style="float:right" onclick="infoPackaging()">
                                <span class="infotext" id="info-packaging">
                                    This tab is to show what bag and/or box that this item should be shipped in and the quantity of the product that each bag or box can be shipped in each,
                                    also the option to select if foam wrap or bubble sleeves are needed.
                                </span>
                            </div>
                            <div class="col-6">
                                <div class="form-group p-1">
                                    <label class="control-label">Box Size</label>
                                    <input class="form-control" type="text" asp-for="NirfPackagings.BoxSize" required />
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-group p-1">
                                    <label class="control-label">Bag Type</label>
