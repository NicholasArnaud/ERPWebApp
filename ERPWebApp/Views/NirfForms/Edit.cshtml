                                            </div>
                                        </div>
                                    }
                                    else
                                    {


                                        <div class="col-6" id="thread-hex">
                                            <div class="form-group p-1">
                                                <label class="control-label">Thread Hex</label>
                                                <input class="form-control" asp-for="NirfParameters.ThreadHex" onkeyup="addHash(this)" />
                                            </div>
                                        </div>

                                        <div class="col-6" id="thread-code" style="display:none">
                                            <div class="form-group p-1">
                                                <label class="control-label">Thread Code</label>
                                                <input class="form-control" asp-for="NirfParameters.ThreadCode" />
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="row">

