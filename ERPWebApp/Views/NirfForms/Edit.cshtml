                                {
                                    <div class="col-6">
                                        <div class="form-group p-1">
                                            <label class="control-label" asp-for="NirfParameters.ThreadTypes">Thread Types</label>
                                            <select class="select custom-select select2-multiple" id="thread-type"
                                                    data-toggle="select2"
                                                    asp-for="NirfParameters.ThreadTypes" asp-items="@Html.GetEnumSelectList<ThreadType>()" class="form-control" required>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="col-6">
                                        <div class="form-group p-1">
                                            <label class="control-label">Thread Color</label>
                                            <input class="form-control" asp-for="NirfParameters.ThreadColor" />
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="row">
