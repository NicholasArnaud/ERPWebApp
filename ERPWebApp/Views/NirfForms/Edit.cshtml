                    </button>
                </h2>
                <div id="collapse-vendor" class="accordion-collapse collapse" aria-labelledby="heading-vendor" data-bs-parent="#accordion-example">
                    <div class="accordion-body">
                        <div class="row">
                            <div class="info mdi-24px mdi mdi-help-circle-outline" style="float:right" onclick="infoVendor()">
                                <span class="infotext" id="info-vendor">
                                    This assigns a vendor to the product that is being created. It also assigns the same vendor to each of the product variations,
                                    you have the option to choose an existing vendor or create a new one.
                                </span>
                            </div>
                            <div class="col-12">
                                <button class="btn btn-dark float-end" data-bs-toggle="modal" data-bs-target="#create-vendor-modal">Create</button>
                            </div>
                        </div>
                        <form asp-action="SignVendorMapping" class="needs-validation" novalidate>
                            <div class="row">
                                <input asp-for="NirfVendorMapping.NirfFormId" value="@Model.NirfProductMapping.NirfForm.NirfFormId" hidden />

                                <div class="col-12">
                                    <div class="form-group p-1">
                                        <label class="control-label">Select A Vendor</label>
                                        <select class="select custom-select select2-multiple" data-toggle="select2" required
                                                asp-items="@ViewBag.VendorList"
                                                asp-for="NirfVendorMapping.VendorId"
                                                data-placeholder="Choose ...">
                                        </select>
                                    </div>
                                </div>
                            </div>

                            @if (Model.NirfVendorMapping == null)
                            {
                                @if (User.IsInRole(RoleList.FinancialManager) || User.IsInRole(RoleList.Administrator))
                                {
                                    <div class="row">
                                        <div class="col-6">
                                            <button type="submit" class="btn btn-primary">Sign</button>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="row justify-content-center">
                                    <span class="badge rounded-pill bg-light col-12" style="font-size: 1.1em; margin: 10px 0px;">@Model.NirfVendorMapping.SignedBy : @Model.NirfVendorMapping.SignedOn.ToLongDateString()</span>
                                </div>
                                @if (User.IsInRole(RoleList.FinancialManager) || User.IsInRole(RoleList.Administrator) && (Model.NirfProductMapping.NirfForm.NirfStatus != NirfForm.Status.Cancelled || Model.NirfProductMapping.NirfForm.NirfStatus != NirfForm.Status.Completed))
                                {
                                    <div class="row">
                                        <div class="col-6">
                                            <button type="submit" class="btn btn-primary">Re-Sign</button>
                                        </div>
                                    </div>
                                }
                            }
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-2">
    <div class="col-12 col-lg-6">
        <div class="accordion custom-accordion mt-1" id="variation-accordion">
            <div class="card mb-3">
                <h2 class="accordion-header" id="heading-variation">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-variation" aria-expanded="false" aria-controls="collapse-variation">
                        Product Variations
                    </button>
                </h2>
                <div id="collapse-variation" class="accordion-collapse collapse" aria-labelledby="heading-variation" data-bs-parent="#accordion-example">
                    <div class="accordion-body">
                        <form asp-action="AddNirfProductMapping" class="needs-validation" novalidate enctype="multipart/form-data">
                            <input asp-for="NirfProductMapping.Product" id="nirf-form-product" value="@Model.NirfProductMapping.Product" hidden />
                            <input asp-for="NirfProductMapping.Product.Sku" id="nirf-form-product-sku" value="@Model.NirfProductMapping.Product.Sku" hidden />
                            <input asp-for="NirfProductMapping.NirfFormId" id="nirf-form-id" value="@Model.NirfProductMapping.NirfFormId" hidden />
                            <div class="form-group p-1">
                                <label class="control-label">Add Product Variant (If Necessary)</label>
                                <div class="popup mdi-24px mdi mdi-help-circle-outline" style="float:right" onclick="infoVariation()">
                                    <span class="popuptext" id="info-variant">
                                        Product variants are the same product in terms of weight, dimensions, design, etc.
                                        Most common variation type in products are different color
                                    </span>
                                </div>

                                <!--Fill out Variations here-->
                                <div class="form-group p-1" id="sku-variations">
                                    @if (Model.NirfProducts != null && Model.NirfProducts.Any())
                                    {
                                        for (var i = 0; i < Model.NirfProducts.Count(); i++)
                                        {
                                            <div id="variant-div-@i">
                                                <!-- Hidden input to store ProductId for updating existing products -->
                                                <input type="hidden" name="NirfProducts[@i].ProductId" value="@Model.NirfProducts[i].ProductId" />

                                                <!-- Input for SKU -->
                                                <label class="control-label">Sku Variant @(i + 1)</label>
                                                <input minlength="4" class="form-control" name="NirfProducts[@i].Sku" type="text" value="@Model.NirfProducts[i].Sku" required />

                                                <!-- Input for Description -->
                                                <label class="control-label">Description Variant @(i + 1)</label>
                                                <input class="form-control" name="NirfProducts[@i].Description" type="text" value="@Model.NirfProducts[i].Description" required /><br />
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <!-- Default entry when no products exist -->
                                        <div id="variant-div-0">
                                            <input type="hidden" name="NirfProducts[0].ProductId" value="0" />
                                            <label class="control-label">Sku Variant 1</label>
                                            <input minlength="4" class="form-control" name="NirfProducts[0].Sku" type="text" value="@Model.NirfProductMapping.Product.Sku" required />

                                            <label class="control-label">Description Variant 1</label>
                                            <input class="form-control" name="NirfProducts[0].Description" type="text" required /><br />
                                        </div>
                                    }
                                </div>
 
                                <div class="form-group p-1" id="button1">
                                    <button class="btn btn-secondary btn-sm" id="add-another" type="button" onclick="add_fields()" aria-haspopup="true" aria-expanded="false">Add Another</button>
                                </div>
                            </div>
                            <div class="form-group p-1">
                                <div class="dropdown">
                                    <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown"
                                            aria-haspopup="true" aria-expanded="false">
                                        Save
                                    </button>
                                    <div class="dropdown-menu">
                                        <center>
                                            <div class="form-group p-1" style="padding: 15px; color: white">
                                                <label>Confirm Variation(s)?</label>
                                                <div class="dropdown-divider"></div>
                                                <input type="button" value="Cancel" class="btn btn-danger btnClose"
                                                       style="margin: 10px" />
                                                <input type="submit" value="Yes" class="btn btn-primary"
                                                       id="btn-transfer" style="margin: 10px" />
                                            </div>
                                        </center>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-6">
    </div>
</div>


<br />
<div class="modal fade" id="example-modal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <!--Add Image popup-->

            <div class="modal-header">
                Add Images
            </div>

            <div class="modal-body">
                <div class="row">
                    <div class="col-12">
                        <form asp-action="UploadImages" class="needs-validation" novalidate enctype="multipart/form-data">
                            <input name="nirfFormId" id="nirf-form-id" value="@Model.NirfProductMapping.NirfForm.NirfFormId" hidden />
                            <div class="form-group p-1">
                                <label class="control-label">Upload Images (Png / Jpeg)</label>
                                <input accept="image/jpeg, image/png" class="form-control" type="file"
                                       name="newImages" id="new-images" multiple="multiple" required />
                            </div>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                            <button type="submit" class="btn btn-primary">Save changes</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
            </div>

        </div>

    </div>
</div>
<div class="modal fade" id="create-vendor-modal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                Create Vendor
            </div>

            <div class="modal-body">
                <div class="row">
                    <div class="col-12">
                        @using (Html.BeginForm("Create", "Vendors"))
                        {
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <input type="number" value="@Model.NirfProductMapping.NirfForm.NirfFormId" hidden name="nirfFormId" id="nirf-form-id" />
                            <div class="row">
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.VendorNumber" class="control-label"></label>
                                        <input asp-for="@Model.Vendor.VendorNumber" class="form-control" placeholder="Vendor #" required />
                                        <span asp-validation-for="@Model.Vendor.VendorNumber" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.VendorName" class="control-label"></label>
                                        <input asp-for="@Model.Vendor.VendorName" class="form-control" placeholder="Vendor Name" required />
                                        <span asp-validation-for="@Model.Vendor.VendorName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.Notes" class="control-label"></label>
                                        <input asp-for="@Model.Vendor.Notes" class="form-control" placeholder="Some notes here." />
                                        <span asp-validation-for="@Model.Vendor.Notes" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.ContactName" class="control-label"></label>
                                        <input asp-for="@Model.Vendor.ContactName" class="form-control" placeholder="John Doe" required />
                                        <span asp-validation-for="@Model.Vendor.ContactName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.PhoneNumber" class="control-label"></label>
                                        <input asp-for="@Model.Vendor.PhoneNumber" class="form-control" data-toggle="input-mask" data-mask-format="(000) 000-0000" placeholder="(012) 345-6789 " required />
                                        <span asp-validation-for="@Model.Vendor.PhoneNumber" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.BusinessEmail" class="control-label"></label>
                                        <input type="email" asp-for="@Model.Vendor.BusinessEmail" class="form-control" placeholder="Email" required />
                                        <span asp-validation-for="@Model.Vendor.BusinessEmail" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.Fax" class="control-label"></label>
                                        <input asp-for="@Model.Vendor.Fax" class="form-control" placeholder="Fax Number" />
                                        <span asp-validation-for="@Model.Vendor.Fax" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.Website" class="control-label"></label>
                                        <input asp-for="@Model.Vendor.Website" class="form-control" placeholder="www.website.com" required />
                                        <span asp-validation-for="@Model.Vendor.Website" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.Address1" class="control-label"></label>
                                        <input asp-for="@Model.Vendor.Address1" class="form-control" placeholder="1234 Main St" required />
                                        <span asp-validation-for="@Model.Vendor.Address1" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.Address2" class="control-label"></label>
                                        <input asp-for="@Model.Vendor.Address2" class="form-control" placeholder="Apartment, studio, or floor" />
                                        <span asp-validation-for="@Model.Vendor.Address2" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.City" class="control-label"></label>
                                        <input asp-for="@Model.Vendor.City" class="form-control" placeholder="City" required />
                                        <span asp-validation-for="@Model.Vendor.City" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.State" class="control-label"></label>
                                        <input asp-for="@Model.Vendor.State" class="form-control" data-provide="typeahead" id="state-list" placeholder="State" required />
                                        <span asp-validation-for="@Model.Vendor.State" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.PostalCode" class="control-label"></label>
                                        <input asp-for="@Model.Vendor.PostalCode" class="form-control" data-toggle="input-mask" data-mask-format="00000-000" placeholder="12345" required />
                                        <span asp-validation-for="@Model.Vendor.PostalCode" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="form-group p-1">
                                        <label asp-for="@Model.Vendor.Country" class="control-label"></label>
                                        <input asp-for="@Model.Vendor.Country" class="form-control" data-provide="typeahead" id="country-list" placeholder="Country" required />
                                        <span asp-validation-for="@Model.Vendor.Country" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-4">
                                </div>
                            </div>

                            <div class="form-group form-check">
                                <label class="form-check-label">
                                    <input class="form-check-input" asp-for="@Model.Vendor.IsActive" checked />
                                    @Html.DisplayNameFor(model => model.Vendor.IsActive)
                                </label>
                            </div>

                            <div class="form-group form-check"
                            @(User.IsInRole(RoleList.Administrator) || User.IsInRole(RoleList.ExternalViewer) ? "" : "hidden")>
                                <label class="form-check-label">
                                    <input class="form-check-input" asp-for="@Model.Vendor.IsExternal"
                                           checked="@User.IsInRole(RoleList.ExternalUser)" />
                                    @Html.DisplayNameFor(model => model.Vendor.IsExternal)
                                </label>
                            </div>

                            <div class="form-group p-2">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                <input type="submit" value="Create" class="btn btn-primary" />
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <div class="row">
                    <div class="col-6">
                        <h3 class="text-nowrap">Images</h3>
                        (Click on the <i class="mdi mdi-24px mdi-camera-gopro"></i> button to set the image as the product thumbnail)
                    </div>
                    @if (User.IsInRole(RoleList.CustomerSupportManager) || User.IsInRole(RoleList.Administrator))
                    {
                        <div class="col-6">
                            <button type="button" class="btn btn-dark float-end" data-bs-toggle="modal" data-bs-target="#example-modal">Upload Images</button>
                        </div>
                    }

                </div>

            </div>
            <div class="card-body">
                <div class="row">
                    @foreach (var img in @Model.NirfImageMapping)
                    {
                        <div class="col-12 col-lg-3">
                            <div class="card">
                                @if (img.IsThumbnail)
                                {
                                    <div class="ribbon-wrapper">
                                        <div class="ribbon">Thumbnail</div>
                                    </div>
                                }

                                <img src="~/File?id=@img.FileId" alt="Image not loaded" class="card-img-top img-responsive" />
                                <div class="card-header">
                                    <div class="row">
                                        <div class="col-9">
                                            @img.Files.FileName
                                        </div>
                                        @if (User.IsInRole(RoleList.CustomerSupportManager) || User.IsInRole(RoleList.Administrator))
                                        {
                                            <div class="col-3">
                                                <div class="row">
                                                    <div class="col-6">
                                                        <a class="action-icon" type="submit" asp-action="SetThumbnail"
                                                           asp-route-FileId="@img.FileId" asp-route-NirfFormId="@img.NirfFormId">
                                                            <i class="mdi mdi-24px mdi-camera-gopro"></i>
                                                        </a>
                                                    </div>
                                                    <div class="col-6">
                                                        <a class="action-icon" type="submit" asp-action="DeleteImage"
                                                           asp-route-FileId="@img.FileId" asp-route-NirfFormId="@img.NirfFormId">
                                                            <i class="mdi mdi-24px mdi-delete"></i>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
        <script src="~/js/pages/nirf-edit.min.js?"></script>

    }
}