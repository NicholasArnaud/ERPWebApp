                                    <div class="form-group p-1">
                                        <label class="control-label">Time To Complete</label>

                                    </div>

                                </div>
                            </div>
                            <div class="row">
                                @if (Model.NirfParameters != null)
                                {
                                    <div class="col-4">
                                        <div class="form-group p-1">
                                            <label class="control-label">Hours</label>

                                        </div>
                                        <input class="form-control" name="TimeHour" type="number" min="0" max="23" step="1" value="@Model.NirfParameters.TimeToComplete.Hour" required />
