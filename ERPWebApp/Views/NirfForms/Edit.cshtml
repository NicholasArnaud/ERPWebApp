<div class="row mt-2">
    <div class="col-12 col-lg-6">
        <div class="accordion custom-accordion mt-1" id="custom-accordion-prod">
            <div class="card mb-0">
                <h2 class="accordion-header" id="heading-five">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-five" aria-expanded="false" aria-controls="collapse-five">
                        Shipping
                    </button>
                </h2>
                <div id="collapse-five" class="accordion-collapse collapse" aria-labelledby="heading-five" data-bs-parent="#accordion-example">
                    <div class="accordion-body">

                        <div class="row">
                            <div class="info mdi-24px mdi mdi-help-circle-outline" style="float:right" onclick="infoShipping()">
                                <span class="infotext" id="info-shipping">
                                    Shipping shows the weight, cost, and size of the product being created for each shipping provider that is used. If there are no providers found in the list,
                                    then all fields are already filled out.
                                </span>
                            </div>
                            <div class="form-group p-1">
                                <label class="control-label">Shipping Provider</label>
                                <select name="ShipperList" id="shipper-list"
                                        class="select custom-select select2" data-toggle="select2"
                                        data-placeholder="Choose ..."
                                        asp-items="@ViewBag.ShippersList" required>
                                </select><br /><br />
                                <button class="btn btn-secondary" id="add-provider">Add Provider</button>
                            </div>
                        </div>
                        <form asp-action="SignShipping" class="needs-validation" enctype="multipart/form-data" novalidate>
                            <div class="row" id="shipping">

                                @if (Model.NirfShippings != null)
                                {
                                    for (var i = 0; i < Model.NirfShippings.NirfShippingProvider.Count; i++)
                                    {
                                        <div id="@Model.NirfShippings.NirfShippingProvider.ToList()[i].ShippingProviderId">
                                            <h3>@Model.NirfShippings.NirfShippingProvider.ToList()[i].ShippingProvider.ShippingProviderName</h3>
                                            <input asp-for="@Model.NirfShippings.NirfShippingProvider.ToList()[i].ShippingProviderId" hidden />
                                            <label class="control-label">Weight(lbs)</label>
                                            <input class="form-control" min="0.01" step="0.01" type="number" asp-for="@Model.NirfShippings.NirfShippingProvider.ToList()[i].ShippingWeight" placeholder="0.00" required />

                                            <label class="control-label">Size</label>
                                            <input class="form-control" asp-for="@Model.NirfShippings.NirfShippingProvider.ToList()[i].ShippingSize" placeholder="5x5x5" required />

                                            <label class="control-label">Cost</label>
                                            <input class="form-control" min="0.01" step="0.01" type="number" asp-for="@Model.NirfShippings.NirfShippingProvider.ToList()[i].ShippingCost" placeholder="0.00" required />
                                            <i class="mdi mdi-24px mdi-delete item-action-btn dismiss" name="dismiss"></i><br />
                                            <input id="@Model.NirfShippingProvider[i].ShippingProviderId-e" asp-for="@Model.NirfShippings.NirfShippingProvider.ToList()[i].ErrorMessage" hidden>
                                        </div>
                                    }
                                }


                                @for (var i = 0; i < Model.NirfShippingProvider.Count; i++)
                                {
                                    <div id="@Model.NirfShippingProvider[i].ShippingProviderId" style="display:none">
                                        <h3>@Model.NirfShippingProvider[i].ShippingProvider.ShippingProviderName</h3>
                                        <input asp-for="@Model.NirfShippingProvider[i].ShippingProviderId" hidden />
                                        <label class="control-label">Weight(lbs)</label>
                                        <input class="form-control" min="0.01" step="0.01" type="number" asp-for="@Model.NirfShippingProvider[i].ShippingWeight" placeholder="0.00" required />

                                        <label class="control-label">Size</label>
                                        <input class="form-control" asp-for="@Model.NirfShippingProvider[i].ShippingSize" placeholder="5x5x5" required />

                                        <label class="control-label">Cost</label>
                                        <input class="form-control" min="0.01" step="0.01" type="number" asp-for="@Model.NirfShippingProvider[i].ShippingCost" placeholder="0.00" required />
                                        <i class="mdi mdi-24px mdi-delete item-action-btn dismiss" name="dismiss"></i><br />
                                        <input id="@Model.NirfShippingProvider[i].ShippingProviderId-e" asp-for="@Model.NirfShippingProvider[i].ErrorMessage" hidden>
                                    </div>
                                    @* <div id="@item.ShippingProviderId">
                                @{
                                await Html.RenderPartialAsync("PartialEditRow", item);
                                }
                                </div>*@
                                }
                                @* @{
                                await Html.RenderPartialAsync("PartialEdit", Model.NirfShippingProvider);
                                }*@
                            </div>

                            <input asp-for="NirfShippings.NirfFormId" value="@Model.NirfProductMapping.NirfForm.NirfFormId" hidden />
                            <div class="row">
                                <div class="col-12">
                                    <div class="form-group p-1">
                                        <label class="control-label">Other</label>
                                        <textarea asp-for="NirfShippings.Comments" class="form-control" rows="7"></textarea>
                                    </div>
                                </div>
                            </div>
                            @if (Model.NirfShippings == null)
                            {
                                @if (User.IsInRole(RoleList.ShippingManager) || User.IsInRole(RoleList.Administrator))
                                {
                                    <div class="row">
                                        <div class="col-6">
                                            <button id="shipping-button" title="Finish Adding Providers" type="submit" class="btn btn-primary" disabled>Sign</button>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="row justify-content-center">
                                    <span class="badge rounded-pill bg-light col-12" style="font-size: 1.1em; margin: 10px 0px;">@Model.NirfShippings.SignedBy : @Model.NirfShippings.SignedOn.ToLongDateString()</span>
                                </div>
                            }
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-6">
        <div class="accordion custom-accordion mt-1" id="custom-accordion-prod">
            <div class="card mb-0">
                <h2 class="accordion-header" id="heading-vendor">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-vendor" aria-expanded="false" aria-controls="collapse-vendor">
