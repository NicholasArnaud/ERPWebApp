                                {
                                    <div class="col-6">
                                        <div class="form-group p-1">
                                            <label class="control-label">Temperature</label>
                                            <input class="form-control" min="0" type="number" asp-for="NirfParameters.Temperature" required />
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="form-group p-1">
                                            <label class="control-label">Temperature Type</label>
