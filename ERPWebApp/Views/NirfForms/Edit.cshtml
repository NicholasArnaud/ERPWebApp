                                    <div class="col-4">
                                        <div class="form-group p-1">
                                            <label class="control-label">Minutes</label>

                                        </div>
                                        <input class="form-control" name="TimeMin" type="number" min="0" max="59" step="1" value="@Model.NirfParameters.TimeToComplete.Minute" required />

                                    </div>
                                    <div class="col-4">
                                        <div class="form-group p-1">
                                            <label class="control-label">Seconds</label>

                                        </div>
                                        <input class="form-control" name="TimeSec" type="number" min="0" max="59" step="1" value="@Model.NirfParameters.TimeToComplete.Second" required />

                                    </div>
                                }
                                else
                                {
                                    <div class="col-4">
                                        <div class="form-group p-1">
                                            <label class="control-label">Hours</label>

                                        </div>
                                        <input class="form-control" name="TimeHour" type="number" min="0" max="23" step="1" value="0" required />
                                    </div>
                                    <div class="col-4">
                                        <div class="form-group p-1">
                                            <label class="control-label">Minutes</label>

                                        </div>
                                        <input class="form-control" name="TimeMin" type="number" min="0" max="59" step="1" value="0" required />

                                    </div>
                                    <div class="col-4">
                                        <div class="form-group p-1">
                                            <label class="control-label">Seconds</label>

                                        </div>
                                        <input class="form-control" name="TimeSec" type="number" min="0" max="59" step="1" value="0" required />

