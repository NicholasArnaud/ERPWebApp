        function getLocationOptions(pickOnlyLocations, receiveOnlyLocations, totalAvailable, quantity, received, index) {
            if (received) {
                return ["", ""];
            }

            let fromContent = "";
            let toContent = "";

            if (totalAvailable >= quantity) {
                fromContent = `<select class='form-control select2' data-toggle='select2' name='stockTransfers[${index}].FromLocationId'>`;
                toContent = `<select class='form-control select2' data-toggle='select2' name='stockTransfers[${index}].ToLocationId'>`;

                pickOnlyLocations.forEach(location => {
                    fromContent += `<option value='${location.locationId}'>${location.locationName} (${location.totalAvailable})</option>`;
                });

                receiveOnlyLocations.forEach(location => {
                    // Check if the current location is "PRODUCTION" and set it as the default option
                    const selected = location.locationName === "PRODUCTION" ? " selected" : "";
                    toContent += `<option value='${location.locationId}'${selected}>${location.locationName}</option>`;
                });

                fromContent += "</select>";
                toContent += "</select>";
            } else {
                fromContent = "Insufficient stock";
                toContent = "";
            }

            return [fromContent, toContent];
        }

        async function updateLocationInfoInventory(dropdown) {
            const newSku = dropdown.value;
            const row = dropdown.closest('tr');
            const orderBatchId = row.getAttribute('data-orderbatchid');
            const productIdInput = row.querySelector('input[name$=".ProductId"]');
            const index = row.getAttribute('data-index');

            // Fetch the productId for the new SKU using AJAX
            const productIdResponse = await fetch(`/OrderBatch/GetProductIdBySku?sku=${newSku}`);
            const newProductId = await productIdResponse.json();
            productIdInput.value = newProductId;

            const response = await fetch(`/OrderBatch/GetLocationInfo?sku=${newSku}`);
            const locationInfo = await response.json();

            const toColumn = row.cells[5];

            const pickOnlyLocations = locationInfo.filter(location => location.type === 1);
            const receiveOnlyLocations = locationInfo.filter(location => location.type === 2);

            // Calculate totalAvailable for the location with the most available stock
            const maxLocation = pickOnlyLocations.reduce((max, location) => location.totalAvailable > max.totalAvailable ? location : max, { totalAvailable: 0 });
            const totalAvailable = maxLocation.totalAvailable;
            const quantity = parseInt(row.cells[3].textContent);

            // Use the getLocationOptions function to generate the 'From' and 'To' select elements
            const [fromContent, toContent] = getLocationOptions(pickOnlyLocations, receiveOnlyLocations, totalAvailable, quantity, false, index);

            const fromContentDiv = row.querySelector(`#from-content-${index}`);
            fromContentDiv.innerHTML = fromContent;
            toColumn.innerHTML = toContent;

            if (totalAvailable >= quantity) {
                row.style.backgroundColor = "";
                row.style.color = "";
            } else {
                row.style.backgroundColor = "#55444D";
                row.style.color = "#FF9D9D";
            }

            checkSufficientStock();
        }

        function checkSufficientStock() {
            const rows = document.querySelectorAll('#testdatatable tbody tr[data-orderbatchid]');
            const verifyBtn = document.getElementById('verify-btn');
            const stockAlert = document.getElementById('stock-alert');

            let hasSufficientStock = true;

            rows.forEach(row => {
                const fromColumn = row.cells[4];
                const fromColumnSelect = fromColumn.querySelector('select');
                if (fromColumnSelect) {
                    const selectedOptionText = fromColumnSelect.options[fromColumnSelect.selectedIndex].text;
                    const totalAvailable = parseInt(selectedOptionText.split('(').pop().split(')')[0]);
                    const quantity = parseInt(row.cells[3].textContent);

                    if (totalAvailable < quantity) {
                        hasSufficientStock = false;
                    }
                } else if (fromColumn.textContent === "Insufficient stock" || fromColumn.textContent === "") {
                    hasSufficientStock = false;
                } else {
                    hasSufficientStock = false;
                }
            });

            if (hasSufficientStock) {
                verifyBtn.classList.replace('btn-secondary', 'btn-primary');
                verifyBtn.disabled = false;
                stockAlert.classList.remove('alert', 'alert-danger');
                stockAlert.textContent = '';
            } else {
                verifyBtn.classList.replace('btn-primary', 'btn-secondary');
                verifyBtn.disabled = true;
                stockAlert.classList.add('alert', 'alert-danger');
                stockAlert.textContent = 'One or more products do not have enough stock for transfer.';
            }
        }
    </script>
