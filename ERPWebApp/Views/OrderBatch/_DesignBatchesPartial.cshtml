@using ERPWebApp.Models.Company
@using ERPWebApp.Models.Orders
@model Tuple<List<DesignBatchItemViewModel>, List<DepartmentStatusLineViewModel>>

<style>
    .status-line-container {
        position: relative;
    }

    .status-line {
        width: 100%;
        height: 2px;
        background-color: #ccc;
        position: relative;
    }

    .status-dot-wrapper {
        display: inline-flex;
        position: absolute;
        height: 100%;
        width: 100%;
    }

    .status-dot {
        position: absolute;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #00bcd4;
        top: -4px;
        transform: translateX(-50%);
    }

    .status-names {
        position: relative;
        width: 100%;
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        margin-top: 4px;
    }

    .status-name {
        position: absolute;
        text-align: center;
        width: 100%;
        transform: translateX(-50%);
    }

    hr {
        margin-top: 1rem;
        margin-bottom: 1rem;
        border: 0;
        border-top: 1px solid rgba(0, 0, 0, 0.1);
    }

    .department-status-line-container .col-4 {
        flex: 0 0 auto;
        width: 400px;
        margin-right: 3rem;
        max-width: 100%;
    }

        .department-status-line-container .col-4:last-child {
            margin-right: 0;
        }
</style>

<div class="modal fade" id="setStatusModal" tabindex="-1" role="dialog" aria-labelledby="setStatusModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="setStatusModalLabel">Set Batch Item Status</h5>
            </div>
            <div class="modal-body">
                <form id="setStatusModalForm">
                    <div class="form-group">
                        <label for="status-select">Status</label>
                        <select id="status-select" class="form-control select2" data-toggle="select2" name="status">
                            <!-- Options will be populated dynamically -->
                        </select>
                    </div>
                </form>
                <div id="status-modal-message" class="text-danger mt-2" style="display: none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="setStatusModalConfirmButton">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="transferModal" tabindex="-1" role="dialog" aria-labelledby="transferModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="transferModalLabel">Transfer Product</h5>
            </div>
            <div class="modal-body">
                <form id="transferModalForm">
                    <div class="form-group" id="alt-item-group" style="display: none;">
                        <label for="alt-item-select">Alt Item Number</label>
                        <select id="alt-item-select" class="form-control select2" data-toggle="select2" name="altItemNumber">
                            <!-- Options will be populated dynamically -->
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="transfer-from">From Location</label>
                        <select id="transfer-from" class="form-control select2" data-toggle="select2" name="transferFrom">
                            <!-- Options will be populated dynamically -->
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="transfer-to">To Location</label>
                        <select id="transfer-to" class="form-control select2" data-toggle="select2" name="transferTo">
                            <!-- Options will be populated dynamically -->
                        </select>
                    </div>
                </form>
                <div id="transfer-modal-message" class="text-danger mt-2" style="display: none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="transferModalCancelButton" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="transferModalConfirmButton">Transfer</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Delete Confirmation</h5>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this entry?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="deleteConfirmButton">Delete</button>
            </div>
        </div>
    </div>
</div>

<div id="department-status-lines" class="row department-status-line-container">
    @foreach (var departmentStatusLine in Model.Item2)
    {
        <div class="col-4">
            <h4>@departmentStatusLine.Department.DepartmentName</h4>
            <div class="status-line-container">
                <div class="status-line">
                    @for (var i = 0; i < departmentStatusLine.Statuses.Count; i++)
                    {
                        var status = departmentStatusLine.Statuses[i];
                        <div class="status-dot-wrapper">
                            <div class="status-dot" data-bs-toggle="tooltip" data-bs-placement="bottom" data-bs-original-title="@status.StatusName" style="left: @(i * (100.0 / (departmentStatusLine.Statuses.Count - 1)))%;"></div>
                        </div>
                    }
                </div>
            </div>
            <div class="status-names">
                @for (var i = 0; i < departmentStatusLine.Statuses.Count; i++)
                {
                    var status = departmentStatusLine.Statuses[i];
                    <div class="status-name" style="left: @(i * (100.0 / (departmentStatusLine.Statuses.Count - 1)))%;">@status.StatusName</div>
                }
            </div>
        </div>
    }
</div>
<hr>


