<table id="design-batches-table" class="table dt-responsive webkit-nowrap w-100">
    <thead>
        <tr>
            <th>Sku</th>
            <th>Quantity</th>
            <th>Description</th>
            <th>Department</th>
            <th>Status</th>
            <th>Image</th>
            <th>Transfer</th>
            <th style="display: none;">Delete</th>
            @if (User.IsInRole(RoleList.Developer) || (User.IsInRole(RoleList.Administrator)))
            {
                <th>Progress</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Item1)
        {
            <tr data-orderbatchid="@item.OrderBatchId" data-orderbatchitemid="@item.OrderBatchItemId">
                <td>@item.Sku</td>
                <td>@item.Quantity</td>
                <td>@item.Description</td>
                <td>@item.DepartmentName</td>
                <td>@item.Status.StatusName</td>
                <td>
                    <img src="@item.ImageSrc" alt="@item.Description" style="max-width: 100px; max-height: 100px;">
                </td>
                <td>
                    @if (@* item.RequiresPO ? anyInvalidStock :  *@!item.IsValidStock || item.BatchItem.IsPicked)
                    {
                        <button type="button" class="btn btn-secondary" disabled>Transfer</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary transfer-btn">Transfer</button>
                    }
                </td>
                <td style="display: none;">
                    <button type="button" class="btn btn-danger delete-btn" data-toggle="modal" data-target="#deleteModal">Delete</button>
                </td>
                @if (User.IsInRole(RoleList.Developer) || (User.IsInRole(RoleList.Administrator)))
                {
                    <td>
                        <button type="button" class="btn btn-info progress-btn">Progress</button>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>  