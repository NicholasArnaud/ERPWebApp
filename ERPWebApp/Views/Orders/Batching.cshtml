<style>
    .modal-scroll {
        max-height: 80vh;
        overflow-y: auto;
    }
</style>

<!-- Unassigned Departments Modal -->
<div id="UnassignedDepartments-model" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Unassigned Departments</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body modal-scroll">
                <div id="unassignedDepartmentsContainer"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="updateDepartments">Update Departments</button>
            </div>
        </div>
    </div>
</div>

<!-- Missing SKUs Modal -->
<div id="MissingSKUs-model" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Missing SKUs</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body modal-scroll">
                <div id="missingSKUsContainer"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="replaceMissingSKUs">Replace SKUs</button>
            </div>
        </div>
    </div>
</div>

<!-- Department Selection Modal -->
<div id="DepartmentSelectionModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Select Department</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <label for="departmentSelect">Department</label>
                <select class="form-control select2" id="departmentSelect">
                    <!-- The options will be populated dynamically -->
                </select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="saveDepartmentButton">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Add Order to Batch Modal -->
<div id="AddOrderToBatch-modal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Order to Batch</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="AddOrderToBatch-form" method="post" asp-action="AddOrdersToBatch">
                    <div class="mb-3">
                        <label for="openBatchesSelect">Select Batch</label>
                        <select class="form-control select2" id="openBatchesSelect" name="BatchId">
                            @foreach (var batch in Model.OrderBatchesForOrderAddition)
                            {
                                <option value="@batch.Value">@batch.Text</option>
                            }
                        </select>
                    </div>
                    <hr>
                    <div>
                        <p>Orders to be added:</p>
                        <ul id="selectedOrderNumbersList">
                            <!-- Selected order numbers will be populated dynamically -->
                        </ul>
                    </div>
                    <input type="hidden" name="ERPOrderIdsJson" id="ERPOrderIdsJson" />
                    <div id="duplicateBatchError" class="text-danger"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="addOrderToBatchButton" data-addordertobatch>Add</button>
            </div>
        </div>
    </div>
</div>

<!-- Batch Creation Modal -->
<form asp-action="BatchCreation" method="post" id="CreateBatch-form">
    <input type="hidden" name="ERPOrderIdsJson" id="selectedOrderIds-BatchCreation" />
    <div id="CreateBatch-model" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-right">
            <div class="modal-content">
                <div class="modal-body p-4 modal-scroll">
                    <div class="text-center">
                        <i class="ri-information-line h1 text-info"></i>
                        <h4 class="mt-2">Heads up!</h4>
                        <p class="mt-3">Batching orders tends to take a while.</p>
                        <p class="mt-3">It might take some time for the batch to be created.</p>
                    </div>
                    <hr>
@*                     <label for="batchTypeSelect">Batch Type</label>
                    <select class="form-control select2" id="batchTypeSelect" name="BatchType">
                        <option value="Inventory" selected>Inventory</option>
                        <option value="Design">Design</option>
                    </select> *@
                    <div id="deductibleCheckboxContainer" class="mt-2">
                        <input class="form-check-input" type="checkbox" value="true" id="isDeductibleCheckbox" checked>
                        <label class="form-check-label" for="isDeductibleCheckbox">
                            Deductible
                        </label>
                    </div>
                    <hr>
                    <input type="text" class="form-control" name="BatchName" id="batchNameInput" placeholder="Enter batch name...">

                    <div class="modal-footer">
                        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
                        <button type="button" class="btn btn-light" data-createbatch>Continue</button>
                    </div>
                    <div id="duplicateBatchErrorCreation" class="text-danger" style="display: block; visibility: visible;"></div>
                </div>
            </div><!-- /.modal-content -->
        </div><!-- /.modal-dialog -->
    </div><!-- /.modal -->
</form>

<div id="BatchCreationSuccess-model" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Success</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Batch creation successful.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal" id="successModalOkButton" data-modal-type="success">OK</button>
            </div>
        </div>
    </div>
</div>

<div id="BatchCreationFailure-model" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Error</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Batch creation failed.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal" id="failureModalOkButton" data-modal-type="failure">OK</button>
            </div>
        </div>
    </div>
</div>

<div id="AddToBatchSuccess-model" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Success</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Adding order(s) to batch successful.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal" id="addToBatchSuccessModalOkButton" data-modal-type="success">OK</button>
            </div>
        </div>
    </div>
</div>

<div id="AddToBatchFailure-model" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Error</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Adding order(s) to batch failed.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal" id="addToBatchFailureModalOkButton" data-modal-type="failure">OK</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="printPreviewModal" tabindex="-1" role="dialog" aria-labelledby="printPreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="printPreviewModalLabel">Pick List</h5>
                <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="printPreviewModalBody">
                <!-- The print preview content will be added here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="printPreviewButton">Print</button>
            </div>
        </div>
    </div>
</div>
<div id="printContentContainer" style="display: none;"></div>
