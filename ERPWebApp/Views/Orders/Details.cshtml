    <a asp-action="Edit" asp-route-id="@Model?.ERPOrderId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script type="text/javascript" src="~/js/pages/Orders/Details.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            let code = "";
            let reading = false;

            document.addEventListener('keypress', e => {
                if (e.key === 'Enter' && code.length > 0) {
                    $('#straight-to-order').submit();
                    code = "";
                    $('#quickOrderNumberSearch').val(code);
                }
                else {
                    code += e.key;
                    $('#quickOrderNumberSearch').val(code);
                }
                if(!reading) {
                    reading = true;
                    setTimeout(() => {
                        code = "";
                        $('#quickOrderNumberSearch').val(code);
                        reading = false;
                    }, 400);
                }
            });
            if ("@Model.orderStatus" === "@Order.OrderStatus.awaiting_shipment"
                && ("@User.IsInRole(RoleList.ShippingBasic)" ==="true" || "@User.IsInRole(RoleList.ShippingManager)" === "true")
            ) {
                $('#OrderShipping-offcanvas').modal('show');
            }
            if("@Model.orderStatus" === "@Order.OrderStatus.shipped" && "@Model.orderShipments.Any(x => !x.voided)" === "true")
            {
                $('#create-shipment-btn').hide();
            }

            let actions = {
                RateEstimateAction : '@Url.Action("GetRateEstimate", "Orders")',
                GenerateLabelAction : '@Url.Action("GenerateLabelAndShip", "Orders")',
                Order : '@Url.Action("Index", "Orders")'
            };

            initialize_OrderDetails(actions);

            let viewData = getViewData();
            updateUI(viewData);

            $("#weight-value-input, #length-value-input, #width-value-input, #height-value-input, #weight-unit-dropdown, #dimensional-unit-dropdown").on("change", ()=>{
                let viewData = getViewData();
                updateUI(viewData);
            });
        });

        const getViewData = () => {
            return {
                orderWeight: parseFloat('@ViewData["OrderWeight"]') || 0,
                orderVolume: parseFloat('@ViewData["OrderVolume"]') || 0,
                zeroWeightSkus: @Html.Raw(Json.Serialize(ViewData["ZeroWeightSkus"])) || [],
                zeroVolumeSkus: @Html.Raw(Json.Serialize(ViewData["ZeroVolumeSkus"])) || [],
                weightUnit: '@(Model.items.FirstOrDefault()?.Product?.WeightUnit ?? 0)',
                dimensionalUnit: '@(Model.items.FirstOrDefault()?.Product?.DimensionalUnit ?? 0)'
            };
        }

        function setDimensions(length, width, height)
        {
            document.getElementById('length-value-input').value = length;
            document.getElementById('width-value-input').value = width;
            document.getElementById('height-value-input').value = height;
            let viewData = getViewData();
            updateUI(viewData);
        }
    </script>
}
