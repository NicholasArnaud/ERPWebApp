@using ERPWebApp.Models.Orders
@model ERPWebApp.Data.DTOModels.OrderViewModel

@{
    ViewData["Title"] = "Orders";
}
@await Html.PartialAsync("Batching")

<style>
    .green-outline {
        border: 2px solid green;
    }

    .dt-buttons {
        display: inline-flex !important;
        align-items: center;
        gap: 10px;
        margin: 0;
    }

    .dataTables_filter {
        margin-left: auto;
        text-align: right;
    }

    .dataTables_wrapper .row:first-child {
        align-items: center;
    }
</style>

<form asp-action="StraightToOrder" method="get" id="straight-to-order" hidden>
    <label asp-for="OrderNumber" class="control-label"></label>
    <input type="text" asp-for="OrderNumber" name="OrderNumber" class="form-control" id="quickOrderNumberSearch" />
    <button type="submit"></button>
</form>
<!-- GetOrderUpdatesBulk Modal -->
<form asp-action="GetOrderUpdatesBulk" method="post" id="OrderUpdatesBulk-form">
    <input type="hidden" name="ERPOrderIdsJson" id="selectedOrderIds-OrderUpdatesBulk" />
    <div id="OrderUpdatesBulk-model" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-md">
            <div class="modal-content">
                <div class="modal-body p-4">
                    <div class="text-center">
                        <i class="ri-information-line h1 text-info"></i>
                        <h4 class="mt-2">Heads up!</h4>
                        <p class="mt-3">
                            Running a bulk Action can take some time depending on how many rows were
                            selected. Please exercise patience until the page has reloaded otherwise the selected action
                            will not complete.
                        </p>
                        <p class="mt-3">Some orders when updated, may no longer apply to current filters.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-light" id="OrderUpdatesBulk-btn">Continue</button>
                    </div>
                </div>
            </div><!-- /.modal-content -->
        </div><!-- /.modal-dialog -->
    </div><!-- /.modal -->
</form>
