@model ERPWebApp.Models.Inventory.ProductContainersFilter

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<head xmlns="http://www.w3.org/1999/html">
    <link rel="stylesheet" type="text/css" href="~/css/datatablecoloring.css">
    <link rel="stylesheet" type="text/css" href="~/css/sliderbutton.css">
</head>

<div class="row">
    <div class="col-12">

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Product Containers</h3>
            </div>

            <div class="card-body">

                @if (User.IsInRole(RoleList.Administrator) ||
                        User.IsInRole(RoleList.InventoryManager) ||
                        User.IsInRole(RoleList.ShippingManager))
                {
                    <div class="row custom-bb">
                        <div class="col-md-3 col-sm-5 col-xs-12">
                            <a class="btn btn-dark" asp-action="Create">Create New</a>
                        </div>
                    </div>
                }

                <div class="row mb-3 d-print-none">

                    <!--Filters-->
                    <div class="col-12">
                        <div class="row">

                            <div class="col-md-4 col-sm-6 col-xs-12 custom-mt-xs">
                                <label for="product-select">Sku</label>
                                <select id="product-select" class="form-control select2" data-toggle="select2" asp-items="Model.Sku">
                                    <option>Any</option>
                                </select>
                            </div>

                            <div class="col-md-4 col-sm-6 col-xs-12 custom-mt-xs">
                                <label for="vendor-select">Vendor</label>
                                <select id="vendor-select" class="form-control select2" data-toggle="select2" asp-items="Model.Vendor">
                                    <option>All</option>
                                </select>
                            </div>

                            @if (User.IsInRole(RoleList.Administrator) || User.IsInRole(RoleList.Manager))
                            {

                                <div class="col-md-4 col-sm-6 col-xs-12 custom-mt-sm custom-mt-xs d-flex flex-column justify-content-center">

                                    <div class="form-check form-switch">
                                        <label class="form-check-label" for="custom-switch-3" id="custom-switch-3-label">Is Active</label>
                                        <input type="checkbox" class="form-check-input" id="custom-switch-3" />
                                    </div>

                                </div>

                            }
                        </div>
                    </div>

                </div>

                <hr class="hr m-0 mt-2 mb-2" />

                <div id="error-warning" style="display:none" class="row">
                    <div class="alert alert-warning" role="alert">
                        <i class="dripicons-warning mr-2"></i>Red Container dimensions do not have the volume for the product dimensions<i class="dripicons-warning mr-2"></i>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div id="filtered-orders-partial">
                            @{
                                await Html.RenderPartialAsync("PartialView", Model.ProductContainers);
                            }
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>
<div hidden id="lastconid"></div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    @* <link rel="stylesheet" type="text/css" href="~/css/datatablecoloring.css"> *@
    <script src="~/js/pages/container-datatable.min.js"></script>
}
