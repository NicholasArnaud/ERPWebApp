@model ERPWebApp.Data.DTOModels.ProductGalleryDTO
@using Newtonsoft.Json
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .product-image-container {
        background-color: white;
        width: 100%;
        height: 40vh;
        object-fit: contain;
    }

</style>
<div class="row">
    <div class="col-12">
        <div class="card col-12 mt-2">
            <div class="card-header">
                <h3 class="card-title">Product Gallery</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <form asp-action="Index" asp-route-type="Filter" id="myForm">
                        <div class="row">
                            <div class="form-group p-1 col-12 col-sm-5 col-md-5">
                                <label class="control-label"> Select  a department</label>
                                <select class="select2 form-control select2-multiple"
                                        data-placeholder="Choose ..."
                                        id="department-pid"
                                        name="SelectedDepartments">
                                    @* <option value="">Select a department</option> *@
                                </select>
                            </div>
                            <div class="form-group p-1 col-12 col-sm-5 col-md-5">
                                <label class="control-label"> Select  a product</label>
                                <select class="select2 form-control select2-multiple"
                                        data-placeholder="Choose ..."
                                        id="product-pid"
                                        name="SelectedProducts">
                                    @* <option value="">Select a product</option> *@
                                </select>
                            </div>
                            <div class="col-12 col-sm-2 col-md-2 max-auto d-grid p-3">
                                <button class="action-button btn btn-primary" type="submit">Filter</button>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="row mb-3 align-items-center text-center">
                    <div class="col-12 col-xl-6 col-sm-12 col-md-6" style="text-align: left;">
                        <div class="pagination-info mb-2">
                            Showing @(Math.Min(Model.TotalEntries, (Model.CurrentPage - 1) * Model.EntriesPerPage + 1))
                            to @(Math.Min(Model.TotalEntries, Model.CurrentPage * Model.EntriesPerPage))
                            of @Model.TotalEntries entries
                        </div>
                    </div>
                    <div class="col-12 col-xl-6 col-sm-12 col-md-6">
                        @if (Model.TotalPages < 5)
                        {
                            <nav aria-label="Page navigation" class="mx-auto" style="float: right;">
                                <ul class="pagination pagination-rounded">

                                    @for (int i = 1; i <= Model.TotalPages; i++)
                                    {
                                        <li class="page-item @(i == Model.CurrentPage ? "active" : "") pl-2">
                                            <a class="page-link page-c-id">
                                                @i
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                        else
                        {

                            int totalPages = Model.TotalPages;
                            int currentPage = Model.CurrentPage;

                            int startPage;
                            int endPage;

                            if (totalPages <= 2) // If there are 5 or fewer total pages, show all pages.
                            {
                                startPage = 1;
                                endPage = totalPages;
                            }
                            else if (currentPage <= 2) // Show the first 5 pages when on the first 3 pages.
                            {
                                startPage = 1;
                                endPage = 2;
                            }
                            else if (currentPage >= totalPages - 2) // Show the last 5 pages when on the last 3 pages.
                            {
                                startPage = totalPages - 2;
                                endPage = totalPages;
                            }
                            else // Show 5 pages centered around the current page.
                            {
                                startPage = currentPage - 1;
                                endPage = currentPage + 2;
                            }

                            <nav aria-label="Page navigation" class="mx-auto" style="float: right;">
                                <ul class="pagination pagination-rounded">
                                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" id="page-f" data-pageindex="1" aria-label="Previous">
                                            <span aria-hidden="true">&laquo;</span>

                                        </a>
                                    </li>
                                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" id="page-p" data-pageindex="@(@Model.CurrentPage - 1)" aria-label="Previous">
                                            <span aria-hidden="true">&lsaquo;</span>
                                        </a>
                                    </li>

                                    @if (startPage > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link page-c-id">1</a>
                                        </li>
                                        @if (startPage > 2)
                                        {
                                            <li class="page-item disabled">
                                                <span class="page-link">...</span>
                                            </li>
                                        }
                                    }

                                    @for (int i = startPage; i <= endPage; i++)
                                    {
                                        <li class="page-item @(i == currentPage ? "active" : "")">
                                            <a class="page-link page-c-id">@i</a>
                                        </li>
                                    }

                                    @if (endPage < totalPages)
                                    {
                                        @if (endPage < totalPages - 1)
                                        {
                                            <li class="page-item disabled">
                                                <span class="page-link">...</span>
                                            </li>
                                        }
                                        <li class="page-item">
                                            <a class="page-link page-c-id">@totalPages</a>
                                        </li>
                                    }
                                    <li class="page-item @(Model.CurrentPage == totalPages ? "disabled" : "")">
                                        <a class="page-link" id="page-n" data-pageindex="@(@Model.CurrentPage + 1)" aria-label="Next">
                                            <span aria-hidden="true">&rsaquo;</span>
                                        </a>

                                    </li>
                                    <li class="page-item @(Model.CurrentPage == totalPages ? "disabled" : "")">
                                        <a class="page-link" id="page-l" data-pageindex="@Model.TotalPages" aria-label="Next">
                                            <span aria-hidden="true">&raquo;</span>

                                        </a>
                                    </li>

                                </ul>
                            </nav>

                        }
                    </div>
              
                </div>

                <div class="row">
                    <div class="col-12">
                        @if (Model.Products == null || Model.Products.Count() == 0)
                        {
                            <p class="text-center text-muted mt-4">No data found.</p>
                        }
                        else
                        {
                            <div class="container">
                                <div class="row" id="card-container">
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        var departmentList = @Html.Raw(Json.Serialize(ViewBag.DepartmentList is null ? new object[] {} : ViewBag.DepartmentList));
        var productList = @Html.Raw(Json.Serialize(ViewBag.ProductList is null ? new object[] {} : ViewBag.ProductList));

        $(document).ready(function () {
            //initialize the select2 components for department filter
            departmentList.forEach(function (value, index) {
                $("#department-pid").append($('<option>', {
                    value: value.value,
                    text: value.text
                }));
            });
            $("#department-pid").select2({
                multiple: true
            });

            //initialize the select2 components for product filter
            productList.forEach(function (value, index) {
                $("#product-pid").append($('<option>', {
                    value: value.value,
                    text: value.text
                }));
            });
            $("#product-pid").select2({
                multiple: true
            });

            //setting all select2 components' initial value to null (for some reason browser selecting the first item automatically)
            $('.select2').val(null).trigger('change');

            var products = @Html.Raw(Json.Serialize(Model.Products));

            // Generate card views from the data
            products.forEach(function (item) {
                var defaultImage = item.productImages.find(function (image) {
                    return image.isDefault;
                });
                var card = `<div class="col-12 col-sm-4 col-md-3 mb-4">
                              <div class="card">
                                    <img src="${defaultImage.fileUrl}" id="default_Image" class="card-img-top product-image-container" alt="${item.sku}">
                                <div class="card-body">
                                        <h5 class="card-title">${item.sku}</h5>
                                        <p class="card-text">${item.description}</p>
                                    </div>
                                </div>
                        </div>`;
                $('#card-container').append(card);
            });

            $("#department-pid").on("change", handleDepartmentChange);
        });

        function handleDepartmentChange() {
            var departmentIds = $("#department-pid").val().length > 0 ? JSON.stringify($("#department-pid").val()) : null;
            var productIds = $("#product-pid").val().length > 0 ? JSON.stringify($("#product-pid").val()) : null;
            $.ajax({
                url: "../ProductGallery/GetProductsByDepartment",
                type: "GET",
                data: { departmentIds, productIds },
                success: function (data) {

                    $("#product-pid").empty();

                    let s = ''
                    for (let i = 0; i < data.product.length; i++) {
                        s += '<option value="' + data.product[i].productId + '">' + data.product[i].sku + '</option>'
                    }

                    $('#product-pid').html(s)

                    $("#product-pid").select2({
                        multiple: true
                    });

                    $('#product-pid').val(data.selectedProduct);
                    $('#product-pid').trigger('change');

                },
                error: function (error) {
                    console.log(error);
                }
            });
        }

        $('.page-c-id').click(function () {
            var pageindex = parseInt($(this).html(), 10);
            paging(pageindex);
        });

        $('#page-f').click(function () {
            var pageindex = parseInt($(this).data('pageindex'), 10);
            paging(pageindex);
        });

        $('#page-p').click(function () {
            var pageindex = parseInt($(this).data('pageindex'), 10);
            paging(pageindex);
        });

        $('#page-l').click(function () {
            var pageindex = parseInt($(this).data('pageindex'), 10);
            paging(pageindex);
        });

        $('#page-n').click(function () {
            var pageindex = parseInt($(this).data('pageindex'), 10);
            paging(pageindex);
        });

        function paging(pageindex) {

            var products = $("#product-pid").val().length > 0 ? JSON.stringify($("#product-pid").val()) : null;
            var departments = $("#department-pid").val().length > 0 ? JSON.stringify($("#department-pid").val()) : null;

            var url = `/ProductGallery/Pagination?pageIndex=${pageindex}&departmentIds=${departments}&productIds=${products}`;

            window.location.href = url;
        }
    </script>

}
