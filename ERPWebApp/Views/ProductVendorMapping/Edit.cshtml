@model ERPWebApp.Models.Mappings.ProductVendorMapping

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Edit</h1>
<hr />
<div class="container-fluid text-white">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Product Vendor Mapping</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
        </ol>
    </nav>
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="card-title">Product Vendor Mapping</h2>
                <div>
                    <button type="submit" name="submit" class="action-button btn btn-primary"><span class="mdi mdi-18px ">Save</span></button>
                    <a asp-action="Index">
                        <button type="button" class="btn btn-info"><span class="mdi mdi-18px mdi-arrow-top-left-thick">&nbsp;Back to List</span></button>
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-6">
                        <input id="editid" asp-for="ProductVendorMappingId" value="@Model.ProductVendorMappingId" type="hidden" />
                        <input asp-for="ProductId" value="@Model.ProductId" type="hidden" />
                        <input asp-for="VendorId" value="@Model.VendorId" type="hidden" />
                        <div class="form-group mt-2">
                            <label asp-for="Product.Sku" class="control-label"></label>
                            <input asp-for="Product.Sku" class="form-control" readonly />
                            <span asp-validation-for="Product.Sku" class="text-danger"></span>
                        </div>
                        <div class="form-group mt-2">
                            <label asp-for="Vendor.VendorName" class="control-label"></label>
                            <input asp-for="Vendor.VendorName" class="form-control" readonly />
                            <span asp-validation-for="Vendor.VendorName" class="text-danger"></span>
                        </div>
                        <div class="form-group mt-2">
                            <label asp-for="VendorSku" class="control-label"></label>
                            <input asp-for="VendorSku" class="form-control" />
                            <span asp-validation-for="VendorSku" class="text-danger"></span>
                        </div>
                        <div class="form-group mt-2">
                            <label asp-for="Cost" class="control-label"></label>
                            <input asp-for="Cost" class="form-control" type="number" min="0.0000" placeholder="0.0000" step="0.0001"/>
                            <span asp-validation-for="Cost" class="text-danger"></span>
                        </div>
                        <div class="form-group mt-2">
                            <label asp-for="MOQ" class="control-label"></label>
                            <input asp-for="MOQ" class="form-control" type="number" value="1" min="1" placeholder="0" />
                            <span asp-validation-for="MOQ" class="text-danger"></span>
                        </div>
                        <div class="form-group mt-2">
                            <label asp-for="OrderMultiples" class="control-label"></label>
                            <input asp-for="OrderMultiples" class="form-control" type="number" min="1" placeholder="0" />
                            <span asp-validation-for="OrderMultiples" class="text-danger"></span>
                        </div>
                        <div class="form-group mt-2">
                            <label asp-for="LeadTime" class="control-label"></label>
                            <input asp-for="LeadTime" class="form-control" type="number" min="1" placeholder="0" />
                            <span asp-validation-for="LeadTime" class="text-danger"></span>
                        </div>
                        <div class="form-group mt-2">
                            <label class="control-label"> Select a Unit of Measure</label>
                            @Html.DropDownListFor(model => model.UnitofMeasure, ViewBag.UnitofMeasureList as SelectList, "Select an option", new { id = "selector-vid", @class = "select2 form-control select2-multiple wizard-require", data_toggle = "select2" })
                            @Html.ValidationMessageFor(model => model.UnitofMeasure, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group mt-2">
                            <label class="control-label"> Select a Term</label>
                            @Html.DropDownListFor(model => model.Term, ViewBag.TermsList as SelectList, "Select an option", new { id = "selector-vid", @class = "select2 form-control select2-multiple wizard-require", data_toggle = "select2" })
                            @Html.ValidationMessageFor(model => model.Term, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group col-md-12">
                            <label asp-for="Notes">Notes</label>
                            <textarea asp-for="Notes" class="form-control" type="text" rows="5"> </textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>    
                        </div>
                        <div class="form-group form-check">
                            <label class="form-check-label">
                                <input class="form-check-input" asp-for="isPrimaryVendor" />
                                <label asp-for="isPrimaryVendor" class="control-label"></label>
                            </label>
                        </div>
                        <div class="form-group form-check">
                            <label class="form-check-label">
                                <input class="form-check-input" asp-for="IsActive" />
                                <label asp-for="IsActive" class="control-label"></label>
                            </label>
                        </div>
                        <div class="form-group form-check">
                            <label class="form-check-label">
                                <input class="form-check-input" asp-for="IsRawMaterial" />
                                <label asp-for="IsRawMaterial" class="control-label"></label>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}


