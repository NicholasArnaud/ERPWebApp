@model ERPWebApp.Models.Inventory.Product

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Product</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Sku)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Sku)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        @if (Model.AlternateProduct is not null)
        {
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.AlternateProductId)
            </dt>
            <dd class="col-sm-10">
                <a href="/Products/Details/@Model.AlternateProduct.ProductId">@Model.AlternateProduct.Sku</a>
            </dd>
        }
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.FulfillmentCost)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.FulfillmentCost)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Cost)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Cost)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.LaborCost)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.LaborCost)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.AltItemNumber)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.AltItemNumber)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.OnOrder)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.OnOrder)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.WeightAmount)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.WeightAmount)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Length)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Length)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Width)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Width)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Height)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Height)
        </dd>
        <dt hidden class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsEmbroidery)
        </dt>
        <dd hidden class="col-sm-10">
            @Html.DisplayFor(model => model.IsEmbroidery)
        </dd>
        <dt hidden class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsEngraving)
        </dt>
        <dd hidden class="col-sm-10">
            @Html.DisplayFor(model => model.IsEngraving)
        </dd>
        <dt hidden class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsMetal)
        </dt>
        <dd hidden class="col-sm-10">
            @Html.DisplayFor(model => model.IsMetal)
        </dd>
        <dt hidden class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsUv)
        </dt>
        <dd hidden class="col-sm-10">
            @Html.DisplayFor(model => model.IsUv)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.IsActive)
        </dd>
        @if (User.IsInRole(RoleList.Administrator) || User.IsInRole(RoleList.ExternalViewer))
        {
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.IsExternalProduct)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.IsExternalProduct)
            </dd>
        }
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.WeightAmount)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.WeightAmount)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.WeightUnit)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.WeightUnit)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ShippingWeightAmount)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ShippingWeightAmount)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ShippingWeightUnit)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ShippingWeightUnit)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsShippingContainer)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.IsShippingContainer)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ExpectedShipmentCost)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ExpectedShipmentCost)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ShippingLength)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ShippingLength)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ShippingWidth)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ShippingWidth)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ShippingHeight)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ShippingHeight)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ModifyByUser)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ModifyByUser)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ModifyDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ModifyDate)
        </dd>
        @if (!User.IsInRole(RoleList.ExternalUser))
        {
            <dt class="col-sm-2">
                Departments
            </dt>
            <dd class="col-sm-10">
                @foreach (var dept in Model.Departments)
                {
                    @dept.DepartmentName
                    <div></div>
                }
            </dd>
        }
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ProductTags)
        </dt>
        <dd class="col-sm-10">
            @if (Model.ProductTags != null && Model.ProductTags.Any())
            {
                @string.Join(", ", Model.ProductTags.Select(x=>x.Tag.Description).ToArray())
            }
            else
            {
                <span>No tags available</span>
            }
        </dd>
    </dl>
    <div class="row mb-2">
        @if (Model.ProductImages.Any())
        {
            <div id="productImagesCarousel" class="carousel slide" data-ride="carousel" data-interval="2000"
                style="width:192px;">
                <div class="carousel-inner">
                    @foreach (var image in Model.ProductImages)
                    {
                        <div class="carousel-item @(image == Model.ProductImages.First() ? "active" : "")">
                            <img src="@image.FileUrl" alt="@image.Files.FileName">
                        </div>
                    }
                </div>
                <a class="carousel-control-prev" href="#productImagesCarousel" role="button" data-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="sr-only">Previous</span>
                </a>
                <a class="carousel-control-next" href="#productImagesCarousel" role="button" data-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="sr-only">Next</span>
                </a>
            </div>
        }
    </div>
</div>
<!--change buttons to coordinate to a post action where  values are changed based on inputs-->
@if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.InventoryManager) ||
this.User.IsInRole(RoleList.ShippingManager))
{
    <div class="row">
    <form asp-action="Delete">
        <input type="hidden" asp-for="ProductId" />
        <input style="text-align:left" type="submit" value="Delete" class="btn btn-danger" />
        <span>|</span>
        <a asp-action="Index">Back to List</a>
    </form>
</div>
}
