        $('#addTag').click(() => {
            var tag_data = $('#productTag').select2('data');
            var color = $('.TagColor').val();
            var oddTags = $('#productTags_hidden').data('oldtags') || [];
            var json = $('#productTags_hidden').val() ? JSON.parse($('#productTags_hidden').val()) : [];
            if (tag_data != undefined && tag_data.length > 0 && tag_data[0].text != "") {

                if (!isNaN(tag_data[0].id)) color = $('#productTag').find(':selected').data('color');
                var tagId = isNaN(tag_data[0].id) ? 0 : parseInt(tag_data[0].id);
                var tag = {
                    TagId: tagId,
                    Description: tag_data[0].text,
                    Color: color
                };

                if (oddTags.findIndex(x => x.Description.toUpperCase() == tag.Description.toUpperCase()) > -1
                    || json.findIndex(x => x.Description.toUpperCase() == tag.Description.toUpperCase()) > -1) {
                    $('#productTag').val(null).trigger('change');
                    return;
                }

                var tagJson = JSON.stringify({ productId: 0, tagId: tag.TagId });

                var tagPill = `<div class="btn-group p-0 m-0" style="width:auto;margin-right: 5px !important" role="group" aria-label="${tag.Description}" title="${tag.Description}">
                                                                                                                    <button type="button" disabled class="btn" style="background-color:${tag.Color}; width:auto">${tag.Description}</button>
                                                                                                                    <button type="button" data-tag='${tagJson}' class="btn btn-danger p-0 removeTag" style="width:40px"><span class="mdi mdi-24px mdi-delete"></span></button>
                                                                                                                  </div>`;
                $(".productTagList").append(tagPill);

                json.push(tag);
                $('#productTags_hidden').val(JSON.stringify(json));
                $('#productTag').val(null).trigger('change');
            }
        });

        $(document).on('click', '.removeTag', function () {
            var tag = $(this).data('tag') || {};
            if (!$.isEmptyObject(tag)) {
                if (tag.productId != 0 && tag.tagId != 0) {
                    $.ajax({
                        url: '/Products/UnAssignProductTag',
                        type: 'POST',
                        data: { productId: tag.productId, tagId: tag.tagId },
                        error: function (data) {
                            console.log(data);
                        }
                    });
                }

                var json = $('#productTags_hidden').val() ? JSON.parse($('#productTags_hidden').val()) : [];
                if (json.length > 0) {
                    json = $.grep(json, function (item) { return item.TagId !== tag.tagId; });
                    $('#productTags_hidden').val(JSON.stringify(json));
                }
            }
            $(this).parent().remove();
        });

        //manage the alternate product related operations
        function InitAlternateProductSelect2() {
            let currentProductId = @Model.ProductId;

            //get the selected item
            let selectedAltProduct = JSON.parse('@Json.Serialize(Model.AlternateProduct is null ? new { } : Model.AlternateProduct)');

            //#region load items to Alternate Production dropdown from the remote data source

            $('#alternate-product').select2({
                ajax: {
                    url: '/Products/GetAllProducts',
                    dataType: 'json',
                    type: "GET",
                    data: function (params) {
                        return { queryString: !params ? null : params.term };
                    },
                    processResults: function (data) {
                        let select2Data = { results: [{ id: '', text: 'Select Alternate product' }] };

                        if (data && Array.isArray(data)) {

                            data.forEach((value, index) => {
                                //restrict form adding the current product id
                                if (value.productId != currentProductId) {
                                    select2Data.results.push({
                                        id: value.productId,
                                        text: value.sku + " | " + value.description,
                                        selected: (selectedAltProduct && selectedAltProduct.productId && selectedAltProduct.productId == value.productId)
                                    });
                                }
                            });

                        }
                        else {

                            if (selectedAltProduct && selectedAltProduct.productId) {
                                select2Data.results.push({
                                    id: selectedAltProduct.productId,
                                    text: selectedAltProduct.sku + " | " + selectedAltProduct.description,
                                    selected: true
                                });
                            }

                        }

                        return select2Data;
                    }
                }
            });

            //make the initial selection
            var newOption = new Option('Select Alternate product', '', false, false);
            if (selectedAltProduct && selectedAltProduct.productId) {
                var newOption = new Option((selectedAltProduct.sku + " | " + selectedAltProduct.description), selectedAltProduct.productId, true, true);
                $('#alternate-product').append(newOption).trigger('change');
            }
            else {
                $('#alternate-product').append(newOption).trigger('change');
                $('#alternate-product').val('').trigger('change');
            }

            //#endregion

        }

        function confirmUncheck(checkbox) {
            var productId = parseInt(document.getElementById("editid").value);
            if (!checkbox.checked) {
                $.ajax({
                    url: '@Url.Action("IsStockExists", "Products")',
                    type: 'GET',
                    data: { productId: productId },
                    success: function (result) {
                        if (result.isAvailable && !confirm("Are you sure you want to disable the product ? There is active stock.")) {
                            checkbox.checked = true;
                        }
                    },
                    error: function () {

                    }
                });
            }
        }

    </script>
