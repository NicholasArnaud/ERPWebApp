                const tbody = document.getElementById('misc-table-body');
                const row = document.createElement('tr');
                const datePickerId = `expectedDate-picker-misc-${Date.now()}`;
                const hiddenDescId = `misc-description-${Date.now()}`;
                row.innerHTML = `
                    <td class="miscproduct-sku">${sku}</td>
                    <td><input type="number" class='form-control miscproduct-cost-product' required></td>
                    <td><input type="number" class='form-control miscproduct-cost-set wizardHelpFloat' required></td>
                    <td><input type="number"  class='form-control miscproduct-quantity wizardHelpInt' min='0' value='0' required onchange='updateMiscTotal()'></td>
                    <td><input type="number" class='form-control miscdiscount-percentage wizardHelpInt' min='0' value='0'  required onchange='updateMiscTotal()'></td>
                    <td><input type="text" class='form-control miscproduct-total-cost wizardHelpFloat' type='decimal' value='0' readonly onchange='updateMiscTotal()'></td>
                    <td>
                        <div id='${datePickerId}' class='input-group date' data-provide='datepicker'>
                            <input type='text' class='form-control expected-date' placeholder='Select date' >
                            <div class='input-group-addon'>
                                <span class='glyphicon glyphicon-th'></span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <i class='mdi mdi-24px mdi-delete item-action-btn' tabindex='0' onclick='removeTableRow()'>
                    </td>
                `;
                tbody.appendChild(row);

                const hiddenField = `<input type="hidden" id="${hiddenDescId}" class="miscproduct-description" value="${description}" />`;
                document.getElementById('misc-table-container').insertAdjacentHTML('beforeend', hiddenField);

                document.getElementById('miscSku').value = '';
                document.getElementById('miscDescription').value = '';

                document.getElementById('misc-table-container').style.display = 'block';
                toggleMiscAddButton();
            }
        }

        function updateMiscTotal() {
            const rows = document.querySelectorAll('#misc-datatable tbody tr');
            rows.forEach(row => {
            const quantity = row.querySelector('.miscproduct-quantity').value || 0;
            const cost = row.querySelector('.miscproduct-cost-set').value || 0;
            const discount = row.querySelector('.miscdiscount-percentage').value || 0;

            const subtotal = quantity * cost;
            const discountedTotal = subtotal - (subtotal * (discount / 100));

            row.querySelector('.miscproduct-total-cost').value = discountedTotal.toFixed(2);
            });
            calTotalCost();
        }

        function saveMiscItems() {
            const miscItems = [];
            const rows = document.querySelectorAll('#misc-datatable tbody tr');
            rows.forEach((row, index) => {
                const descriptionInput = document.querySelectorAll('.miscproduct-description')[index]?.value || "N/A";
                const item = {
                    sku: row.querySelector('.miscproduct-sku')?.innerText || "N/A",
                    description: descriptionInput,
                    productCost: parseFloat(row.querySelector('.miscproduct-cost-product')?.value) || 0,
                    customCost: parseFloat(row.querySelector('.miscproduct-cost-set')?.value) || 0,
                    quantity: parseInt(row.querySelector('.miscproduct-quantity')?.value) || 0,
                    discountPercentage: parseInt(row.querySelector('.miscdiscount-percentage')?.value) || 0,
                    totalCost: parseFloat(row.querySelector('.miscproduct-total-cost')?.value) || 0,
                    expectedDate: row.querySelector('.expected-date')?.value || "N/A"
                };
                miscItems.push(item);
            });

            const miscItemsJson = JSON.stringify(miscItems, null, 2);
                $('#miscItems').val(JSON.stringify(miscItems));
            }

            function submitFunction(){
                saveMiscItems();
                var demo = document.getElementById("purchaseOrderForm");
                demo.submit();
            }
    </script>
}
