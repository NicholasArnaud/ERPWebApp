        function setTotal() {
            const tp1 = parseFloat($('#item-total').val()) || 0;
            const dis1 = parseFloat($('#discount-item').val()) || 0;
            const shp1 = parseFloat($('#shipping-tax').val()) || 0;
            const shp2 = parseFloat($('#shipping-cost').val()) || 0;
            const oth1 = parseFloat($('#other-cost').val()) || 0;

            const discountedTotal = tp1 - (tp1 * dis1 / 100);
            const grandTotal = (discountedTotal + (discountedTotal * shp1 / 100) + shp2 + oth1);

            $('#grand-total').val(grandTotal.toFixed(4));
