        function calTotalCost() {
            $('#productskus').val('');
            $('#productaverages').val('');
            $('#productcosts').val('');
            $('#productquantity').val('');
            $('#discountPercentage').val('');
            $('#totalCost').val('');

            const qtys = document.getElementsByClassName('product-quantity');
            const productDiscounts = document.getElementsByClassName('discount-percentage');
            const productnames = document.getElementsByClassName('product-name');
            const customCosts = document.getElementsByClassName('product-cost-set');
            const productCosts = document.getElementsByClassName('product-cost-product');
            const netTotals = document.getElementsByClassName('product-total-cost');

            let productTotal = 0.0000;
            let miscTotal = 0.0000;

            // Calculate the total for regular products
            for (let i = 0; i < qtys.length; i++) {
                if (qtys[i].value >= 0) {
                    let sbTotal = (customCosts[i].value >= 0) ?
                        parseFloat(qtys[i].value * customCosts[i].value) :
                        parseFloat(qtys[i].value * productCosts[i].value);

                    customCosts[i].value = customCosts[i].value || productCosts[i].value;
                    const discount = sbTotal * (productDiscounts[i].value / 100);
                    productTotal += (sbTotal - discount);
                }
                $('#productskus').val($('#productskus').val() + ',' + productnames[i].value);
                $('#productaverages').val($('#productaverages').val() + ',' + productCosts[i].value);
                $('#productcosts').val($('#productcosts').val() + ',' + customCosts[i].value);
                $('#productquantity').val($('#productquantity').val() + ',' + qtys[i].value);
                $('#discountPercentage').val($('#discountPercentage').val() + ',' + productDiscounts[i].value);
                $('#totalCost').val($('#totalCost').val() + ',' + netTotals[i].value);
            }

            // Calculate the total for misc items
            const miscRows = document.querySelectorAll('#misc-datatable tbody tr');
            miscRows.forEach(row => {
                const miscTotalCost = parseFloat(row.querySelector('.miscproduct-total-cost')?.value) || 0;
                miscTotal += miscTotalCost;
            });

            // Set the combined item total
            const combinedTotal = productTotal + miscTotal;
            $('#item-total').val(combinedTotal.toFixed(4));

            setTotal();
        }
        function getTotalCost() {
            const els = document.getElementsByClassName('product-quantity')
            const pcostside = document.getElementsByClassName('product-cost-set')
            const pcosttotals = document.getElementsByClassName('product-total-cost')
            const productDiscounts = document.getElementsByClassName('discount-percentage')

            for (let i = 0; i < els.length; i++) {
                var subTotal = (els[i].value * pcostside[i].value);
                var discount = subTotal * (productDiscounts[i].value / 100);
                pcosttotals[i].value = (subTotal - discount).toFixed(4);
            }

            calTotalCost()
            setTotal()
        }
