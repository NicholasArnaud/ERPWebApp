        function initializeSelect2(batchData) {
            $('#search-batch-select').select2({
                placeholder: 'Search...',
                dropdownParent: $('#addProductsFromBatchModalContainer'),
                data: batchData,
                matcher: function(params, data) {
                    if ($.trim(params.term) === '') {
                        return data;
                    }
                    if (typeof data.text === 'undefined') {
                        return null;
                    }
                    if (data.text.toLowerCase().indexOf(params.term.toLowerCase()) > -1) {
                        return data;
                    }
                    return null;
                }
            });
        }

