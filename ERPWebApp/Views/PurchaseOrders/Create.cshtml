@model ERPWebApp.Models.PurchaseOrders.PurchaseOrderViewModel
@namespace ERPWebApp.Models.PurchaseOrders
@using Newtonsoft.Json
@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<head>
    <title>Loop through List</title>
    <script type="text/javascript">
        const batchItems=[];

        function quantityOnchange(quantity){

        }

        function toggleMiscAddButton() {
            const sku = document.getElementById('miscSku').value.trim();
            const description = document.getElementById('miscDescription').value.trim();
            const addButton = document.getElementById('miscAddButton');
            addButton.disabled = !(sku && description);
        }

        function reRenderMiskItems(item, productCost, customCost,  quantity, discount, totalCost,expectedDate) {

             const sku = item;
             const description = item;
                const tbody = document.getElementById('misc-table-body');
                const row = document.createElement('tr');
                const datePickerId = `expectedDate-picker-misc-${Date.now()}`;
                const hiddenDescId = `misc-description-${Date.now()}`;
                row.innerHTML = `
                    <td class="miscproduct-sku">${item}</td>
                    <td><input type="number" class='form-control miscproduct-cost-product'value=${productCost} required></td>
                    <td><input type="number" class='form-control miscproduct-cost-set wizardHelpFloat' value=${customCost} required></td>
                    <td><input type="number"  class='form-control miscproduct-quantity wizardHelpInt' min='0' value=${quantity} required onchange='updateMiscTotal()'></td>
                    <td><input type="number" class='form-control miscdiscount-percentage wizardHelpInt' min='0' value=${discount}  required onchange='updateMiscTotal()'></td>
                    <td><input type="text" class='form-control miscproduct-total-cost wizardHelpFloat' type='decimal' value=${totalCost} readonly onchange='updateMiscTotal()'></td>
                    <td>
                        <div id='${datePickerId}' class='input-group date' data-provide='datepicker'>
                            <input type='text' class='form-control expected-date' placeholder='Select date' value=${expectedDate}>
                            <div class='input-group-addon'>
                                <span class='glyphicon glyphicon-th'></span>
                            </div>
                        </div>
                    </td>
                    <td>
                       <i class='mdi mdi-24px mdi-delete item-action-btn' tabindex='0' onclick='removeTableRow()'>
                    </td>
                `;
                tbody.appendChild(row);
                const hiddenField = `<input type="hidden" id="${hiddenDescId}" class="miscproduct-description" value="${description}" />`;
                document.getElementById('misc-table-container').insertAdjacentHTML('beforeend', hiddenField);
                document.getElementById('misc-table-container').style.display = 'block';
                toggleMiscAddButton();
        }
    </script>
</head>


<script type="text/javascript">


</script>


<style>

    @Html.Raw("@") media only screen and (max-width: 1150px), (min-device-width: 1158px) and (max-device-width: 1164px) {
        /* Force table to not be like tables anymore */
        table, thead, tbody, th, td, tr

    {
        display: block;
    }
    /* Hide table headers (but not display: none;, for accessibility) */
    .add-product thead tr {
        position: absolute;
        top: -9999px;
        left: -9999px;
    }

    .add-product tr {
        border: 1px solid #ccc;
    }

    .add-product td {
        /* Behave  like a "row" */
        border: none;
        border-bottom: 1px solid #eee;
        position: relative;
        padding-left: 50%;
    }

        .add-product td:before {
            /* Now like a table header */
            position: absolute;
            /* Top/left values mimic padding */
            top: 6px;
            left: 6px;
            width: 45%;
            padding-right: 10px;
            white-space: nowrap;
        }
    /*
                Label the data
                */
    td:nth-of-type(1):before {
        content: "Product";
    }

    td:nth-of-type(2):before {
        content: "Product Cost";
    }

    td:nth-of-type(3):before {
        content: "Custom Cost";
    }

    td:nth-of-type(4):before {
        content: "Quantity";
    }

    td:nth-of-type(5):before {
        content: "Total";
    }

    td:nth-of-type(6):before {
        content: "Action";
    }

    }

    .line-title {
        width: 100%;
        border-bottom: 1px solid #000;
        line-height: 0.1em;
        margin: 10px 0 20px;
        border-bottom-color: #ffff;
    }

        .line-title span {
            background: #37404a;
            padding: 0 10px;
        }

    kbd {
        display: inline-block;
        border: 1px solid #ccc;
        border-radius: 4px;
        padding: 0.1em 0.5em;
        margin: 0 0.2em;
        box-shadow: 0 1px 0px rgba(0, 0, 0, 0.2), 0 0 0 2px #fff inset;
        background-color: #f7f7f7;
        font-size: 1em;
    }
</style>

