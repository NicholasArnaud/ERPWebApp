        $('#other-cost').keydown(function(event) {
            if (event.key === "Tab") {
                event.preventDefault();
                $('#vendor-ref-number').focus();
            }
        });
        document.addEventListener('keydown', function(event) {
            if (event.key === "Escape") {
                event.preventDefault();
                if ($('#myModalWarn').hasClass('show')) { $('#myModalCloseBtn').trigger('click');}
                if ($('#myModalHelp').hasClass('show')) {$("#myModalHelpCloseBtn").trigger('click'); }
            }
            if (event.ctrlKey) {
                event.preventDefault();
                if (event.key === "k") {
                    $("#myModalHelp").modal("show");
                }
                if (event.key === "s") {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                    $("#vendor-ref-number").focus();
                }
                if (event.key === "l") {
                    $('#backtolistbtn').trigger('click');
                }
                if (event.key === "c") {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                    $("#discount-item").focus();
                }
                if (event.key === "p") {
                    closeAllSelect();
                    $("#selector-product").select2().val(null).trigger('change');
                    $("#selector-product").select2("open");
                    window.scrollTo(0, document.body.scrollHeight);
                }
                if (event.key === "v") {
                    closeAllSelect()
                    $("#selector-vendor").select2("open");
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                }
                const table = document.getElementById('product-datatable');
                const rows = table.getElementsByTagName('tr');
                const currentCell = document.activeElement.closest('td');
                if (event.key === 'f') {
                    navigateToCell(rows[1].cells[2]);
                    window.scrollTo(0, document.body.scrollHeight);
                }
                if (currentCell) {
                    const currentRowIndex = currentCell.parentElement.rowIndex;
                    const currentCellIndex = currentCell.cellIndex;
                    switch (event.key) {
                        case 'ArrowUp':
                        if (currentRowIndex > 0) {
                            navigateToCell(rows[currentRowIndex - 1].cells[currentCellIndex]);
                        }
                        break;
                        case 'ArrowDown':
                        if (currentRowIndex < rows.length - 1) {
                            navigateToCell(rows[currentRowIndex + 1].cells[currentCellIndex]);
                        }
                        break;
                        case 'ArrowLeft':
                        if (currentCellIndex > 0) {
                            navigateToCell(currentCell.parentElement.cells[currentCellIndex - 1]);
                        }
                        break;
                        case 'ArrowRight':
                        if (currentCellIndex < currentCell.parentElement.cells.length - 1) {
                            navigateToCell(currentCell.parentElement.cells[currentCellIndex + 1]);
                        }
                        break;
                        case 'd':
                        const deleteButton = rows[currentRowIndex].cells[6].querySelector('.item-action-btn');
                        const rowLength = rows.length;
                        if (deleteButton) {
                            deleteButton.click();

                            if (currentRowIndex > 0) {
                                navigateToCell(rows[currentRowIndex - 1].cells[2]);
                            }
                            if (rowLength === 2) {
                                $("#selector-product").select2("open");
                            }
                        }
                        break;
                    };
                }
            }
        });
