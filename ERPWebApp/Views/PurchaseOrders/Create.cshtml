<!-- help -->
<div class="container-fluid text-white">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Purchase Order</a></li>
            <li class="breadcrumb-item active" aria-current="page">New</li>
        </ol>
    </nav>

    <form asp-action="Create" id="purchaseOrderForm" novalidate enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h2 class="card-title">Purchase Order</h2>
                <div>
                    <button type="submit" id="submitbtn" ,tabindex="13" name="submit" class="action-button btn btn-primary"><span class="mdi mdi-18px mdi-content-save">&nbsp;Submit</span></button>
                    <a asp-action="Index">
                        <button type="button" id="backtolistbtn" tabindex="14" class="btn btn-info"><span class="mdi mdi-18px mdi-arrow-top-left-thick">&nbsp;Back to List</span></button>
                    </a>
                    <button type="button" id="helpbtn" tabindex="15" name="help" class="btn btn-primary" style="background-color: #ADD8E6;"><span class="mdi mdi-18px mdi-keyboard"></span></button>

                </div>
            </div>
            <div class="card-body">

                <div class="row">
                    <div class="col-9">
                        <div class="row g-3">
                            <div class="form-group col-md-4">

                                @Html.LabelFor(model => model.PurchaseOrderSingle.PurchaseOrderNumber)
                                <input asp-for="PurchaseOrderSingle.PurchaseOrderNumber" class="form-control" value="@ViewData["PONumber"]" readonly="readonly" />
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.PurchaseOrderNumber, "", new { @class = "text-danger" })

                            </div>

                            <div class="form-group col-md-4">

                                @Html.LabelFor(model => model.PurchaseOrderSingle.ReferenceNumber)
                                @Html.TextBoxFor(model => model.PurchaseOrderSingle.ReferenceNumber, new { @class = "form-control", id = "vendor-ref-number", tabindex = "1" })
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.ReferenceNumber, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group col-md-4">

                                @Html.LabelFor(model => model.PurchaseOrderSingle.OrderDate)
                                <div id="orderDate-picker" class="input-group date" data-provide="orderDate">
                                    @Html.TextBoxFor(model => model.PurchaseOrderSingle.OrderDate, new { @class = "form-control", id = "orderDate", @type = "text", tabindex = "2" })
                                    <div class="wizard-form-error"></div>
                                    <div class="input-group-addon">
                                        <span class="glyphicon glyphicon-th"></span>
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.OrderDate, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group col-md-4">

                                <label class="control-label"> Select a Vendor</label>
                                @Html.DropDownListFor(model => model.PurchaseOrderSingle.VendorId, ViewBag.Vendor as SelectList, "Select an option", new { id = "selector-vendor", @class = "select2 form-control select2-multiple wizard-require", onchange = "OnVendorChanged()", data_toggle = "select2" })
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.VendorId, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group col-md-4">
                                <label for="vendor-contact">Vendor Contact</label>
                                @Html.TextBoxFor(model => model.PurchaseOrderSingle.Vendor.PhoneNumber, new { @class = "form-control", id = "vendor-contact", type = "tel", tabindex = "4" })
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.Vendor.PhoneNumber, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group col-md-4">
                                <label for="vendor-email">Vendor Email</label>
                                @Html.TextBoxFor(model => model.PurchaseOrderSingle.Vendor.BusinessEmail, new { @class = "form-control", id = "vendor-email", type = "email", tabindex = "5" })
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.Vendor.BusinessEmail, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group col-md-4">
                                <label class="control-label">Ship Via</label>
                                @Html.DropDownListFor(model => model.PurchaseOrderSingle.ShippingProviderId, ViewBag.ShippingPro as SelectList, "Select an option", new { id = "selector-ship", @class = "select2 form-control select2-multiple wizard-require", onchange = "OnShippingProvider()", data_toggle = "select2" })
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.ShippingProviderId, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group col-md-4">
                                <label class="control-label">Ship Method</label>
                                @Html.DropDownListFor(model => model.PurchaseOrderSingle.ShippingMethodId, ViewBag.ShippingMeth as SelectList, "Select an option", new { id = "selector-ship-method", @class = "select2 form-control select2-multiple wizard-require", onchange = "OnShippingMethod()", data_toggle = "select2" })
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.ShippingMethodId, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group col-md-4">

                                @Html.LabelFor(model => model.PurchaseOrderSingle.EstimatedDate)
                                <div id="estimatedDate-pickers" class="input-group date" data-provide="estimatedDate">
                                    @Html.TextBoxFor(model => model.PurchaseOrderSingle.EstimatedDate, new { @class = "form-control", id = "estimatedDate", @type = "text", tabindex = "8" })
                                    <div class="wizard-form-error"></div>
                                    <div class="input-group-addon">
                                        <span class="glyphicon glyphicon-th"></span>
                                    </div>
                                </div>
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.EstimatedDate, "", new { @class = "text-danger" })
                            </div>

                            <div class="form-group col-md-12">
                                <label asp-for="PurchaseOrderSingle.Notes">Notes</label>

                                @Html.TextAreaFor(model => model.PurchaseOrderSingle.Notes, new { @class = "form-control", id = "vendor-notes", rows = "5", tabindex = "9" })
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.Notes, "", new { @class = "text-danger" })
                            </div>

                            <div>
                                <label class="mt-2">File Name:</label>
                                <input type="text" id="fileName" name="fileName" class="form-control" placeholder="File Name..." tabindex="10">
                                <label class="mt-2">Submit A File:</label>
                                <input id="upload" name="upload" onchange="filebutton()" class="form-control mb-2" type="file" style="color:white" accept="image/* | application/pdf">
                            </div>
                        </div>
                    </div>
                    <div class="col-3 card mt-0 pt-0">
                        <div class="card-body row pt-0 mt-0">
                            <h5 class="card-title text-center line-title"><span>Cost Breakdown</span></h5>
                            <div class="form-group">
                                <label for="item-total">Total Product Cost</label>
                                @Html.TextBoxFor(model => model.PurchaseOrderSingle.TotalProdutsCost, new { @class = "form-control", id = "item-total", @readonly = "readonly" })
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.TotalProdutsCost, "", new { @class = "text-danger" })
                            </div>
                            <div class="form-group mt-2">
                                <label asp-for="PurchaseOrderSingle.Discount">Discount: (0-100%)</label>
                                @Html.TextBoxFor(model => model.PurchaseOrderSingle.Discount, new { @class = "form-control", id = "discount-item", onchange = "setTotal()", min = "0", max = "100", placeholder = "0" })
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.Discount, "", new { @class = "text-danger", tabindex = "10" })
                            </div>
                            <div class="form-group mt-2">
                                <label asp-for="PurchaseOrderSingle.ShippingCost">Shipping Cost</label>
                                @Html.TextBoxFor(model => model.PurchaseOrderSingle.ShippingCost, new { @class = "form-control", id = "shipping-cost", onchange = "setTotal()", min = "0", max = "100", placeholder = "0.0000", step = "0.001" })
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.ShippingCost, "", new { @class = "text-danger", tabindex = "11" })
                                <div class="wizard-form-error"></div>
                            </div>
                            <div class="form-group mt-2">
                                <label asp-for="PurchaseOrderSingle.ShippingTax">Tax: (0-100%)</label>
                                @Html.TextBoxFor(model => model.PurchaseOrderSingle.ShippingTax, new { @class = "form-control", id = "shipping-tax", onchange = "setTotal()", min = "0", max = "100", placeholder = "0" })
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.ShippingTax, "", new { @class = "text-danger", tabindex = "12" })
                                <div class="wizard-form-error"></div>
                            </div>
                            <div class="form-group mt-2">
                                <label asp-for="PurchaseOrderSingle.OtherCost">Other Cost</label>
                                @Html.TextBoxFor(model => model.PurchaseOrderSingle.OtherCost, new { @class = "form-control", id = "other-cost", onchange = "setTotal()", min = "0", max = "100", placeholder = "0.0000", step = "0.001" })
                                @Html.ValidationMessageFor(model => model.PurchaseOrderSingle.OtherCost, "", new { @class = "text-danger" })
                                <div class="wizard-form-error"></div>
                            </div>
                            <div class="form-group mt-2">
                                <label asp-for="PurchaseOrderSingle.GrandTotal">Grand Total</label>
                                <input asp-for="PurchaseOrderSingle.GrandTotal" id="grand-total" class="form-control" readonly>
                                <span asp-validation-for="PurchaseOrderSingle.GrandTotal" class="text-danger"></span>
                                <div class="wizard-form-error"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h2 class="card-title col-6">Products</h2>
                            <div class="row col-6">
                                <div class="col-md-6">
                                    <select class="select2 form-control select2-multiple wizard-require" data-toggle="select2" data-placeholder="Choose ..." id="selector-product" name="selector-prod">
                                        <option value="">Select a product</option>
                                    </select>
                                </div>
                                <div class="col-6 d-flex justify-content-end gap-2">
                                    <button type="button" id="btn-add-product" class="btn btn-success" onclick="add_fields()">
                                        <span class="mdi mdi-18px mdi-plus">&nbsp;Add Product</span>
                                    </button>
                                    <button type="button" id="btn-add-misc" class="btn btn-primary" onclick="showMiscInputs()">
                                        <span class="mdi mdi-18px mdi-plus">&nbsp;Add Misc Item</span>
                                    </button>
                                    <button type="button" id="btn-add-misc" class="btn btn-primary" onclick="showAddFromBatch()">
                                        <span class="mdi mdi-18px mdi-plus">&nbsp;Add From Batch</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div id="product-content  mt-3">
                                <div class="row g-2">
                                    <div class="add-product table-responsive" id="add-product"></div>
                                    <table class="table table-hover table-dar" id="product-datatable">
                                        <thead>
                                            <tr>
                                                <th scope="col">Product</th>
                                                <th scope="col">Product Cost</th>
                                                <th scope="col">Custom Cost</th>
                                                <th scope="col">Quantity</th>
                                                <th scope="col">Discount (%)</th>
                                                <th scope="col">Total</th>
                                                <th scope="col">Expected Delivery Date</th>
                                                <th scope="col">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody id="table-body">
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="card-body">
                            <div id="misc-inputs" class="mt-3" style="display: none;">
                                <h3>Add Misc Item</h3>
                                <div class="row">
                                    <div class="col-md-4">
                                        <input type="text" class="form-control" id="miscSku" placeholder="Enter SKU" required oninput="toggleMiscAddButton()">
                                    </div>
                                    <div class="col-md-4">
                                        <input type="text" class="form-control" id="miscDescription" placeholder="Enter Description" required oninput="toggleMiscAddButton()">
                                    </div>
                                    <div class="col-md-4">
                                        <button type="button" id="miscAddButton" class="btn btn-success" onclick="addMiscItem()" disabled>Add</button>
                                    </div>
                                </div>
                            </div>

                            <div id="misc-table-container" class="mt-4" style="display: none;">
                                <h2 class="card-title">Misc. Items</h2>
                                <table class="table table-hover table-dar" id="misc-datatable">
                                    <thead>
                                        <tr>
                                            <th scope="col">Product</th>
                                            <th scope="col">Product Cost</th>
                                            <th scope="col">Custom Cost</th>
                                            <th scope="col">Quantity</th>
                                            <th scope="col">Discount(%)</th>
                                            <th scope="col">Total</th>
                                            <th scope="col">Expected Delivery Date</th>
                                            <th scope="col">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody id="misc-table-body"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="miskItemsList">
                    @if (Model != null && Model?.MiscProducts != null && Model?.MiscProducts?.Count > 0)
                    {
                        @foreach (var misk in Model.MiscProducts)
                        {
                            <script>
                                reRenderMiskItems("@misk.Sku","@misk.ProductCost","@misk.CustomCost", "@misk.Quantity", "@misk.DiscountPercentage","@misk.TotalCost", "@misk.ExpectedDate");
                            </script>
                        }
                    }
                </div>

                <input hidden name="idvendor" id="idvendor" />
