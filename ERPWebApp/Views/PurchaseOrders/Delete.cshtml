@model ERPWebApp.Models.PurchaseOrders.PurchaseOrder
@namespace ERPWebApp.Models.PurchaseOrders
@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Product</h4>
    <hr />
    <div class="row"></div>
 </div>
    <!--change buttons to coordinate to a post action where  values are changed based on inputs-->
    @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.InventoryManager) || this.User.IsInRole(RoleList.ShippingManager))
    {
        <div class="row">
    <form asp-action="Delete">
        <input type="hidden" />
        <input style="text-align:left" type="submit" value="Delete" class="btn btn-danger" /> 
        <span>|</span>
        <a asp-action="Index">Back to List</a>
    </form>
    </div>
    }

    @section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    }