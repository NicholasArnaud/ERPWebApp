@model ERPWebApp.Models.PurchaseOrders.PurchaseOrderViewModel
@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    kbd {
    display: inline-block;
    border: 1px solid #ccc;
    border-radius: 4px;
    padding: 0.1em 0.5em;
    margin: 0 0.2em;
    box-shadow: 0 1px 0px rgba(0, 0, 0, 0.2), 0 0 0 2px #fff inset;
    background-color: #f7f7f7;
    font-size: 1em;
    }
}
</style>
<div id="myModalWarn" class="modal fade text-width:80%;" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div style="display: none" class="modal-header modal-colored-header bg-warning" id="modalHeaderWarn">
                <center> <i class="dripicons-wrong h1"></i>&nbsp;&nbsp;Save Data!</center>
            </div>
            <div id="myModalWarnAlertBody" class="Modal-body" style="text-align:center; color: white; font-size: 20px;">
                Message will appear here
            </div>
            <div class="modal-footer">
                &nbsp;
                <button type="button" id="myModalCloseBtn" class="btn btn-secondary" onclick="$('#myModalWarn').modal('hide');">Close</button>
                <button type="button" id="myModalBtn" class="btn btn-secondary">Save</button>
            </div>
        </div>
    </div>
</div>
<!-- help -->
<div id="myModalHelp" class="modal fade text-width:80%;" role="dialog">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header modal-colored-header bg-success" id="modalHeaderWarn">
                <center>
                    <i class="dripicons-wrong h1" style="color: white; font-size: 1em;"></i>&nbsp;&nbsp;
                    <span style="color: white; font-size: 1em;">Keyboard Shortcuts</span>
                </center>
            </div>
            <div id="myModalWarnAlertBody" class="Modal-body" style="text-align:center; color: white; font-size: 1em;">
                <table class="table table-striped" style="margin: 0 auto;">
                    <tr>
                        <td style="text-align: left;padding-bottom:10px;padding-top:10px;"><kbd>Enter</kbd></td>
                        <td style="text-align: left;padding-bottom:10px;padding-top:10px">submit/save data.</td>
                    </tr>
                    <tr>
                        <td style="text-align: left;padding-bottom:10px"><kbd>Esc</kbd></td>
                        <td style="text-align: left;padding-bottom:10px">Close any popups</td>
                    </tr>
                    <tr>
                        <td style="text-align: left;padding-bottom:10px"><kbd>Tab</kbd></td>
                        <td style="text-align: left;padding-bottom:10px">Navigates to next input</td>
                    </tr>
                    <tr>
                        <td style="text-align: left;padding-bottom:10px"><kbd>Ctrl</kbd>+<kbd>k</kbd></td>
                        <td style="text-align: left;padding-bottom:10px">Keyboard shortcuts help</td>
                    </tr>
                    <tr>
                        <td style="text-align: left;padding-bottom:10px"><kbd>Ctrl</kbd>+<kbd>p</kbd></td>
                        <td style="text-align: left;padding-bottom:10px">Navigates to PO first available input</td>
                    </tr>
                    <tr>
                        <td style="text-align: left;padding-bottom:10px"><kbd>Ctrl</kbd>+<kbd>e</kbd></td>
                        <td style="text-align: left;padding-bottom:10px">Navigates to 1st row Edit Product table</td>
                    </tr>
                    <tr>
                        <td style="text-align: left;padding-bottom:10px">
                            <kbd>Ctrl</kbd>+
                            <kbd><span class="mdi mdi-18px mdi-arrow-up-thin" style="color: black !important;"></span></kbd>
                            <kbd><span class="mdi mdi-18px mdi-arrow-down-thin" style="color: black !important;"></span></kbd>
                            <kbd><span class="mdi mdi-18px mdi-arrow-left-thin" style="color: black !important;"></span></kbd>
                            <kbd><span class="mdi mdi-18px mdi-arrow-right-thin" style="color: black !important;"></span></kbd>
                        </td>
                        <td style="text-align: left;padding-bottom:10px">Navigates throughout the edit Product table</td>
                    </tr>
                    <tr>
                        <td style="text-align: left;padding-bottom:10px"><kbd>Ctrl</kbd>+<kbd>l</kbd></td>
                        <td style="text-align: left;padding-bottom:10px">Lock Changes</td>
                    </tr>
                    <tr>
                        <td style="text-align: left;padding-bottom:10px"><kbd>Ctrl</kbd>+<kbd>a</kbd></td>
                        <td style="text-align: left;padding-bottom:10px">Navigates to add products</td>
                    </tr>
                   
                    <tr>
                        <td style="text-align: left;padding-bottom:10px"><kbd>Ctrl</kbd>+<kbd>b</kbd></td>
                        <td style="text-align: left;padding-bottom:10px">Navigates back to PO list</td>
                    </tr>
                   
                    <tr>
                        <td style="text-align: left;padding-bottom:10px"><kbd>Ctrl</kbd>+<kbd>f</kbd></td>
                        <td style="text-align: left;padding-bottom:10px">Navigates to add files</td>
                    </tr>                                  
                </table>
            </div>
            <div class="modal-footer">
                &nbsp;
                <button type="button" id="myModalHelpCloseBtn" class="btn btn-secondary" onclick="$('#myModalHelp').modal('hide');">Close</button>
            </div>
        </div>
    </div>
</div>
<!-- help -->
<div class="card-header d-flex justify-content-between align-items-center">
    <h1>Edit: @Model.PurchaseOrderSingle.PurchaseOrderNumber</h1>
    <div>
        <a asp-action="Index">
            <button type="button" id="btnbacktolist" class="btn btn-info"><span class="mdi mdi-18px mdi-arrow-top-left-thick">Back to List</span></button>
        </a>
        <button type="button" id="helpbtn" tabindex="15" name="help" class="btn btn-primary" style="background-color: #ADD8E6;"><span class="mdi mdi-18px mdi-keyboard"></span></button>
    </div>
</div>
<div class="row"></div>
@if (Model.PurchaseOrderSingle.POStatus != ERPWebApp.Models.PurchaseOrders.Status.Close)
{
    <div class="row">
        <div class="col-12 col-xl-9 col-lg-12 col-md-12">
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="accordion custom-accordion" id="custom-accordion-one">
                    <div class="card mb-0">
                        <div class="card-header" id="heading-Four">
                            <h5 class="m-0">
                                <a class="custom-accordion-title d-block py-1" data-bs-toggle="collapse" href="#collapse-Four" aria-expanded="false" aria-controls="collapse-Four">
                                    Purchase Order<i class="mdi mdi-chevron-right accordion-arrow"></i>
                                </a>
                            </h5>
                        </div>
                        <div id="collapse-Four" class="collapse" aria-labelledby="heading-Four" data-bs-parent="#custom-accordion-one">
                            <div class="card-body">
                                <div class="row mt-1">
                                    <input hidden asp-for="PurchaseOrderSingle.PurchaseOrderId" id="purchaseOrderId" />
                                    <input hidden asp-for="PurchaseOrderSingle.PurchaseOrderNumber" />
                                    <div class="col-md-3">
                                        <label asp-for="PurchaseOrderSingle.Discount">Discount: (0-100%)</label>
                                        @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager))
                                        {
                                            <input  asp-for="PurchaseOrderSingle.Discount" id="discount-item" onchange="setTotal()" type="number" min="0" max="100" placegolder="0" tabindex="1" class="form-control wizard-required" />
                                        }
                                        else
                                        {
                                            <input readonly asp-for="PurchaseOrderSingle.Discount" id="discount-item" onchange="setTotal()" type="number" min="0" max="100"  placegolder="0" class="form-control wizard-required" />
                                        }
                                        <span asp-validation-for="PurchaseOrderSingle.Discount" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-3">
                                        <label asp-for="PurchaseOrderSingle.ShippingCost">Shipping Cost</label>
                                        @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager))
                                        {
                                            <input asp-for="PurchaseOrderSingle.ShippingCost" id="shipping-cost" onchange="setTotal()" type="number" step=".0001" min="0" tabindex="2" placeholder="0.0000" class="form-control wizard-required" />
                                        }
                                        else
                                        {
                                            <input readonly asp-for="PurchaseOrderSingle.ShippingCost" id="shipping-cost" onchange="setTotal()" type="number" step=".0001" min="0" placeholder="0.0000" class="form-control wizard-required" />
                                        }
                                        <span asp-validation-for="PurchaseOrderSingle.ShippingCost" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-3">
                                        <label asp-for="PurchaseOrderSingle.ShippingTax">Tax: (0-100%)</label>
                                        @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager))
                                        {
                                            <input asp-for="PurchaseOrderSingle.ShippingTax" tabindex="3" id="shipping-tax" onchange="setTotal()" type="number" min="0" max="100" step="0.001" class="form-control wizard-required" />
                                        }
                                        else
                                        {
                                            <input readonly asp-for="PurchaseOrderSingle.ShippingTax" id="shipping-tax" onchange="setTotal()" type="number" min="0" max="100" step="0.0001" class="form-control wizard-required" />
                                        }
                                        <span asp-validation-for="PurchaseOrderSingle.ShippingTax" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-3">
                                        <label asp-for="PurchaseOrderSingle.OtherCost">Other Cost</label>
                                        @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager))
                                        {
                                            <input asp-for="PurchaseOrderSingle.OtherCost" tabindex="4" id="other-cost" onchange="setTotal()" type="number" min="0" step="0.001" class="form-control wizard-required" />
                                        }
                                        else
                                        {
                                            <input readonly asp-for="PurchaseOrderSingle.OtherCost" id="other-cost" onchange="setTotal()" type="number" min="0" step="0.001" class="form-control wizard-required" />
                                        }
                                        <span asp-validation-for="PurchaseOrderSingle.OtherCost" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="row mt-1">
                                    <div class="col-md-3">
                                        <label asp-for="PurchaseOrderSingle.ReferenceNumber">Reference Number</label>
                                        @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager))
                                        {
                                            <input asp-for="PurchaseOrderSingle.ReferenceNumber" tabindex="5" id="reference-number" class="form-control" type="text" value="@Model.PurchaseOrderSingle.ReferenceNumber" />
                                        }
                                        else
                                        {
                                            <input readonly asp-for="PurchaseOrderSingle.ReferenceNumber"  id="reference-number" class="form-control" type="text" value="@Model.PurchaseOrderSingle.ReferenceNumber" />
                                        }
                                        <span asp-validation-for="PurchaseOrderSingle.ReferenceNumber" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-3">
                                        @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager))
                                        {
                                            <div>
                                                <label asp-for="PurchaseOrderSingle.EstimatedDate" class="control-label">Estimated Due Date</label>
                                                <div id="date-picker" class="input-group date" data-provide="date-picker">
                                                    <input asp-for="PurchaseOrderSingle.EstimatedDate" tabindex="6" type="text" id="date-picks" class="form-control" />
                                                    <span asp-validation-for="PurchaseOrderSingle.EstimatedDate" class="text-danger"></span>
                                                    <div class="input-group-addon">
                                                        <span class="glyphicon glyphicon-th"></span>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <label asp-for="PurchaseOrderSingle.EstimatedDate" class="control-label">Estimated Due Date</label>
                                            <div id="date-pickers" class="input-group date" data-provide="date-picker">
                                                <input readonly asp-for="PurchaseOrderSingle.EstimatedDate" type="text" id="date-pick" class="form-control wizard-required" />
                                                <span asp-validation-for="PurchaseOrderSingle.EstimatedDate" class="text-danger"></span>
                                            </div>
                                        }
                                        <span asp-validation-for="PurchaseOrderSingle.EstimatedDate" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-3">
                                        @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager))
                                        {
                                            <div>
                                                <label asp-for="PurchaseOrderSingle.ShippingProviderId" class="Shipping Provider">Shipping Provider</label>
                                                <select asp-for="PurchaseOrderSingle.ShippingProviderId" tabindex="7" class="select2 form-control select2-multiple" data-toggle="select2" data-placeholder="Choose ..." id="selector-ship" name="selector-ship" asp-items="@ViewBag.ShippingPro">
                                                    <span asp-validation-for="PurchaseOrderSingle.ShippingProviderId" class="text-danger"></span>
                                                </select>

                                            </div>
                                        }
                                        else
                                        {
                                            <div hidden>
                                                <label asp-for="PurchaseOrderSingle.ShippingProviderId" class="Shipping Provider">Shipping Provider</label>

                                                <select asp-for="PurchaseOrderSingle.ShippingProviderId" class="select2 form-control select2-multiple" data-toggle="select2" data-placeholder="Choose ..." id="selector-ship" name="selector-ship" asp-items="@ViewBag.ShippingPro">
                                                    <span asp-validation-for="PurchaseOrderSingle.ShippingProviderId" class="text-danger"></span>
                                                </select>
                                            </div>
                                            <div>
                                                <label>Shipping Provider</label>
                                                <input readonly value="@Model.PurchaseOrderSingle.ShippingProvider.ShippingProviderName" class="form-control wizard-required" />
                                            </div>
                                        }
                                        <input hidden name="id-shipping-pro" id="id-shipping-pro" value="@Model.PurchaseOrderSingle.ShippingProviderId" />
                                    </div>
                                    <div class="col-md-3">
                                        @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager))
                                        {
                                            <div>
                                                <label asp-for="PurchaseOrderSingle.ShippingMethod" class="Shipping Method">Shipping Method</label>
                                                <select asp-for="PurchaseOrderSingle.ShippingMethod" class="select2 form-control select2-multiple" data-toggle="select2" data-placeholder="Choose ..." id="selector-ship-method" name="selector-ship-method" asp-items="@ViewBag.ShippingMeth">
                                                    <span asp-validation-for="PurchaseOrderSingle.ShippingMethod" class="text-danger"></span>
                                                </select>

                                            </div>
                                        }
                                        else
                                        {
                                            <div hidden>
                                                <label asp-for="PurchaseOrderSingle.ShippingMethod" class="Shipping Method">Shipping Method</label>
                                                <select asp-for="PurchaseOrderSingle.ShippingMethod" class="select2 form-control select2-multiple" data-toggle="select2" data-placeholder="Choose ..." id="selector-ship-method" name="selector-ship-method" asp-items="@ViewBag.ShippingMeth">
                                                    <span asp-validation-for="PurchaseOrderSingle.ShippingMethod" class="text-danger"></span>
                                                </select>

                                            </div>
                                            <div>
                                                <label>Shipping Provider</label>
                                                <input readonly value="@Model.PurchaseOrderSingle.ShippingMethod.ShippingMethodName" class="form-control wizard-required" />
                                            </div>
                                        }
                                        <input hidden name="id-shipping-meth" id="id-shipping-meth" value="@Model.PurchaseOrderSingle.ShippingMethodId" />
                                    </div>
                                </div>
                                <div class="row mt-1">
                                    <div class="col-md-3">
                                        <label class="form-check-label"> <input readonly class="form-check-input" asp-for="PurchaseOrderSingle.IsActive" checked /> @Html.DisplayNameFor(model => model.PurchaseOrderSingle.IsActive) </label>
                                    </div>
                                </div>
                                <div class="row mt-1">
                                    <div class="col-md-12">
                                        <label asp-for="PurchaseOrderSingle.Notes">Notes</label>
                                        @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager))
                                        {
                                            <textarea style="height: 225px;" asp-for="PurchaseOrderSingle.Notes" class="form-control"></textarea>
                                        }
                                        else
                                        {
                                            <textarea style="height: 225px;" readonly asp-for="PurchaseOrderSingle.Notes" class="form-control"></textarea>
                                        }
                                        <span asp-validation-for="PurchaseOrderSingle.Notes" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="row mt-3" style="float:right">
                                    @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager))
                                    {
                                        <div class="col-md-3 mt-2">
                                            <label class="form-check-label">
                                                <input style="float: right;" id="savePO" type="submit" name="submit" class="btn btn-success action-button me-3 mb-1" value="Save" />
                                            </label>
                                        </div>

                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="stop-space" class="card mb-0">
                        <div class="card-header" id="heading-Five">
                            <h5 class="m-0">
                                <a class="custom-accordion-title collapsed d-block py-1" data-bs-toggle="collapse" href="#collapse-Five" aria-expanded="false" aria-controls="collapse-Five">
                                    Edit Products <i class="mdi mdi-chevron-down accordion-arrow"></i>
                                </a>
                            </h5>
                        </div>
                        <div id="collapse-Five" class="collapse show" aria-labelledby="heading-Five" data-bs-parent="#custom-accordion-one">
                            <div class="card-body">
                                <div id="my-products">
                                    @{
                                        await Html.RenderPartialAsync("PartialViewEdit", Model);
                                    }
                                </div>

                                <div id="misc-item-section" class="mt-4">
                                    <div class="card">
                                        <div>
                                            <h4 class="card-title">Miscellaneous Items</h4>
                                        </div>
                                        <div class="card-body">
                                            <div class="table-responsive">
                                                <table class="table table-hover" id="misc-item-datatable">
                                                    <thead>
                                                        <tr>
                                                            <th>SKU</th>
                                                            <th>Description</th>
                                                            <th>Product Cost</th>
                                                            <th>Custom Cost</th>
                                                            <th>Quantity</th>
                                                            <th>Discount (%)</th>
                                                            <th>Total</th>
                                                            <th>Expected Date</th>
                                                            <th>Actions</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="misc-table-body">
                                                        @if (Model.MiscProducts != null && Model.MiscProducts.Any())
                                                        {
                                                            @foreach (var item in Model.MiscProducts)
                                                            {
                                                                <tr data-id="@item.MiscProductId">
                                                                    <td>@item.Sku</td>
                                                                    <td>@item.Description</td>
                                                                    <td><input type="number" class="form-control miscproduct-cost-product" value="@item.ProductCost" onchange="updateMiscTotal()" /></td>
                                                                    <td><input type="number" class="form-control miscproduct-cost-set" value="@item.CustomCost" onchange="updateMiscTotal()" /></td>
                                                                    <td><input type="number" class="form-control miscproduct-quantity" value="@item.Quantity" onchange="updateMiscTotal()" /></td>
                                                                    <td><input type="number" class="form-control miscdiscount-percentage" value="@item.DiscountPercentage" onchange="updateMiscTotal()" /></td>
                                                                    <td><input type="text" class="form-control miscproduct-total-cost" value="@item.TotalCost" readonly /></td>
                                                                    <td><input type="text" class="form-control expected-date" value="@item.ExpectedDate.ToString("yyyy-MM-dd")" data-provide="datepicker" /></td>
                                                                    <td>
                                                                        <button type="button" class="btn btn-danger" onclick="removeMiscTableRow(this, @item.MiscProductId)">Remove</button>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                            @* <button type="button" class="btn btn-success mt-3" onclick="addMiscItem()">Add Misc Item</button> *@
                                            <button type="button" class="btn btn-primary mt-3" id="saveMiscBtn" onclick="saveMiscItems()">Save</button>
                                        </div>
                                    </div>
                                </div>

                                <div class="m-3" style="float:right">
                                    <input type="button"
                                           onclick="lockProductChanges()"
                                           id="lock-changes"
                                           data-bs-toggle="collapse"
                                           href="#collapseSix"
                                           aria-expanded="false"
                                           aria-controls="collapseSix"
                                           value="Lock Changes"
                                           class="btn btn-primary" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div style="display: none;" id="finish-edit" class="card mb-0">
                        <div class="card-header" id="heading-Seven">
                            <h5 class="m-0">
                                <a class="custom-accordion-title collapsed d-block py-1" data-bs-toggle="collapse" href="#collapse-Seven" aria-expanded="false" aria-controls="collapse-Seven">
                                    Finished<i class="mdi mdi-chevron-right accordion-arrow"></i>
                                </a>
                            </h5>
                        </div>
                    </div>
                </div>
                <div class="col-12" style="min-width: 300px;">
                    <div class="accordion custom-accordion" id="custom-accordion-three">
                        <div style="display: none;" id="stock-save" class="card mb-0">
                            <div class="card-header" id="heading-Tree">
                                <h5 class="m-0">
                                    <a class="custom-accordion-title d-block py-1" data-bs-toggle="collapse" href="#collapse-Tree" aria-expanded="true" aria-controls="collapse-Tree">
                                        Stock Locations<i class="mdi mdi-chevron-down accordion-arrow"></i>
                                    </a>
                                </h5>
                            </div>
                            <div id="collapse-Tree" class="collapse show" aria-labelledby="heading-Tree" data-bs-parent="#custom-accordion-three">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="form-group p-1">
                                                <label for="ProductId" class="control-label">Product Sku</label>
                                                <input readonly for="ProductId" id="product-id" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group p-1" style="text-align: left;" id="filter-list">
                                                <label style="text-align: left;" class="control-label">Select a Location</label>
                                                <select style="text-align: left;" class="form-control select2" data-toggle="select2" id="selector" name="selector">
                                                    <option>Any</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group p-1">
                                                <label for="TotalAvailable" class="control-label">Recieved</label>
                                                <input readonly id="product-received" for="TotalAvailable" class="form-control" />
                                            </div>
                                        </div>
                                        <div class="form-group p-2">
                                            <span id="tooltip-next" class="d-inline-block" tabindex="0" data-bs-toggle="tooltip" title="Select A Location">
                                                <input type="button" class="btn btn-secondary" value="Next" disabled id="next-button-decoy" />
                                            </span>
                                            <input type="button" class="btn btn-secondary" value="Next" onclick="saveStock($('#counter-helper').val())" tabindex="0" id="next-product-button" />
                                            <input hidden id="counter-helper" value="0" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div style="float:right">
                    <input style="display: none;" type="submit" name="submit" class="btn btn-success action-button me-3 mb-1 mt-2" id="submit-btn" value="Submit" />
                </div>
            </form>
            @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager) || this.User.IsInRole(RoleList.Developer))
            {
                <form asp-action="AddProduct" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="PurchaseOrderSingle.PurchaseOrderId" />
                    <div class="accordion custom-accordion mt-3" id="custom-accordion-prod">
                        <div class="card mb-0">
                            <div class="card-header" id="heading-Prod-Four">
                                <h5 class="m-0">
                                    <a class="custom-accordion-title d-block py-1" data-bs-toggle="collapse" href="#collapse-Prod-Four" aria-expanded="false" aria-controls="collapse-Prod-Four">
                                        Add Product<i class="mdi mdi-chevron-right accordion-arrow"></i>
                                    </a>
                                </h5>
                            </div>
                            <div id="collapse-Prod-Four" class="collapse" aria-labelledby="heading-Prod-Four" data-bs-parent="#custom-accordion-prod">
                                    <div class="card">
                                        <div class="card-header d-flex justify-content-between align-items-center">
                                            <h4 class="card-title col-6">Products</h4>
                                            <div class="row col-6">
                                                <div class="col-md-9">
                                                    <select class="select2 form-control select2-multiple wizard-require" data-toggle="select2" data-placeholder="Choose ..." id="selector-product" name="selector-prod">
                                                        <option value="">Select a product</option>
                                                    </select>
                                                </div>
                                                <div class="col-3">
                                                    <button type="button" id="btn-add-product" class="btn btn-success float-end" onclick="add_fields()"><span class="mdi mdi-18px mdi-plus">&nbsp;Add Product</span></button>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="card-body">
                                            <div id="product-content  mt-3">
                                                <div class="row g-2">
                                                    <div class="add-product table-responsive" id="add-product"></div>
                                                    <table class="table table-hover table-dar" id="product-datatable">
                                                        <thead>
                                                            <tr>
                                                                <th scope="col">Product</th>
                                                                <th scope="col">Product Cost</th>
                                                                <th scope="col">Custom Cost</th>
                                                                <th scope="col">Quantity</th>
                                                                <th scope="col">Discount (%)</th>
                                                                <th scope="col">Total</th>
                                                                <th scope="col">Actions</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody id="table-body">
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                <div class="row m-3" style="float:right">
                                    <div class="col-3">
                                        <input type="submit" value="Submit" id="btnaddproduct" class="btn btn-success mt-2" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            }
        </div>
        <div id="stock-modal" class="col-12 col-xl-3 col-lg-12 col-md-12">
            <div class="accordion custom-accordion" id="custom-accordion-two">
                <div class="card mb-0">
                    <div class="card-header" id="heading-One">
                        <h5 class="m-0">
                            <a class="custom-accordion-title d-block py-1" data-bs-toggle="collapse" href="#collapse-One" aria-expanded="true" aria-controls="collapse-One"> Stock Locations<i class="mdi mdi-chevron-down accordion-arrow"></i> </a>
                        </h5>
                    </div>
                    <div id="collapse-One" class="collapse show" aria-labelledby="heading-One" data-bs-parent="#custom-accordion-two">
                        <div id="stock-load">
                            @{
                                await Html.RenderPartialAsync("PartialIndex", Model);
                            }
                        </div>
                    </div>
                </div>
            </div>
            @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager) || this.User.IsInRole(RoleList.Developer))
            {
                <div id="stock-initial">
                    <div class="accordion custom-accordion mt-3" id="custom-accordion-three">
                        <div class="card mb-0">
                            <div class="card-header" id="heading-Ten">
                                <h5 class="m-0">
                                    <a class="custom-accordion-title d-block py-1" data-bs-toggle="collapse" href="#collapse-Ten" aria-expanded="true" aria-controls="collapse-Ten">
                                        Add File
                                        <i class="mdi mdi-chevron-down accordion-arrow"></i>
                                    </a>
                                </h5>
                            </div>
                            <div id="collapse-Ten" class="collapse show" aria-labelledby="heading-Ten" data-bs-parent="#custom-accordion-three">
                                <div>
                                    <form asp-action="SaveFile" enctype="multipart/form-data" onsubmit="return setWaitCursor()">
                                        <input hidden id="purOrdid" name="purOrdid" value="@Model.PurchaseOrderSingle.PurchaseOrderId" />
                                        <label class="mt-2">File Name:</label>
                                        <input type="text" id="fileName" name="fileName" class="form-control" placeholder="File Name...">
                                        <label class="mt-2">Submit A File:</label>
                                        <input id="upload" name="upload" onchange="filebutton()" class="form-control mb-2" type="file" style="color:white" accept="image/* | application/pdf">
                                        <button type="submit" id="btnsubmit" style="display: none; float:right" class="btn btn-success m-1">Upload File</button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <div class="card mt-3">
                            <div class="card-header" id="heading-Nine">
                                <h5 class="m-0">
                                    <a class="custom-accordion-title d-block py-1" data-bs-toggle="collapse" href="#collapse-Nine" aria-expanded="true" aria-controls="collapse-Nine">
                                        Remove File <i class="mdi mdi-chevron-down accordion-arrow"></i>
                                    </a>
                                </h5>
                            </div>
                            <div id="collapse-Nine" class="collapse show" aria-labelledby="heading-Nine" data-bs-parent="#custom-accordion-three">
                                <div>
                                    <div class="card-body">
                                        <table class="table dt-responsive webkit-nowrap w-100" id="file-datatable">
                                            <thead>
                                                <tr>
                                                    <th>
                                                        File Name
                                                    </th>
                                                    <th>
                                                        Action
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var items in Model.purchaseOrderFilesMappings)
                                                {
                                                    <tr>
                                                        <td>

                                                            <a target="_blank" href="@items.Files.FileUrl">
                                                                @items.Files.FileName
                                                            </a>
