                                                        <td>
                                                            <div class="form-group p-1">
                                                                <div class="dropdown">
                                                                    <i data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" class="mdi mdi-24px mdi-delete dropdown-toggle"></i>
                                                                    <div class="dropdown-menu">
                                                                        <center>
                                                                            <div class="form-group p-1" style="padding: 20px; color: white">
                                                                                <label>Confirm Delete?</label>
                                                                                <div class="dropdown-divider"></div>
                                                                                <input type="button" value="Cancel" class="btn btn-secondary btnClose" style="margin: 10px" />
                                                                                <a asp-action="DeleteFile" asp-route-id="@items.PurchaseOrderFilesMappingId">
                                                                                    <input type="button" onclick="return setWaitCursor()" value="Delete" class="btn btn-danger" />
                                                                                </a>
                                                                            </div>
                                                                        </center>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <h1 class="m-3">PO Closed!</h1>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/pages/purchase-order-edit.min.js?"></script>
    <script type="text/javascript">
        function closeAllSelect() {
            if ($("#selector-vendor").select2("isOpen")) {
                $("#selector-vendor").select2("close");
            }
            if ($("#selector-product").select2("isOpen")) {
                $("#selector-product").select2("close");
            }
            if ($("#selector-ship").select2("isOpen")) {
                $("#selector-ship").select2("close");
            }
            if ($("#selector-ship-method").select2("isOpen")) {
                $("#selector-ship-method").select2("close");
            }
        }
        $('#btnaddproduct').keypress(function (event) {
            if (event.which === 13) {
                event.preventDefault(); 
                $(this).click(); 
            }
        });

        $('#next-product-button').keypress(function (event) {
            if (event.which === 13) {
                event.preventDefault();
                saveStock($('#counter-helper').val())
                if ($('#submit-btn').is(':visible')) {
                    $('#submit-btn').focus();
                }
            }
        });
        $('#submit-btn').keypress(function (event) {
            if (event.which === 13) {
                event.preventDefault(); 
                $(this).click(); 
            }
        });
        $('#other-cost').keydown(function (event) {
            if (event.key === "Tab") {
                event.preventDefault();
                $('#reference-number').focus();
            }
        });

        $('#fileName').keydown(function (event) {
            if (event.key === "Tab") {
                event.preventDefault();
                $('#upload').click();               
            }
        });
       
        document.addEventListener('keydown', function (event) {

            if (event.key === "Escape") {
                event.preventDefault();
                if ($('#myModalWarn').hasClass('show')) { $('#myModalCloseBtn').trigger('click'); }
                if ($('#myModalHelp').hasClass('show')) { $("#myModalHelpCloseBtn").trigger('click'); }
            }
            if (event.ctrlKey) {
                event.preventDefault();
                if (event.key === "k") {
                    $("#myModalHelp").modal("show");

                }
                if (event.key === 'p') {
                    event.preventDefault();
                    $('#collapse-Four').collapse('show');
                    var $input = $('input[tabindex="1"]');
                    if ($input.length === 0) {
                        $input = $('input[tabindex]').not('[tabindex=""]').first();
                    }
                    $input.focus();
                }
                if (event.key === 'a') {
                    event.preventDefault();
                    $('#collapse-Prod-Four').collapse('show');
                    $("#selector-prod").select2("open");
                    setTimeout(function () {
                        window.scrollTo(0, document.body.scrollHeight);
                    }, 100);
                }
                if (event.key === "l") {
                    

                    setTimeout(function () {
                        $("#selector").select2("open");
                        $('#lock-changes').click();
                    }, 100);
                    setTimeout(function () {
                        window.scrollTo(0, document.body.scrollHeight);
                    }, 100);
                   
                   
                }
                if (event.key === "b") {
                    $('#btnbacktolist').click();
                }
                
                if (event.key === "f") {
                    setTimeout(function () {
                        window.scrollTo(0, document.body.scrollHeight);
                    }, 100);
                    $("#fileName").focus();

                }
               
                const table = document.getElementById('Product-datatable');
                const rows = table.getElementsByTagName('tr');
                const currentCell = document.activeElement.closest('td');
                if (event.key === 'e') {
                    $('#collapse-Five').collapse('show');
                    navigateToCell(rows[1].cells[2]);
                    setTimeout(function () {
                        const windowHeight = window.innerHeight;
                        const middleOfPage = document.body.scrollHeight / 2 - windowHeight / 2;
                        window.scrollTo(0, middleOfPage);
                    }, 100);
                }
                if (currentCell) {
                    const currentRowIndex = currentCell.parentElement.rowIndex;
                    const currentCellIndex = currentCell.cellIndex;

                    switch (event.key) {
                        case 'ArrowUp':
                            if (currentRowIndex > 0) {
                                navigateToCell(rows[currentRowIndex - 1].cells[currentCellIndex]);
                            }
                            break;
                        case 'ArrowDown':
                            if (currentRowIndex < rows.length - 1) {
                                navigateToCell(rows[currentRowIndex + 1].cells[currentCellIndex]);
                            }
                            break;
                        case 'ArrowLeft':
                            if (currentCellIndex > 0) {
                                navigateToCell(currentCell.parentElement.cells[currentCellIndex - 1]);
                            }
                            break;
                        case 'ArrowRight':
                            if (currentCellIndex < currentCell.parentElement.cells.length - 1) {
                                navigateToCell(currentCell.parentElement.cells[currentCellIndex + 1]);
                            }
                            break;
                        case 'd':
                            const deleteButton = rows[currentRowIndex].cells[6].querySelector('.item-action-btn');
                            const rowLength = rows.length;
                            if (deleteButton) {
                                deleteButton.click();

                                if (currentRowIndex > 0) {
                                    navigateToCell(rows[currentRowIndex - 1].cells[2]);
                                }
                                if (rowLength === 2) {

                                    $("#selector-product").select2("open");


                                }

                            }
                            break;

                    }
                }
            }
        });

        function navigateToCell(cell) {
            const input = cell.querySelector('input:not([readonly])');
            if (input) {
                input.focus();
            }
        }
        $("#helpbtn").click(function () {
            $("#myModalHelp").modal("show");
        });
        document.addEventListener('keypress', function (e) {
            if (e.key === 'Enter' && !$(e.target).hasClass('form-check-input') && !$(e.target).is('#next-product-button') && !$(e.target).is('#btnsubmit')) {
                event.preventDefault();
                if ($('#myModalWarn').hasClass('show')) {
                    $('#myModalBtn').trigger('click');
                }
                $('#myModalBtn').show();
                var myDiv = document.getElementById("myModalWarnAlertBody");
                myDiv.innerHTML = "Do you want to Save this purchase order?";
                $('#myModalWarn').modal('show');
                $('#modalHeaderWarn').show();
            }
        });

        $(document).on("click", "#myModalBtn", function () {
            $('#myModalWarn').modal('hide');
            $("#savePO").trigger("click"); // click the submit button
        });

      

        $(document).ready(function () {
            $('#upload').change(function () {
                if (this.files.length > 0) {
                    $('#btnsubmit').focus();
                }
            });
            $(".form-check-input").focus(function () {
                $(this).on("keypress", function (event) {
                    event.preventDefault();
                    // Check if the pressed key is Enter (key code 13)
                    if (event.which === 13) {
                        
                        // Toggle the checked state
                        $(this).prop("checked", !$(this).prop("checked"));
                    }
                });
            });
            let keyboardEvent = false;
            $(document).on('keydown', function () {
                keyboardEvent = true;
            });
            $("#selector-ship-method").on("select2:close", function () {
                if (keyboardEvent) {
                    $("#PurchaseOrderSingle_IsActive").focus();
                }
            });
            $("#date-picks").on("keydown", function (e) {
                if (e.key === "Tab") { // Tab key
                    e.preventDefault();
                    $("#selector-ship").select2("open");
                }
            });
            if (/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)) {
                $('#helpbtn').hide();
            }
            $('.select2').select2();
            // Initialize DataTables
            initializeDataTables();
            $("#id-shipping-meth").val($("#selector-ship-method").val());
            $("#id-shipping-pro").val($("#selector-ship").val());
            $(".btnClose").click(function () {
                $(this).parents(".dropdown").find(".dropdown-toggle").dropdown("toggle");
            });

            //select list on change
            $("#selector").on("select2:select", function (e) {
                $("#tooltip-next").hide();
                $("#next-button-decoy").hide();
                $("#next-product-button").show();
                $("#next-product-button").focus();
                console.log(document.querySelector("#selector option:checked").parentElement.label);
            });
            $(document).ready(function () {
                let keyboardEvent = false;
                $(document).on('keydown', function () {
                    keyboardEvent = true;
                });
                $("#selector-ship").on("select2:close", function () {
                    if (keyboardEvent) {
                        $("#selector-ship-method").select2();
                        $("#selector-ship-method").select2("open");
                    }
                });
                $('#date-picker').datepicker({
                    autoclose: true,
                    format: 'mm/dd/yyyy',
                    singleDatePicker: true
                });
                var dateInput = $('#date-picks');
                if (dateInput.val()) {
                    var dateValue = new Date(dateInput.val());
                    var formattedDate = dateValue.toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: '2-digit',
                        day: '2-digit'
                    });
                    dateInput.val(formattedDate);
                }
            });

            //stops enter working on submit form for accidental early submit
            $("#stop-space").on("keypress", function (event) {
                var keyPressed = event.keyCode || event.which;
                if (keyPressed === 13) {
                    event.preventDefault();
                    return false;
                }
            });

            $("#custom-accordion-prod").on("keypress", function (event) {
                var keyPressed = event.keyCode || event.which;
                if (keyPressed === 13) {
                    event.preventDefault();
                    //getTotalCost();
                    return false;
                }
            });

            $("#selector-prod").on("select2:select", function () {
                add_fields();
            });

            $("#selector-ship").on("change", function (e) {
                GetMethodsByShipPro(+$("#selector-ship").val());
            });

            $('.select2').select2();

            const url = '/PurchaseOrders/GetProductsByVendorId/'
            $.getJSON(url, { id: @ViewData["ProductsVendorId"]}).done(function (response) {
                $('#selector-product').empty()
                let s = ''
                for (let i = 0; i < response.length; i++) {
                    s += '<option value="' + response[i].product.productId + '">' + response[i].product.sku + ' | ' + response[i].vendorSku + ' | ' + response[i].product.description + '</option>'
                }
                $('#selector-product').html(s)
            })
        });

        function setWaitCursor(){
            $("button, a").prop("disabled", true);
            $("input").css({ "background-color": "#f5f5f5", "color": "#999", "pointer-events": "none" });
            $('body').css({"cursor": "wait" });
            $('.wrapper').css({ "pointer-events": "none"});
        }

        function OnVendorChanged() {
                const url = '../PurchaseOrders/GetProductsByVendorId/'
            $.getJSON(url, { id: @ViewData["ProductsVendorId"] }).done(function (response) {
                    $('#selector-product').empty()
                    let s = ''
                    for (let i = 0; i < response.length; i++) {
                        s += '<option value="' + response[i].product.productId + '">' + response[i].product.sku + ' | ' + response[i].vendorSku + ' | ' + response[i].product.description + '</option>'
                    }
                    $('#selector-product').html(s)
                })
        }

        function add_fields() {
            const table = document.getElementById('product-datatable').getElementsByTagName('tbody')[0];
            const rowIndex = table.rows.length;

            const row = table.insertRow(table.length);
            const cell1 = row.insertCell(0);
            const cell2 = row.insertCell(1);
            const cell3 = row.insertCell(2);
            const cell4 = row.insertCell(3);
            const cell5 = row.insertCell(4);
            const cell6 = row.insertCell(5);
            const cell7 = row.insertCell(6);
            const url = '/PurchaseOrders/GetPVMDetails';

            $.getJSON(url, { productId: parseInt($('#selector-product option:selected').val()), vendorId: parseInt('@ViewData["ProductsVendorId"]') }, function (response) {

                cell1.innerHTML = "<input name='ProductPurchaseOrders[" + rowIndex + "].ProductVendorMappingId' type='hidden' value='" + response.productVendorMappingId + "' />" +
                    "<input readonly class='form-control' type='text' value='" + $('#selector-product option:selected').text().split('|')[0] + "' />";
                cell2.innerHTML = "<input readonly class='form-control product-cost-set' type='number' value='" + response.cost + "' />";
                cell3.innerHTML = "<input name='ProductPurchaseOrders[" + rowIndex + "].CustomCost' type='number' class='form-control' step='0.0001' value='" + response.cost + "' onchange='getTotalCost()' />";
                cell4.innerHTML = "<input name='ProductPurchaseOrders[" + rowIndex + "].TotalOrdered' type='number' class='form-control product-quantity' value='0' onchange='getTotalCost()' />";
                cell5.innerHTML = "<input name='ProductPurchaseOrders[" + rowIndex + "].DiscountPercentage' type='number' class='form-control product-discount-percentage' step='0.01'  value='0' onchange='getTotalCost()' />";
                cell6.innerHTML = "<input readonly class='form-control product-total-cost' name='ProductPurchaseOrders[" + rowIndex + "].TotalProductCost' type='number' value='0' />";
                cell7.innerHTML = "<i class='mdi mdi-24px mdi-delete item-action-btn' tabindex='0' onclick='removeTableRow()'>";

                const inputs = cell3.getElementsByTagName('input');
                if (inputs.length > 0) {
                    inputs[0].focus();
                }
            });
        }

        function getTotalCost() {
            const els = document.getElementsByClassName('product-quantity')
            const pcostside = document.getElementsByClassName('product-cost-set')
            const pcosttotals = document.getElementsByClassName('product-total-cost')
            const productDiscounts = document.getElementsByClassName('product-discount-percentage')

            for (let i = 0; i < els.length; i++) {
                var subTotal = (els[i].value * pcostside[i].value);
                var discount = subTotal * (productDiscounts[i].value / 100);
                pcosttotals[i].value = (subTotal - discount).toFixed(4);
            }
        }

        $(document).on('click', '.item-action-btn', function (e) {
            e.preventDefault()
            const tr = $(this).closest('tr')
            console.log(tr.children('td:first').attr('id'))
            tr.remove()
        });

         function updateMiscTotal() {
        const rows = document.querySelectorAll('#misc-item-datatable tbody tr');
        rows.forEach(row => {
            const quantity = row.querySelector('.miscproduct-quantity').value || 0;
            const cost = row.querySelector('.miscproduct-cost-set').value || 0;
            const discount = row.querySelector('.miscdiscount-percentage').value || 0;
            const subtotal = quantity * cost;
            const discountedTotal = subtotal - (subtotal * (discount / 100));
            row.querySelector('.miscproduct-total-cost').value = discountedTotal.toFixed(2);
        });
    }

    function addMiscItem() {
        const tbody = document.getElementById('misc-table-body');
        const row = tbody.insertRow();
        row.innerHTML = `
            <td><input type="text" class="form-control" placeholder="SKU"></td>
            <td><input type="text" class="form-control" placeholder="Description"></td>
            <td><input type="number" class="form-control miscproduct-cost-product" onchange="updateMiscTotal()"></td>
            <td><input type="number" class="form-control miscproduct-cost-set" onchange="updateMiscTotal()"></td>
            <td><input type="number" class="form-control miscproduct-quantity" onchange="updateMiscTotal()"></td>
            <td><input type="number" class="form-control miscdiscount-percentage" onchange="updateMiscTotal()"></td>
            <td><input type="text" class="form-control miscproduct-total-cost" readonly></td>
            <td><input type="text" class="form-control expected-date" data-provide="datepicker"></td>
            <td><button type="button" class="btn btn-danger" onclick="removeMiscTableRow(this)">Remove</button></td>
        `;
        document.getElementById('addMiscBtn').style.display = 'none';
        document.getElementById('saveMiscBtn').style.display = 'inline-block';
    }

        function removeMiscTableRow(button, recordId) {
            if (confirm("Are you sure you want to remove this record?")) {
            $.ajax({
                url: '/PurchaseOrders/DeleteMiscRecord',
                type: 'POST',
                data: { id: recordId },
                success: function(response) {
                    if (response.success) {
                        $(button).closest('tr').remove();
                        alert("Record deleted successfully.");
                    } else {
                        alert("Failed to delete record: " + response.message);
                    }
                },
                error: function() {
                    alert("An error occurred while deleting the record.");
                }
            });
        }
    }
        function saveMiscItems() {
            const purchaseOrderId = document.getElementById('purchaseOrderId').value;
            const rows = document.querySelectorAll('#misc-table-body tr');
            const miscItems = [];
            rows.forEach(row => {
                const item = {
                        MiscProductId: row.getAttribute('data-id') || 0,
                        PurchaseOrderId: purchaseOrderId,
                        Sku: row.cells[0]?.querySelector('input')?.value || row.cells[0]?.textContent?.trim() || '',
                        Description: row.cells[1]?.querySelector('input')?.value || row.cells[1]?.textContent?.trim() || '',
                        ProductCost: parseFloat(row.cells[2]?.querySelector('input')?.value) || 0,
                        CustomCost: parseFloat(row.cells[3]?.querySelector('input')?.value) || 0,
                        Quantity: parseInt(row.cells[4]?.querySelector('input')?.value) || 0,
                        DiscountPercentage: parseFloat(row.cells[5]?.querySelector('input')?.value) || 0,
                        TotalCost: parseFloat(row.cells[6]?.querySelector('input')?.value) || 0,
                        ExpectedDate: row.cells[7]?.querySelector('input')?.value || null
                };
                miscItems.push(item);
            });

            var data = JSON.stringify(miscItems);

            $.ajax({
                url: '/PurchaseOrders/UpdateMiscProducts',
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded',
                data: { MiscProducts: data }, // Send as a form field
                success: function(response) {
                    alert('Misc items updated successfully!');
                },
                error: function() {
                    alert('Failed to update misc items.');
                }
            });
    }
       
    </script>
 }
