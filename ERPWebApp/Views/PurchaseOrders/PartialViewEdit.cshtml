@model ERPWebApp.Models.PurchaseOrders.PurchaseOrderViewModel
<div class="card-body">
    <div class="row">
        <div class="table-responsive">
        <table class="table table-striped table-bordered dt-responsive" style="width:100%" id="Product-datatable">
            <thead>
                <tr>
                    <th hidden>
                        @Html.DisplayNameFor(model => model.ProductPurchaseOrders.First().ProductPurchaseOrderId)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ProductPurchaseOrders.First().ProductVendorMapping.Product.Sku)
                    </th>
                    <th style="width: 4em; white-space: nowrap;">
                        @Html.DisplayNameFor(model => model.ProductPurchaseOrders.First().CustomCost)
                    
                    <th>
                        @Html.DisplayNameFor(model => model.ProductPurchaseOrders.First().TotalOrdered)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ProductPurchaseOrders.First().TotalRecieved)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ProductPurchaseOrders.First().DiscountPercentage)
                    </th>
                    <th style="width: 7em; white-space: nowrap;">
                        Total Cost
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ProductPurchaseOrders.First().ExpectedDate)
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.ProductPurchaseOrders)
                {
                    <tr>
                        <td hidden>
                            <div class="purchase-order-id">  @Html.DisplayFor(modelItem => item.ProductPurchaseOrderId)</div>
                        </td>
                        <td>
                            <div class="product-sku">
                                <a target="_blank" href="/Products/Details/@item.ProductVendorMapping.Product.ProductId">@Html.DisplayFor(modelItem => item.ProductVendorMapping.Product.Sku)</a>
                             </div>
                        </td>
                        <td>
                            @if(this.User.IsInRole(RoleList.FinancialManager)||this.User.IsInRole(RoleList.Administrator)){
                                <input onchange="getTotalCost()" for="@item.CustomCost" value="@String.Format("{0:0.0000}",item.CustomCost)" class="form-control custom-cost">
                            }
                            else
                            {
                                <input onchange="getTotalCost()" readonly for="@item.CustomCost" value="@String.Format("{0:0.0000}",item.CustomCost)" class="form-control custom-cost">
                            }
                            <span validation-for="@item.CustomCost" class="text-danger"></span>
                        </td>
                        
                        <td>
                            @if (this.User.IsInRole(RoleList.FinancialManager) || this.User.IsInRole(RoleList.Administrator)||this.User.IsInRole(RoleList.ShippingManager))
                            {
                                <input onchange="getTotalCost()" for="@item.TotalOrdered" type="number" min="0" value="@Html.DisplayFor(modelItem =>item.TotalOrdered)" class="form-control total-ordered">
                            }
                            else
                            {
                                 <input readonly onchange="getTotalCost()" for="@item.TotalOrdered" type="number" min="0" value="@Html.DisplayFor(modelItem =>item.TotalOrdered)" class="form-control total-ordered">

                            }
                            <span validation-for="@item.TotalOrdered" class="text-danger"></span>
                        </td>

                        <td>
                            @if (this.User.IsInRole(RoleList.ShippingManager) || this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.ShippingBasic))
                            {
                                <input for="@item.TotalRecieved" type="number" min="@item.TotalRecieved" value="@Html.DisplayFor(modelItem =>item.TotalRecieved)" class="form-control total-recieved">
                            }
                            else
                            {
                                <input readonly for="@item.TotalRecieved" type="number" min="@item.TotalRecieved" value="@Html.DisplayFor(modelItem =>item.TotalRecieved)" class="form-control total-recieved">                                
                            }
                            <input hidden for="@item.TotalRecieved" value="@Html.DisplayFor(modelItem =>item.TotalRecieved)" class="form-control total-recbefore">
                            <span validation-for="@item.TotalRecieved" class="text-danger"></span>
                        </td>
                        <td>
                            <input readonly onchange="getTotalCost()" for="@item.DiscountPercentage" value="@Html.DisplayFor(modelItem =>item.DiscountPercentage)" class="form-control discount-percentage">
                            <span validation-for="@item.CustomCost" class="text-danger"></span>
                        </td>
                        <td>

                            <input readonly type="number" value="@String.Format("{0:0.0000}",item.TotalProductCost)" class="form-control wizard-required totalcosteditmain" />
                             <span></span>
                        </td>
                        <td>
                            <input readonly for="@item.ExpectedDate" value="@item.ExpectedDate.ToString("MM/dd/yyyy"))" class="form-control">
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
</div>