@model ERPWebApp.Models.QCStationLocation

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Create</h1>

<h4>Station Locations</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group p-1">
                <label asp-for="QCStationLocationName" class="control-label"></label>
                <input asp-for="QCStationLocationName" class="form-control" />
                <span asp-validation-for="QCStationLocationName" class="text-danger"></span>
            </div>
            <div class="form-group p-1">
                <label asp-for="DepartmentId" class="control-label"></label>
                <select asp-for="DepartmentId" class="form-control select2" data-toggle="select2" asp-items="ViewBag.Department"></select>
                
            </div>
            <div class="form-group form-check">
                <label class="form-check-label p-1">
                    <input class="form-check-input" asp-for="IsActive" /> @Html.DisplayNameFor(model => model.IsActive)
                </label>
            </div>
            <div class="form-group p-1">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="p-1">
    <a asp-action="Index">Back to List</a>
</div>

