@model ERPWebApp.Models.QCStationLocation

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Details</h1>

<div>
    <h4>QC Station Location</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.QCStationLocationName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.QCStationLocationName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DepartmentId)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DepartmentId) - @Html.DisplayFor(model => model.Departments.DepartmentName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsActive)
        </dd>
    </dl>
</div>
<div>
    @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager) || this.User.IsInRole(RoleList.QCManager))
    {
        <a asp-action="Edit" asp-route-id="@Model.QCStationLocationId">Edit</a>
    }
    |
    <a asp-action="Index">Back to List</a>
</div>
