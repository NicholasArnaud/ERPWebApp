@model ERPWebApp.Models.QualityControlCapture

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Details</h1>

<div>
    <h4>QualityControlCapture</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.OrderNumber)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.OrderNumber)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.QCStationLocationId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Locations.QCStationLocationName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DepartmentId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Departments.DepartmentName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.SkuNumber)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.SkuNumber)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.OrderDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.OrderDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.QCDiagnosisId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Diagnoses.QCDiagnosisName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.EmployeeId)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Employees.FullName) - @Html.DisplayFor(model => model.Employees.EmployeeReferenceNumber)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CaptureDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CaptureDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.QCPerson)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.QCPerson)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Quantity)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Quantity)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.BatchNumber)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BatchNumber)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Notes)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Notes)
        </dd>
    </dl>
</div>
<div>
    @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager) || this.User.IsInRole(RoleList.QCManager))
    {
        <a asp-action="Edit" asp-route-id="@Model.QualityControlCaptureId">Edit</a>
    }
    |
    <a asp-action="Index">Back to List</a>
</div>
