@model IEnumerable<ERPWebApp.Models.QualityControlCapture>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">QC Capture Data</h3>
            </div>
            <div class="card-body">
                @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager) || this.User.IsInRole(RoleList.QCManager))
                {
                    <ul class="nav nav-tabs nav-bordered mb-3">
                        <li class="nav-item">
                            <div class="col-sm-3 col-md-2">
                                <div class="floatleft">
                                    <a class="nav-link" asp-action="Create">
                                        <div type="button" class="btn btn-dark mb-2">Create</div>
                                    </a>
                                </div>
                            </div>
                        </li>
                    </ul>
                }
                <table class="table dt-responsive webkit-nowrap w-100" id="QCCapture-datatable">
                    <thead>
                        <tr>
                            <th>
                                @Html.DisplayNameFor(model => model.OrderNumber)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.QCStationLocationId)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.DepartmentId)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.SkuNumber)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.OrderDate)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.QCDiagnosisId)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.EmployeeId)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.CaptureDate)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.QCPerson)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.Quantity)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.BatchNumber)
                            </th>
                            <th>
                                @Html.DisplayNameFor(model => model.Notes)
                            </th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @Html.DisplayFor(modelItem => item.OrderNumber)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Locations.QCStationLocationName)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Departments.DepartmentName)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.SkuNumber)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.OrderDate)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Diagnoses.QCDiagnosisName)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Employees.FullName) - @Html.DisplayFor(modelItem =>  item.Employees.EmployeeReferenceNumber)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.CaptureDate)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.QCPerson)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Quantity)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.BatchNumber)
                                </td>
                                <td>
                                    @Html.DisplayFor(modelItem => item.Notes)
                                </td>
                                <td>
                                    @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager) || this.User.IsInRole(RoleList.QCManager))
                                    {
                                        <a class="action-icon" asp-action="Edit" asp-route-id="@item.QualityControlCaptureId"><i class="mdi mdi-24px mdi-pencil"></i></a>
                                    }
                                    <a class="action-icon" asp-action="Details" asp-route-id="@item.QualityControlCaptureId"><i class="mdi mdi-24px mdi-book-information-variant"></i></a>
                                    @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.FinancialManager) || this.User.IsInRole(RoleList.QCManager))
                                    {
                                        <a class="action-icon" asp-action="Delete" asp-route-id="@item.QualityControlCaptureId"><i class="mdi mdi-24px mdi-delete"></i></a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");

    <script type="text/javascript">
        $(document).ready(function () {
            $("#QCCapture-datatable").DataTable({
                keys: !0, language: {
                    paginate: {
                        previous: "<i class='mdi mdi-chevron-left'>", next: "<i class='mdi mdi-chevron-right'>"
                    },

                }, drawCallback: function () {
                    $(".dataTables_paginate > .pagination").addClass("pagination-rounded")
                }
            });
        });
    </script>
    }
}
