@model int?

<div class="row">
    <div class="col-12">
        <div class="card">

            <div class="card-header">
                <h3 class="card-title">PowerBI Reports</h3>
            </div>

            <div class="card-body">

                <div class="row">
                    <div class="col-3">

                        <form method="get" action="PowerBIReports" id="powerbi-query-form">
                            <div class="mb-3">
                                <label for="queries">Queries</label>
                                <select class="form-select select2" data-toggle="select2" name="Query" id="queries" required>
                                    <option value="-1">Choose Query</option>
                                    <option value="1">Average Shipment Cost by Sku & Date Range</option>
                                    <option value="2">Average Shipment Cost by Service & Date Range</option>
                                    <option value="3">All Item Amounts Shipped by Date Range</option>
                                    <option value="4">Amount an Item has been shipped by Date Range</option>
                                    <option value="5">Get Sum Of Order Sales By Date Range (order items)</option>
                                    <option value="6">Get Sum Of Order Sales By Date Range (Sum of order items)</option>
                                    <option value="7">Get On-hand by Sites</option>
                                    <option value="8">Inventory Balance</option>
                                    @* <option value="9">Stock History Report</option> *@
                                    <option value="10">Product Stock Report</option>
                                    <option value="11">Cycle Count Report</option>
                                    @* <option value="12">Stock History Report With Additions/Subtractions</option> *@
                                </select>
                            </div>
                        </form>

                    </div>
                </div>

                <div class="row">
                    <div class="col-12">

                        @if (Model != null && Model.Value == 1)
                        {
                            <iframe title="GetAvgShippingCostInDateRangeBySku Report" width="100%" height="1405px" src="https://app.powerbi.com/reportEmbed?reportId=f6d678ab-237a-4266-8f68-98855d22aa4f&autoAuth=true&ctid=cd185f77-47bf-4be6-87b7-1d611fbb6a8c" frameborder="0" allowFullScreen="true"></iframe>
                        }

                        @if (Model != null && Model.Value == 2)
                        {
                            <iframe title="GetAvgShippingCostInDateRangeBySku Report" width="100%" height="1405px" src="https://app.powerbi.com/reportEmbed?reportId=da174415-2972-4560-a5b3-522504fc9ce4&autoAuth=true&ctid=cd185f77-47bf-4be6-87b7-1d611fbb6a8c" frameborder="0" allowFullScreen="true"></iframe>
                        }

                        @if (Model != null && Model.Value == 3)
                        {
                            <iframe title="GetAvgShippingCostInDateRangeBySku Report" width="100%" height="1405px" src="https://app.powerbi.com/reportEmbed?reportId=95ef06b5-6590-4c29-962e-7dfbf96a25f0&autoAuth=true&ctid=cd185f77-47bf-4be6-87b7-1d611fbb6a8c" frameborder="0" allowFullScreen="true"></iframe>
                        }

                        @if (Model != null && Model.Value == 4)
                        {
                            <iframe title="GetAvgShippingCostInDateRangeBySku Report" width="100%" height="1405px" src="https://app.powerbi.com/reportEmbed?reportId=f6d5b547-d33b-4580-ae6c-3176c69c1261&autoAuth=true&ctid=cd185f77-47bf-4be6-87b7-1d611fbb6a8c" frameborder="0" allowFullScreen="true"></iframe>
                        }

                        @if (Model != null && Model.Value == 5)
                        {
                            <iframe title="GetSumOfOrderSalesByDateRange Report - 1 (Order Items)" width="100%" height="1405px" src="https://app.powerbi.com/reportEmbed?reportId=6aa4e388-fbbf-4335-8e53-fc24b864d710&autoAuth=true&ctid=cd185f77-47bf-4be6-87b7-1d611fbb6a8c" frameborder="0" allowFullScreen="true"></iframe>
                        }

                        @if (Model != null && Model.Value == 6)
                        {
                            <iframe title="GetSumOfOrderSalesByDateRange Report - 2 (Sum Of Order Items)" width="100%" height="1405px" src="https://app.powerbi.com/reportEmbed?reportId=c860c132-51f6-40a7-92a0-eb2e6799bcf5&autoAuth=true&ctid=cd185f77-47bf-4be6-87b7-1d611fbb6a8c" frameborder="0" allowFullScreen="true"></iframe>
                        }

                        @if (Model != null && Model.Value == 7)
                        {
                            <iframe title="Get On-Hands Report" width="100%" height="1405px" src="https://app.powerbi.com/reportEmbed?reportId=884fe249-ca5a-4835-9445-5cf56b078ca6&autoAuth=true&ctid=cd185f77-47bf-4be6-87b7-1d611fbb6a8c" frameborder="0" allowFullScreen="true"></iframe>
                        }

                        @if (Model != null && Model.Value == 8)
                        {
                            <iframe title="Inventory Balance Report - LiveData" width="100%" height="1405px" src="https://app.powerbi.com/reportEmbed?reportId=a8cef69f-dfe7-468e-a2bb-6c8b1009629a&autoAuth=true&ctid=cd185f77-47bf-4be6-87b7-1d611fbb6a8c" frameborder="0" allowFullScreen="true"></iframe>
                        }

                        @if (Model != null && Model.Value == 10)
                        {
                            <iframe title="Product Stock Report" width="100%" height="1405px" src="https://app.powerbi.com/reportEmbed?reportId=897573f7-e3a7-4c49-8ed7-cc00be7aebe5&autoAuth=true&ctid=cd185f77-47bf-4be6-87b7-1d611fbb6a8c" frameborder="0" allowFullScreen="true"></iframe>
                        }

                        @if (Model != null && Model.Value == 11)
                        {
                            <iframe title="Cycle Count Report" width="100%" height="1405px" src="https://app.powerbi.com/reportEmbed?reportId=91079866-d05c-4a9e-8645-5244623a4c8b&autoAuth=true&ctid=cd185f77-47bf-4be6-87b7-1d611fbb6a8c" frameborder="0" allowFullScreen="true"></iframe>
                        }

                    </div>
                </div>

            </div>

        </div>
    </div>
</div>


@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script type="text/javascript">
        $(document).ready(function () {

            $("#queries").select2();
            $('#queries').val(@(Model == null ? -1 : Model.Value)).trigger('change');

            $("#queries").on('select2:select', function () {
                $("#powerbi-query-form").submit();
            });

        });
    </script>

}