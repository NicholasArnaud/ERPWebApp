@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Error.</h1>
<h2 class="text-danger">Some data has fallen into the river in our Database!! Let me know so we can rescue it!</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}
<h3>About the Issue</h3>

@if (ViewBag.ErrorPath != null)
{
    <p>Error Path: @ViewBag.ErrorPath</p>
}
@if (ViewBag.ErrorMessage != null)
{
    <p>Error Message: @ViewBag.ErrorMessage</p>
}
@if (ViewBag.ErrorCode != null)
{
    if (ViewBag.ErrorCode == 404)
    {
        <p>Error Code: @ViewBag.ErrorCode Not Found</p>
    }
    else if (ViewBag.ErrorCode == 401)
    {
        <p>Error Code: @ViewBag.ErrorCode Unauthorized</p>
    }
    else if (ViewBag.ErrorCode == 500)
    {
        <p>Error Code: @ViewBag.ErrorCode Internal Server Error</p>
    }
    else if (ViewBag.ErrorCode == 502)
    {
        <p>Error Code: @ViewBag.ErrorCode Bad Gateway</p>
    }
    else
    {
        <p>Error Code: @ViewBag.ErrorCode </p>
    }
}

<p>
    This happens usually because our data expects there to be a bridge.
    Our data wants to really trust us so it doesn't look where its going so it just falls in.
    Let me know what led our poor data astray by telling me the steps that got it here so I can build that bridge. Thanks!
</p>
@*<h3>Development Mode</h3>
    <p>
        Swapping to <strong>Development</strong> environment will display more detailed information about the error that occurred.
    </p>
    <p>
        <strong>The Development environment shouldn't be enabled for deployed applications.</strong>
        It can result in displaying sensitive information from exceptions to end users.
        For local debugging, enable the <strong>Development</strong> environment by setting the <strong>ASPNETCORE_ENVIRONMENT</strong> environment variable to <strong>Development</strong>
        and restarting the app.
    </p>*@
