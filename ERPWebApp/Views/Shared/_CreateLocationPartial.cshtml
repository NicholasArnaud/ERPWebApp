@model ERPWebApp.Models.Inventory.Location

<h4>Location</h4>
<hr />
<div class="row">
    <div class="col-md-12">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row">
            <div class="col-md-6 col-sm-12">
                <div class="form-group">
                    <label asp-for="SiteId" class="control-label"></label>
                    <select asp-for="SiteId" name="Location.SiteId" class="select2 form-control" asp-items="ViewBag.Site"></select>
                </div>
            </div>
            <div class="col-md-6 col-sm-12">
                <div class="form-group">
                    <label asp-for="LocationName" class="control-label"></label>
                    <input asp-for="LocationName" name="Location.LocationName" class="form-control" />
                    <span asp-validation-for="LocationName" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 col-sm-12">
                <label asp-for="LocationDescription" class="control-label"></label>
                <input asp-for="LocationDescription" name="Location.LocationDescription" class="form-control" />
                <span asp-validation-for="LocationDescription" class="text-danger"></span>

            </div>
            <div class="col-md-6 col-sm-12">
                <label asp-for="Type" class="control-label"></label>
                <select asp-for="Type" name="Location.Type" asp-items="@Html.GetEnumSelectList<ERPWebApp.Models.Inventory.LocationType>()" class="form-control"></select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>
        </div>
        <div class="row mt-2">
            <div class="col-md-6 col-sm-12">
                <div class="form-group form-check">
                    <label class="form-check-label">
                        <input class="form-check-input" name="Location.IsActive" asp-for="IsActive" checked /> @Html.DisplayNameFor(model => model.IsActive)
                    </label>
                </div>
                <div class="form-group form-check">
                    <label class="form-check-label">
                        <input class="form-check-input" name="Location.IsExternal" asp-for="IsExternal" /> @Html.DisplayNameFor(model => model.IsExternal)
                    </label>
                </div>
            </div>
        </div>
    </div>
</div>
