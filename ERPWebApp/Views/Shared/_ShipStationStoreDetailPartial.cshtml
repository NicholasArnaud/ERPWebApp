@model ERPWebApp.Models.ShipStationStore

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title">ShipStation Store</h5>
        @if(User.IsInRole(RoleList.ProductionManager) || User.IsInRole(RoleList.Administrator))
        {
            <div>
                <a asp-controller="ShipStationStores" asp-action="Edit" asp-route-id="@Model.ShipStationStoreId">
                    <button type="button" class="btn btn-info"><span class="mdi mdi-18px mdi-arrow-top-left-thick">&nbsp;Edit</span></button>
                </a>
            </div>
        }
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model =>model.StoreName)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model =>model.StoreName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model =>model.ContactName)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model =>model.ContactName)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model =>model.PhoneNumber)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model =>model.PhoneNumber)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model =>model.FaxNumber)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model =>model.FaxNumber)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model =>model.Email)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model =>model.Email)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model =>model.PublicEmail)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model =>model.PublicEmail)
            </dd>
            @if(User.IsInRole(RoleList.Administrator) ||User.IsInRole(RoleList.Manager) || User.IsInRole(RoleList.CustomerSupportManager))
            {
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model =>model.Address)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model =>model.Address)
                </dd>
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model =>model.Notes)
                </dt>
                <dd class="col-sm-10">
                    @Html.DisplayFor(model =>model.Notes)
                </dd>
            }
        </dl>
    </div>
</div>