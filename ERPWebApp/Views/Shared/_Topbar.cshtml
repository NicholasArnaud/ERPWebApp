@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<div class="navbar-custom">
    <div class="topbar container-fluid">
        <div class="d-flex align-items-center gap-lg-2 gap-1">
            <div class="logo-topbar">
                <!-- LOGO -->
                <a asp-area="" asp-controller="Home" asp-action="Index">
                    <!--Holiday Themed Logos-->
                    @if (DateTime.Today.Month == 10 &&
                    User.Identity.Name != null &&
                    !User.IsInRole("Seller Basic"))
                    {
                        if(DateTime.Today.Day % 2 == 0)
                        {
                            <span class="logo-lg">
                                <img class="text-center logo-light" alt="logo" src="~/Images/HalloweenImages/LogoVariant01.png" width="180" style="height:50px;">
                            </span>
                            <span class="logo-sm">
                                <img class="text-center logo-light" alt="small logo" src="~/Images/HalloweenImages/IconVariant01.png" width="50" style="height:50px;">
                            </span>
                        }
                        else
                        {
                            <span class="logo-lg">
                                <img class="text-center logo-light" alt="logo" src="~/Images/HalloweenImages/LogoVariant02.png" width="180" style="height:50px;">
                            </span>
                            <span class="logo-sm">
                                <img class="text-center logo-light" alt="small logo" src="~/Images/HalloweenImages/IconVariant02.png" width="50" style="height:50px;">
                            </span>
                        }
                    }
                    else if (DateTime.Today.Month == 12 && 
                    User.Identity.Name != null &&
                    !User.IsInRole("Seller Basic"))
                    {
                        <span class="logo-lg">
                            <img class="text-center logo-light" alt="logo" src="~/Images/ChristmasImages/LogoVariant01.svg" width="180" style="height:50px;">
                        </span>
                        <span class="logo-sm">
                            <img class="text-center logo-light" alt="small logo" src="~/Images/ChristmasImages/IconVariant01.svg" width="50" style="height:50px;">
                        </span>
                    }
                    else
                    {
                        <span class="logo-lg">
                            <img class="text-center logo-light" alt="logo" src="~/Images/image.png" width="150" style="height:40px;">
                        </span>
                        <span class="logo-sm">
                            <img class="text-center logo-light" alt="small logo" src="~/Images/image.png" width="50" style="height:40px;">
                        </span>
                    }
                    
                </a>
            </div>
            <!-- Sidebar Menu Toggle Button -->
            <button class="button-toggle-menu" aria-label="Toggle Sidebar">
                <i class="mdi mdi-menu"></i>
            </button>

            

           
        </div>
        <select class="select2 form-control" data-toggle="select2" data-placeholder="Search..." id="page-search">
        </select>
        <ul class="topbar-menu d-flex align-items-center gap-3">
            <!-- User Profile-->
            @if (SignInManager.IsSignedIn(User))
            {
                <li class="dropdown">
                    <a class="nav-link dropdown-toggle arrow-none nav-user px-2" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="false" aria-expanded="false">
                        <span class="account-user-avatar">
                            <img src="~/lib/hyper-assets/images/users/avatar-1.jpg" alt="user-image" width="32" class="rounded-circle">
                        </span>
                        <span class="d-lg-flex flex-column gap-1 d-none">
                            <h5 class="my-0">@User.Identity.Name</h5>
                        </span>
                    </a>
                    <div class="dropdown-menu dropdown-menu-end dropdown-menu-animated profile-dropdown">
                        <!-- item-->
                        <div class=" dropdown-header noti-title">
                            <h6 class="text-overflow m-0">Welcome !</h6>
                        </div>

                        <!-- item-->
                        <a class="dropdown-item notify-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                            <i class="mdi mdi-account-circle mr-1"></i>
                            <span>My Account</span>
                        </a>


                        <!-- item-->
                        <a class="dropdown-item notify-item" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                            <i class="mdi mdi-logout mr-1"></i>
                            <span>Logout</span>
                        </a>
                    </div>
                </li>
            }
            else
            {
                <li class="dropdown">
                    <a class="nav-link dropdown-toggle arrow-none  nav-user px-2" data-toggle="dropdown" href="#" role="button" aria-haspopup="false" aria-expanded="false">
                        <i class="dripicons-gear noti-icon"></i>
                        <span class="d-lg-flex flex-column gap-1 d-none">
                            <h5 class="my-0">@User.Identity.Name</h5>
                        </span>
                    </a>
                    <div class="dropdown-menu dropdown-menu-end dropdown-menu-animated profile-dropdown">
                        <!-- item-->
                        <div class=" dropdown-header noti-title">
                            <h6 class="text-overflow m-0">Welcome !</h6>
                        </div>

                        <!-- item-->
                        <a class="dropdown-item notify-item" asp-area="Identity" asp-page="/Account/Register">
                            <i class="mdi mdi-account-circle mr-1"></i>
                            <span>Register</span>
                        </a>


                        <!-- item-->
                        <a class="dropdown-item notify-item" asp-area="Identity" asp-page="/Account/Login">
                            <i class="mdi mdi-logout mr-1"></i>
                            <span>Login</span>
                        </a>
                    </div>
                </li>
            }
            <!-- end User Profile-->
        </ul>
    </div>
</div>