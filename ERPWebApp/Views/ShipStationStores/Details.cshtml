@model ERPWebApp.Models.ShipStationStore

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Details</h1>
<hr />
<div class="container-fluid text-white">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">ShipStationStore</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="card-title">Ship Station Store</h2>
            <div>
                <a asp-action="Edit" asp-route-id="@Model.ShipStationStoreId">
                    <button type="button" class="btn btn-info"><span class="mdi mdi-18px mdi-arrow-top-left-thick">&nbsp;Edit</span></button>
                </a>
                <a asp-action="Index">
                    <button type="button" class="btn btn-info"><span class="mdi mdi-18px mdi-arrow-top-left-thick">&nbsp;Back to List</span></button>
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-6">
                    <div class="form-group">
                        <label asp-for="StoreName" class="control-label"></label>
                        @Html.TextBoxFor(model => model.StoreName, new { @class = "form-control",  type = "text", @readonly = "readonly" })
                    </div>
                    <div class="form-group">
                        <label asp-for="ContactName" class="control-label"></label>
                        @Html.TextBoxFor(model => model.ContactName, new { @class = "form-control",  type = "text", @readonly = "readonly" })
                    </div>
                    <div class="form-group">
                        <label asp-for="PhoneNumber" class="control-label"></label>
                        @Html.TextBoxFor(model => model.PhoneNumber, new { @class = "form-control", type = "text", @readonly = "readonly" })
                    </div>
                    <div class="form-group">
                        <label asp-for="FaxNumber" class="control-label"></label>
                        @Html.TextBoxFor(model => model.FaxNumber, new { @class = "form-control",  type = "text", @readonly = "readonly" })
                    </div>
                    <div class="form-group mt-2">
                        <label asp-for="Email" class="control-label"></label>
                        @Html.TextBoxFor(model => model.Email, new { @class = "form-control",  type = "text", @readonly = "readonly" })
                    </div>
                    <div class="form-group mt-2">
                        <label asp-for="PublicEmail" class="control-label"></label>
                        @Html.TextBoxFor(model => model.PublicEmail, new { @class = "form-control",  type = "text", @readonly = "readonly" })
                    </div>
                    <div class="form-group mt-2">
                        <label asp-for="Address" class="control-label"></label>
                        @Html.TextBoxFor(model => model.Address, new { @class = "form-control",  type = "text", @readonly = "readonly" })
                    </div>
                    <div class="form-group mt-2">
                        <label asp-for="HasIncreasedPricing" class="control-label"></label>
                        @if (@Html.ValueFor(model => model.HasIncreasedPricing) == "True")
                        {
                            <input value="Yes" class="form-control" readonly />
                        }
                        else
                        {
                            <input value="No" class="form-control" readonly />
                        }
                    </div>
                    <div class="form-group mt-2">
                        <label asp-for="IsActive" class="control-label"></label>
                        @if (@Model.IsActive)
                        {
                            <input value="Yes" class="form-control" readonly />
                        }
                        else
                        {
                            <input value="No" class="form-control" readonly />
                        }
                    </div>
                    <div class="form-group col-md-12">
                        <label asp-for="Notes">Notes</label>
                        @Html.TextAreaFor(model => model.Notes, new { @class = "form-control", rows = "5" })
                        @Html.ValidationMessageFor(model => model.Notes, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}