@model ERPWebApp.Models.Inventory.Site

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="row">
    <div class="col-12">

        <div class="card">

            <div class="card-header">
                <div class="row">
                    <div class="col-md-9 col-sm-7 col-xs-12 card-title">
                        <h3>Delete</h3>
                        <h4>Are you sure you want to delete this?</h4>
                        <h5>Site</h5>
                    </div>
                </div>
            </div>

            <div class="card-body">

                <dl class="row">
                    <dt class = "col-sm-2">
                        @Html.DisplayNameFor(model => model.SiteName)
                    </dt>
                    <dd class = "col-sm-10">
                        @Html.DisplayFor(model => model.SiteName)
                    </dd>
                    <dt class = "col-sm-2">
                        @Html.DisplayNameFor(model => model.SiteDescription)
                    </dt>
                    <dd class = "col-sm-10">
                        @Html.DisplayFor(model => model.SiteDescription)
                    </dd>
                    <dt class = "col-sm-2">
                        @Html.DisplayNameFor(model => model.SiteVolume)
                    </dt>
                    <dd class = "col-sm-10">
                        @Html.DisplayFor(model => model.SiteVolume)
                    </dd>
                    <dt class = "col-sm-2">
                        @Html.DisplayNameFor(model => model.IsActive)
                    </dt>
                    <dd class = "col-sm-10">
                        @Html.DisplayFor(model => model.IsActive)
                    </dd>
                    @if (User.IsInRole(RoleList.Administrator) || User.IsInRole(RoleList.ExternalViewer))
                    {
                        <dt class="col-sm-2">
                            @Html.DisplayNameFor(model => model.IsExternal)
                        </dt>
                        <dd class="col-sm-10">
                            @Html.DisplayFor(model => model.IsExternal)
                        </dd>
                    }
                </dl>
    
                <form asp-action="Delete">
                    <input type="hidden" asp-for="SiteId" />
                    <input type="submit" value="Delete" class="btn btn-danger" /> |
                    <a asp-action="Index">Back to List</a>
                </form>

            </div>

        </div>

    </div>
</div>
