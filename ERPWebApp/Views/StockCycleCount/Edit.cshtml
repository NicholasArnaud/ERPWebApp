@model ERPWebApp.Models.Inventory.Stock
<form asp-action="Edit">

    <label asp-for="StockId" hidden></label>
    <input asp-for="StockId" id="editid" value="@Model.StockId" type="hidden" >

    <div class="form-group p-1">
        <label class="control-label">Product</label>
        <input value="@Model.Products.Sku" class="form-control" disabled />
    </div>

    <div class="form-group p-1">
        <label class="control-label">Description</label>
        <input value="@Model.Products.Description" class="form-control" disabled />
    </div>

    <div class="form-group p-1">
        <label class="control-label">Site</label>
        <input value="@Model.Location.Sites.SiteName" class="form-control" disabled />
    </div>

    <div class="form-group p-1">
        <label class="control-label">Location</label>
        <input value="@Model.Location.LocationName" class="form-control" disabled />
    </div>

    <div class="form-group p-1">
        <label asp-for="TotalAvailable" class="control-label">Count</label>
        <input asp-for="TotalAvailable" id="edit-count" required="required" type="number" class="form-control" />
    </div>

    <div class="modal-footer">
        <a id="error-message-edit" style="color:pink"></a>
        <!--change buttons to coordinate to a post action where ProductVendorMapping values are changed based on inputs-->
        <button type="button" class="btn btn-danger" data-bs-dismiss="modal" aria-hidden="true">Cancel</button>
        @if (this.User.IsInRole(RoleList.Administrator) || this.User.IsInRole(RoleList.InventoryManager) || this.User.IsInRole(RoleList.ShippingManager))
        {
            <input type="submit" value="Save" class="btn btn-primary" />
        }
    </div>

</form>
<script language="javascript" type="text/javascript">
    function EditStock(){
        var count = $('edit-count').val();
        var id = $('editid').val();
        $.ajax({
            url: '/StockCycleCount/Edit',
            type: 'POST',
            data: {id: id, count: count},
            success: function (partialView) {
                $("#edit-modal-view").html(partialView);
                console.log("Grabbed Detail Info");
            },
            error: function (data) {
                console.log(data);
            }
        });
    }
</script>