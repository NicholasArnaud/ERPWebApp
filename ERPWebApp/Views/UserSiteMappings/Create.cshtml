@model ERPWebApp.Models.Mappings.UserSiteMapping

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>@Html.DisplayNameFor(model => model.UserSiteMappingId)</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="UserId" class="control-label"></label>
                <select asp-for="UserId" class="form-control select2" data-toggle="select2" asp-items="ViewBag.UserId" id="userId-select2">
                    <option></option>
                </select>
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SiteId" class="control-label"></label>
                <select asp-for="SiteId" class="form-control select2" data-toggle="select2" asp-items="ViewBag.SiteId" id="siteId-select2">
                    <option value='0'></option>
                </select>
                <span asp-validation-for="SiteId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script type="text/javascript">
        $(document).ready(function() {
            $("#userId-select2").select2({
                placeholder: 'Select a User.'
            });
            $("#siteId-select2").select2({
                placeholder: {
                    id: '0',
                    text: 'Select a Site.'
                }
            });
        });
    </script>
}
