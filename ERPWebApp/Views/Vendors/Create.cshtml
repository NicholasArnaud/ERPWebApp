                "Yemen", "Zambia", "Zimbabwe", "Åland Islands"
            ];

            $('#state-list').typeahead({
                hint: true,
                highlight: true,
                minLength: 1
            },
                {
                    name: 'states',
                    source: substringMatcher(states)
                });
            $('#country-list').typeahead({
                hint: true,
                highlight: true,
                minLength: 3
            },
                {
                    name: 'countries',
                    source: substringMatcher(countryList)
                });
        });
    </script>
}
