                "Brunei Darussalam", "Bulgaria", "Burkina Faso", "Burundi", "Cabo Verde", "Cambodia",
                "Cameroon", "Canada", "Cayman Islands (the)", "Central African Republic (the)",
                "Chad", "Chile", "China", "Christmas Island", "Cocos (Keeling) Islands (the)",
                "Colombia", "Comoros (the)", "Congo (the Democratic Republic of the)", "Congo (the)",
                "Cook Islands (the)", "Costa Rica", "Croatia", "Cuba", "Curaçao", "Cyprus", "Czechia",
