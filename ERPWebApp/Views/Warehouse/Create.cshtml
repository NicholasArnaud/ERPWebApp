@model ERPWebApp.Models.Warehouse

@{
    ViewData["Title"] = "Create Location";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Create</h1>

<h4>Warehouse</h4>
<hr />
<div class="row">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row">
            <!-- Warehouse Name -->
            <div class="form-group p-1 col-md-4">
                <label asp-for="WarehouseName" class="control-label"></label>
                <input asp-for="WarehouseName" class="form-control" />
                <span asp-validation-for="WarehouseName" class="text-danger"></span>
            </div>

            <!-- Company -->
            <div class="form-group p-1 col-md-4">
                <label asp-for="Company" class="control-label"></label>
                <input asp-for="Company" class="form-control" id="company" />
                <span asp-validation-for="Company" class="text-danger"></span>
            </div>

            <!-- Country -->
            <div class="form-group p-1 col-md-4">
                <label asp-for="Country" class="control-label"></label>
                <input asp-for="Country" class="form-control" id="country" />
                <span asp-validation-for="Country" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="form-group p-1 col-md-4">
                <label asp-for="StreetAddress1" class="control-label"></label>
                <input asp-for="StreetAddress1" class="form-control" id="StreetAddress1" />
                <span asp-validation-for="StreetAddress1" class="text-danger"></span>
            </div>
            <div class="form-group p-1 col-md-4">
                <label asp-for="StreetAddress2" class="control-label"></label>
                <input asp-for="StreetAddress2" class="form-control" id="StreetAddress2" />
                <span asp-validation-for="StreetAddress2" class="text-danger"></span>
            </div>
            <div class="form-group p-1 col-md-4">
                <label asp-for="City" class="control-label"></label>
                <input asp-for="City" class="form-control" id="City" />
                <span asp-validation-for="City" class="text-danger"></span>
            </div>
            <div class="form-group p-1 col-md-4">
                <label asp-for="State" class="control-label"></label>
                <input asp-for="State" class="form-control" id="State" />
                <span asp-validation-for="State" class="text-danger"></span>
            </div>
           
            <div class="form-group p-1 col-md-4">
                <label asp-for="PostalCode" class="control-label"></label>
                <input asp-for="PostalCode" class="form-control" id="PostalCode" />
                <span asp-validation-for="PostalCode" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <!-- Phone Number -->
            <div class="form-group p-1 col-md-4">
                <label asp-for="PhoneNumber" class="control-label"></label>
                <input asp-for="PhoneNumber" class="form-control" id="Phone" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <!-- Email -->
            <div class="form-group p-1 col-md-4">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- Time Zone -->
            <div class="form-group mb-2 col-md-4">
                <label asp-for="TimeZone" class="control-label "></label>
                <select asp-for="TimeZone" class="form-control select2" data-toggle="select2" asp-items="ViewBag.TimeZone" id="timeZoneId-select2">
                    <option value="" disabled selected>Select a Time Zone.</option>
                </select>
                <span asp-validation-for="TimeZone" class="text-danger"></span>
            </div>
        </div>

        <!-- Default Warehouse -->
        <div class="form-group p-1 d-flex align-items-center">
            <input class="form-check-input me-2" asp-for="DefaultWarehouse" />
            <label asp-for="DefaultWarehouse" class="form-check-label"></label>
        </div>

        <!-- Same as Return Address -->
        <div class="form-group p-1 d-flex align-items-center">
            <input class="form-check-input me-2" asp-for="SameAsReturnAddress" id="SameAsReturnAddress" />
            <label asp-for="SameAsReturnAddress" class="form-check-label"></label>
        </div>

        <div class="row">
            <h3 class="mt-3">Billing Address</h3>
            <div class="form-group p-1 col-md-4">
                <label asp-for="BillingAddress.company" class="control-label"></label>
                <input asp-for="BillingAddress.company" class="form-control" id="BillingAddress_company" />
                <span asp-validation-for="BillingAddress.company" class="text-danger"></span>
            </div>
            <div class="form-group p-1 col-md-4">
                <label asp-for="BillingAddress.street1" class="control-label"></label>
                <input asp-for="BillingAddress.street1" class="form-control" id="BillingAddress_street1" />
                <span asp-validation-for="BillingAddress.street1" class="text-danger"></span>
            </div>

            <div class="form-group p-1 col-md-4">
                <label asp-for="BillingAddress.street2" class="control-label"></label>
                <input asp-for="BillingAddress.street2" class="form-control" id="BillingAddress_street2" />
                <span asp-validation-for="BillingAddress.street2" class="text-danger"></span>
            </div>

            <div class="form-group p-1 col-md-4">
                <label asp-for="BillingAddress.city" class="control-label"></label>
                <input asp-for="BillingAddress.city" class="form-control" id="BillingAddress_city" />
                <span asp-validation-for="BillingAddress.city" class="text-danger"></span>
            </div>

            <div class="form-group p-1 col-md-4">
                <label asp-for="BillingAddress.state" class="control-label"></label>
                <input asp-for="BillingAddress.state" class="form-control" id="BillingAddress_state" />
                <span asp-validation-for="BillingAddress.state" class="text-danger"></span>
            </div>
            <div class="form-group p-1 col-md-4">
                <label asp-for="BillingAddress.country" class="control-label"></label>
                <input asp-for="BillingAddress.country" class="form-control" id="BillingAddress_country" />
                <span asp-validation-for="BillingAddress.country" class="text-danger"></span>
            </div>
            <div class="form-group p-1 col-md-4">
                <label asp-for="BillingAddress.postalCode" class="control-label"></label>
                <input asp-for="BillingAddress.postalCode" class="form-control" id="BillingAddress_postalCode" />
                <span asp-validation-for="BillingAddress.postalCode" class="text-danger"></span>
            </div>
            <div class="form-group p-1 col-md-4">
                <label asp-for="BillingAddress.phone" class="control-label"></label>
                <input asp-for="BillingAddress.phone" class="form-control" id="BillingAddress_phone" />
                <span asp-validation-for="BillingAddress.phone" class="text-danger"></span>
            </div>
        </div>

        <!-- Submit Button -->
        <div class="form-group">
            <input type="submit" value="Create" class="btn btn-primary" />
        </div>
    </form>
</div>

<div class="mt-2">
    <a class="p-0" asp-action="Index">Back to List</a>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            $('#SameAsReturnAddress').change(function () {
                if ($(this).is(':checked')) {
                    // Copy values from top address fields to return address fields
                    $('#BillingAddress_company').val($('#company').val());
                    $('#BillingAddress_street1').val($('#StreetAddress1').val());
                    $('#BillingAddress_street2').val($('#StreetAddress2').val());
                    $('#BillingAddress_city').val($('#City').val());
                    $('#BillingAddress_state').val($('#State').val());
                    $('#BillingAddress_country').val($('#country').val());
                    $('#BillingAddress_postalCode').val($('#PostalCode').val());
                    $('#BillingAddress_phone').val($('#Phone').val());
                } else {
                    // If unchecked, optionally clear the return address fields
                    $('#BillingAddress_company').val('');
                    $('#BillingAddress_street1').val('');
                    $('#BillingAddress_street2').val('');
                    $('#BillingAddress_city').val('');
                    $('#BillingAddress_state').val('');
                    $('#BillingAddress_country').val('');
                    $('#BillingAddress_postalCode').val('');
                    $('#BillingAddress_phone').val('');
                }
            });
        });
    </script>
}
